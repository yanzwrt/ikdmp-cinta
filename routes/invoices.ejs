<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kelola Tagihan - Admin Portal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/boxicons@2.0.7/css/boxicons.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet">
    <!-- Admin Mobile Optimizations -->
    <link href="/css/admin-mobile.css" rel="stylesheet">
    <link href="/css/responsive-admin.css" rel="stylesheet">
    <style>
        .toast {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 9999;
            min-width: 300px;
        }

        :root {
            --bg-body: #f5f7fb;
            --bg-card: #ffffff;
            --text-color: #212529;
            --text-muted: #6c757d;
            --border-color: #eef2f6;
            --card-shadow: 0 4px 20px rgba(0,0,0,0.02);
        }

        /* Dark Mode Variables */
        [data-theme="dark"] {
            --bg-body: #1a1a1a;
            --bg-card: #2d2d2d;
            --text-color: #e0e0e0;
            --text-muted: #a0a0a0;
            --border-color: #404040;
            --card-shadow: 0 4px 20px rgba(0,0,0,0.2);
        }

        body {
            background-color: var(--bg-body);
            color: var(--text-color);
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        .card, .modal-content {
            background-color: var(--bg-card) !important;
            color: var(--text-color);
            border-color: var(--border-color) !important;
        }
        
        [data-theme="dark"] .table {
            color: var(--text-color);
            border-color: var(--border-color);
        }
        
        [data-theme="dark"] .table-hover tbody tr:hover {
            color: var(--text-color);
            background-color: rgba(255,255,255,0.05);
        }

        [data-theme="dark"] .form-control, 
        [data-theme="dark"] .form-select {
            background-color: #2d2d2d;
            border-color: #404040;
            color: #e0e0e0;
        }
        
        [data-theme="dark"] .text-muted {
            color: #a0a0a0 !important;
        }

        [data-theme="dark"] .nav-tabs .nav-link {
             color: var(--text-muted);
        }
        
        [data-theme="dark"] .nav-tabs .nav-link.active {
             background-color: var(--bg-body);
             border-color: var(--border-color) var(--border-color) var(--bg-body);
             color: var(--text-color);
        }

        .billing-tabs-wrap {
            margin-bottom: 1.5rem;
            padding: 0.55rem 0.75rem;
            border: 1px solid rgba(148, 163, 184, 0.18);
            border-radius: 20px;
            background: linear-gradient(145deg, rgba(255,255,255,0.88), rgba(244,247,255,0.82));
            backdrop-filter: blur(16px);
            box-shadow: 0 14px 34px rgba(37, 99, 235, 0.08);
        }

        [data-theme="dark"] .billing-tabs-wrap {
            background: linear-gradient(145deg, rgba(15,23,42,0.88), rgba(17,24,39,0.9));
            border-color: rgba(148, 163, 184, 0.16);
            box-shadow: 0 18px 36px rgba(2, 8, 23, 0.32);
        }

        .billing-tabs.nav-tabs {
            border-bottom: 0;
            gap: 0.5rem;
            align-items: center;
        }

        .billing-tabs.nav-tabs .nav-item {
            flex: 0 0 auto;
            display: block;
        }

        .billing-tabs.nav-tabs .nav-link {
            position: relative;
            border: 0;
            border-radius: 999px;
            padding: 0.9rem 1rem 1rem;
            color: var(--text-muted);
            font-weight: 700;
            width: auto;
            display: inline-flex;
            align-items: center;
            justify-content: flex-start;
            gap: 0.4rem;
            text-align: left;
            transform: translateY(2px);
        }

        .billing-tabs.nav-tabs .nav-link.active,
        .billing-tabs.nav-tabs .show > .nav-link {
            background: linear-gradient(135deg, #2563eb, #4f46e5) !important;
            color: #fff !important;
            box-shadow: 0 10px 24px rgba(37, 99, 235, 0.18);
            transform: translateY(0);
        }

        .billing-tabs.nav-tabs .nav-link.active::after,
        .billing-tabs.nav-tabs .show > .nav-link::after {
            content: "";
            position: absolute;
            left: 50%;
            bottom: 6px;
            transform: translateX(-50%);
            width: 34px;
            height: 4px;
            border-radius: 999px;
            background: rgba(255,255,255,0.92);
        }

        [data-theme="dark"] .billing-tabs.nav-tabs .nav-link {
            color: #cbd5e1 !important;
        }

        [data-theme="dark"] .billing-tabs.nav-tabs .nav-link.active,
        [data-theme="dark"] .billing-tabs.nav-tabs .show > .nav-link {
            background: linear-gradient(135deg, #2563eb, #4f46e5) !important;
            color: #ffffff !important;
        }
    </style>
    <script>
        // Theme Toggle Functionality
        function toggleTheme() {
            const body = document.body;
            const currentTheme = body.getAttribute('data-theme');
            const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
            
            body.setAttribute('data-theme', newTheme);
            localStorage.setItem('theme', newTheme);
            
            updateThemeButton(newTheme);
        }

        function updateThemeButton(theme) {
            const icon = document.getElementById('themeIcon');
            const text = document.getElementById('themeText');
            const btn = document.getElementById('themeToggle');
            
            if (!icon || !text || !btn) return;

            if (theme === 'dark') {
                icon.className = 'bi bi-moon-stars-fill text-white me-1';
                text.textContent = 'Dark';
                btn.classList.remove('btn-white');
                btn.classList.add('btn-dark');
                // Apply dark mode styles dynamically
                document.documentElement.style.setProperty('--bg-body', '#1a1a1a');
                document.documentElement.style.setProperty('--bg-card', '#2d2d2d');
                document.documentElement.style.setProperty('--text-color', '#ffffff');
                document.documentElement.style.setProperty('--text-muted', '#a0a0a0');
            } else {
                icon.className = 'bi bi-sun-fill text-warning me-1';
                text.textContent = 'Light';
                btn.classList.remove('btn-dark');
                btn.classList.add('btn-white');
                // Apply light mode styles dynamically
                document.documentElement.style.setProperty('--bg-body', '#f5f7fb');
                document.documentElement.style.setProperty('--bg-card', '#ffffff');
                document.documentElement.style.setProperty('--text-color', '#212529');
                document.documentElement.style.setProperty('--text-muted', '#6c757d');
            }
        }

        // Initialize Theme
        document.addEventListener('DOMContentLoaded', () => {
            const savedTheme = localStorage.getItem('theme') || 'light';
            document.body.setAttribute('data-theme', savedTheme);
            updateThemeButton(savedTheme);
        });
    </script>
</head>

<body>
    <div class="container-fluid">
            <!-- Sidebar -->
            <%- include('../../partials/billing-responsive-sidebar', { page: 'invoices' }) %>

                <!-- Main content -->
                <main class="main-content px-md-4">
                    <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3">
                        <h3 class="h3 mb-0">Invoice</h3>
                        <button class="btn btn-white shadow-sm border rounded-pill px-3" id="themeToggle" onclick="toggleTheme()">
                            <i class="bi bi-sun-fill text-warning me-1" id="themeIcon"></i> <span class="small fw-bold" id="themeText">Light</span>
                        </button>
                    </div>

                    <!-- Tab Navigation -->
                    <div class="billing-tabs-wrap mb-4">
                    <ul class="nav nav-tabs billing-tabs">
                        <li class="nav-item">
                            <a class="nav-link <%= typeof page !== 'undefined' && page === 'invoices' ? 'active' : '' %>"
                                href="/admin/billing/invoices">
                                <i class="bi bi-receipt"></i> Buat Invoice
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= typeof page !== 'undefined' && page === 'auto-invoice' ? 'active' : '' %>"
                                href="/admin/billing/auto-invoice">
                                <i class="bi bi-calendar-check"></i> Auto Invoice
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= typeof page !== 'undefined' && page === 'invoices-by-type' ? 'active' : '' %>"
                                href="/admin/billing/invoices-by-type">
                                <i class="bi bi-list-ul"></i> Invoice per Tipe
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= typeof page !== 'undefined' && page === 'invoice-list' ? 'active' : '' %>"
                                href="/admin/billing/invoice-list">
                                <i class="bi bi-receipt"></i> Semua Invoice
                            </a>
                        </li>
                    </ul>
                    </div>

                    <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 mobile-header-visible"
                        style="border-bottom: 1px solid #dee2e6;">
                        <h1 class="h2">
                            <i class="bx bx-receipt"></i> Kelola Tagihan
                        </h1>
                        <div class="d-flex gap-2">
                            <button id="bulkDeleteBtn" class="btn btn-danger" disabled>
                                <i class="bx bx-trash"></i> Hapus Terpilih
                            </button>
                            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addInvoiceModal">
                                <i class="bx bx-plus"></i> Buat Tagihan
                            </button>
                        </div>
                    </div>

                    <!-- Invoice Table -->
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title mb-0">
                                <i class="bx bx-list-ul"></i> Daftar Tagihan
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table id="invoicesTable" class="table table-striped table-hover">
                                    <thead>
                                        <tr>
                                            <th style="width:36px;">
                                                <input type="checkbox" id="selectAllInvoices" />
                                            </th>
                                            <th>No. Tagihan</th>
                                            <th>Pelanggan</th>
                                            <th>Paket</th>
                                            <th>Jumlah</th>
                                            <th>Status</th>
                                            <th>Jatuh Tempo</th>
                                            <th>Tanggal Dibuat</th>
                                            <th>Aksi</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (invoices && invoices.length> 0) { %>
                                            <% invoices.forEach(function(invoice) { %>
                                                <tr>
                                                    <td>
                                                        <input type="checkbox" class="invoice-checkbox"
                                                            value="<%= invoice.id %>" />
                                                    </td>
                                                    <td>
                                                        <span class="text-body fw-bold">
                                                            <%= invoice.invoice_number %>
                                                        </span>
                                                    </td>
                                                    <td>
                                                        <span class="text-body fw-bold">
                                                            <%= invoice.customer_name %>
                                                        </span>
                                                        <br>
                                                        <small class="text-muted">
                                                            <%= invoice.customer_phone %>
                                                        </small>
                                                    </td>
                                                    <td>
                                                        <%= invoice.package_name %>
                                                    </td>
                                                    <td class="currency-format" data-amount="<%= invoice.amount %>">
                                                        Rp <%=
                                                            Math.round(parseFloat(invoice.amount)).toLocaleString('id-ID')
                                                            %>
                                                    </td>
                                                    <td>
                                                        <% if (invoice.status==='paid' ) { %>
                                                            <span class="badge bg-success">Lunas</span>
                                                            <% } else if (invoice.status==='unpaid' ) { %>
                                                                <% if (new Date(invoice.due_date) < new Date()) { %>
                                                                    <span class="badge bg-danger">Terlambat</span>
                                                                    <% } else { %>
                                                                        <span class="badge bg-warning">Belum
                                                                            Lunas</span>
                                                                        <% } %>
                                                                            <% } %>
                                                        <% if (invoice.payment_status==='pending' && invoice.status !== 'paid') { %>
                                                            <br><span class="badge bg-info text-dark mt-1">Pending Gateway</span>
                                                        <% } else if (invoice.payment_status==='manual_admin' ) { %>
                                                            <br><span class="badge bg-primary mt-1">Manual Admin</span>
                                                        <% } %>
                                                    </td>
                                                    <td>
                                                        <% if (new Date(invoice.due_date) < new Date() &&
                                                            invoice.status==='unpaid' ) { %>
                                                            <span class="text-danger">
                                                                <%= new
                                                                    Date(invoice.due_date).toLocaleDateString('id-ID')
                                                                    %>
                                                            </span>
                                                            <% } else { %>
                                                                <%= new
                                                                    Date(invoice.due_date).toLocaleDateString('id-ID')
                                                                    %>
                                                                    <% } %>
                                                    </td>
                                                    <td>
                                                        <%= new Date(invoice.created_at).toLocaleDateString('id-ID') %>
                                                    </td>
                                                    <td>
                                                        <div class="btn-group" role="group">
                                                            <a href="/admin/billing/invoices/<%= invoice.id %>"
                                                                class="btn btn-sm btn-primary">
                                                                <i class="bx bx-show"></i>
                                                            </a>
                                                            <% if (invoice.status==='unpaid' ) { %>
                                                                <button class="btn btn-sm btn-success"
                                                                    onclick="markAsPaid('<%= invoice.id %>')">
                                                                    <i class="bx bx-check"></i>
                                                                </button>
                                                                <% } %>
                                                                    <a href="/admin/billing/invoices/<%= invoice.id %>/print"
                                                                        target="_blank" class="btn btn-sm btn-info">
                                                                        <i class="bx bx-printer"></i>
                                                                    </a>
                                                                    <button class="btn btn-sm btn-danger"
                                                                        onclick="deleteInvoice('<%= invoice.id %>')">
                                                                        <i class="bx bx-trash"></i>
                                                                    </button>
                                                        </div>
                                                    </td>
                                                </tr>
                                                <% }); %>
                                                    <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </main>
        </div>
    </div>

    <!-- Add Invoice Modal -->
    <div class="modal fade" id="addInvoiceModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Buat Tagihan Baru</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form id="addInvoiceForm">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="customer_id" class="form-label">Pelanggan</label>
                            <select class="form-control" id="customer_id" name="customer_id" required>
                                <option value="">Pilih Pelanggan</option>
                                <% if (customers && customers.length> 0) { %>
                                    <% customers.forEach(function(customer) { %>
                                        <option value="<%= customer.id %>">
                                            <%= customer.name %> (<%= customer.phone %>)
                                        </option>
                                        <% }); %>
                                            <% } %>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="package_id" class="form-label">Paket</label>
                            <select class="form-control" id="package_id" name="package_id" required>
                                <option value="">Pilih Paket</option>
                                <% if (packages && packages.length> 0) { %>
                                    <% packages.forEach(function(package) { %>
                                        <option value="<%= package.id %>" data-price="<%= package.price %>"
                                            data-tax-rate="<%= package.tax_rate !== null && package.tax_rate !== undefined ? package.tax_rate : 11.00 %>">
                                            <%= package.name %> - Rp <%=
                                                    Math.round(parseFloat(package.price)).toLocaleString('id-ID') %>
                                                    <% if (package.tax_rate===0) { %>
                                                        (Tidak Ada PPN)
                                                        <% } else if (package.tax_rate) { %>
                                                            (PPN <%= package.tax_rate.toFixed(2) %>%)
                                                                <% } else { %>
                                                                    (PPN 11.00%)
                                                                    <% } %>
                                        </option>
                                        <% }); %>
                                            <% } %>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="base_amount" class="form-label">Harga Dasar (Sebelum PPN)</label>
                            <input type="number" class="form-control" id="base_amount" readonly>
                        </div>
                        <div class="mb-3">
                            <label for="tax_rate_display" class="form-label">PPN</label>
                            <input type="text" class="form-control" id="tax_rate_display" readonly>
                        </div>
                        <div class="mb-3">
                            <label for="amount" class="form-label">Jumlah (Setelah PPN)</label>
                            <input type="number" class="form-control" id="amount" name="amount" required>
                        </div>
                        <!-- Hidden fields for PPN data -->
                        <input type="hidden" id="base_amount_hidden" name="base_amount">
                        <input type="hidden" id="tax_rate_hidden" name="tax_rate">
                        <div class="mb-3">
                            <label for="due_date" class="form-label">Jatuh Tempo</label>
                            <input type="date" class="form-control" id="due_date" name="due_date" required>
                        </div>
                        <div class="mb-3">
                            <label for="notes" class="form-label">Deskripsi</label>
                            <textarea class="form-control" id="notes" name="notes" rows="3"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                        <button type="submit" class="btn btn-primary">Buat Tagihan</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#invoicesTable').DataTable({
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/id.json',
                    emptyTable: "Tidak ada data yang tersedia",
                    info: "Menampilkan _START_ sampai _END_ dari _TOTAL_ entri",
                    infoEmpty: "Menampilkan 0 sampai 0 dari 0 entri",
                    infoFiltered: "(disaring dari _MAX_ entri keseluruhan)",
                    lengthMenu: "Tampilkan _MENU_ entri",
                    loadingRecords: "Sedang memuat...",
                    processing: "Sedang memproses...",
                    search: "Cari:",
                    zeroRecords: "Tidak ditemukan data yang sesuai",
                    paginate: {
                        first: "Pertama",
                        last: "Terakhir",
                        next: "Selanjutnya",
                        previous: "Sebelumnya"
                    }
                },
                pageLength: 25,
                lengthMenu: [[10, 25, 50, 100], [10, 25, 50, 100]]
            });

            // Auto-fill amount when package is selected
            $('#package_id').on('change', function () {
                const selectedOption = $(this).find('option:selected');
                const price = parseFloat(selectedOption.data('price')) || 0;
                const taxRate = parseFloat(selectedOption.data('tax-rate')) || 0;

                $('#base_amount').val(price);

                // Handle PPN = 0 correctly
                if (taxRate === 0) {
                    $('#tax_rate_display').val('0% (Tidak Ada PPN)');
                    $('#amount').val(price); // No tax added
                } else {
                    $('#tax_rate_display').val(`${taxRate}%`);
                    const amount = price * (1 + taxRate / 100);
                    // Round to integer (hilangkan desimal)
                    $('#amount').val(Math.round(amount));
                }

                // Set hidden fields for PPN data
                $('#base_amount_hidden').val(price);
                $('#tax_rate_hidden').val(taxRate);
            });

            // Set default due date to 30 days from now
            const today = new Date();
            const dueDate = new Date(today.getTime() + (30 * 24 * 60 * 60 * 1000));
            $('#due_date').val(dueDate.toISOString().split('T')[0]);
        });

        // Add Invoice Form
        $('#addInvoiceForm').on('submit', function (e) {
            e.preventDefault();
            const formData = new FormData(this);
            const urlParams = new URLSearchParams();
            for (const [key, value] of formData.entries()) {
                urlParams.append(key, value);
            }

            // Loading state
            const $btn = $(this).find('button[type="submit"]');
            const originalText = $btn.html();
            $btn.prop('disabled', true).html('<i class="bi bi-hourglass-split"></i> Memproses...');

            fetch('/admin/billing/invoices', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8' },
                body: urlParams.toString()
            })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showToast('success', 'Tagihan Berhasil', 'Tagihan berhasil dibuat');
                        $('#addInvoiceModal').modal('hide');
                        // Update table tanpa reload
                        setTimeout(() => {
                            location.reload();
                        }, 1500);
                    } else {
                        showToast('error', 'Gagal Membuat Tagihan', data.message || 'Gagal membuat tagihan');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    showToast('error', 'Error', 'Terjadi kesalahan saat membuat tagihan');
                })
                .finally(() => {
                    // Reset button
                    $btn.prop('disabled', false).html(originalText);
                });
        });

        // Bulk Delete Selected Invoices
        (function initBulkDelete() {
            const bulkBtn = document.getElementById('bulkDeleteBtn');
            const selectAll = document.getElementById('selectAllInvoices');

            const getChecks = () => Array.from(document.querySelectorAll('.invoice-checkbox'));
            const getSelected = () => getChecks().filter(c => c.checked).map(c => parseInt(c.value, 10));

            function updateBulkState() {
                const selected = getSelected();
                bulkBtn.disabled = selected.length === 0;
                const checks = getChecks();
                if (checks.length) {
                    const allChecked = checks.every(c => c.checked);
                    const someChecked = checks.some(c => c.checked);
                    selectAll.checked = allChecked;
                    selectAll.indeterminate = !allChecked && someChecked;
                }
            }

            if (selectAll) {
                selectAll.addEventListener('change', () => {
                    const checked = selectAll.checked;
                    getChecks().forEach(c => { c.checked = checked; });
                    updateBulkState();
                });
            }

            getChecks().forEach(c => c.addEventListener('change', updateBulkState));
            updateBulkState();

            bulkBtn.addEventListener('click', async () => {
                const ids = getSelected();
                if (!ids.length) return;
                if (!confirm(`Hapus ${ids.length} tagihan terpilih?`)) return;
                showToast('info', 'Memproses...', 'Menghapus tagihan terpilih');
                try {
                    const resp = await fetch('/admin/billing/invoices/bulk-delete', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ ids })
                    });
                    const ct = resp.headers.get('content-type') || '';
                    let data;
                    if (ct.includes('application/json')) {
                        data = await resp.json();
                    } else {
                        const text = await resp.text();
                        throw new Error(text?.slice(0, 200) || 'Respons tidak valid');
                    }
                    if (!resp.ok || !data?.success) throw new Error(data?.message || 'Gagal hapus massal');
                    showToast('success', 'Selesai', `Berhasil menghapus ${data.summary.success} dari ${data.summary.total} tagihan`);
                    setTimeout(() => location.reload(), 1200);
                } catch (e) {
                    console.error(e);
                    showToast('error', 'Gagal', e.message || 'Terjadi kesalahan saat hapus massal');
                }
            });
        })();

        // Mark as Paid
        function markAsPaid(invoiceId) {
            if (confirm('Tandai tagihan ini sebagai lunas?')) {
                showToast('info', 'Memproses...', 'Menandai tagihan sebagai lunas');

                // 1) Get invoice amount
                fetch(`/admin/billing/api/invoices/${invoiceId}`)
                    .then(response => response.json())
                    .then(inv => {
                        if (!inv || !inv.success || !inv.invoice) {
                            throw new Error(inv?.message || 'Gagal mengambil data tagihan');
                        }
                        const amount = parseFloat(inv.invoice.amount);
                        // 2) Record payment (this will also update invoice status server-side)
                        return fetch('/admin/billing/payments', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                invoice_id: invoiceId,
                                amount: amount,
                                payment_method: 'manual_admin',
                                reference_number: '',
                                notes: ''
                            })
                        });
                    })
                    .then(response => response.json())
                    .then(result => {
                        if (!result || !result.success) {
                            throw new Error(result?.message || 'Gagal menandai tagihan');
                        }
                        showToast('success', 'Tagihan Lunas', 'Tagihan berhasil ditandai lunas');
                        setTimeout(() => { location.reload(); }, 1500);
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        showToast('error', 'Error', error?.message || 'Terjadi kesalahan saat menandai tagihan');
                    });
            }
        }

        // Delete Invoice
        function deleteInvoice(invoiceId) {
            if (confirm('Apakah Anda yakin ingin menghapus tagihan ini?')) {
                showToast('info', 'Memproses...', 'Menghapus tagihan');

                fetch(`/admin/billing/invoices/${invoiceId}`, {
                    method: 'DELETE'
                })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            showToast('success', 'Tagihan Dihapus', 'Tagihan berhasil dihapus');
                            // Update table tanpa reload
                            setTimeout(() => {
                                location.reload();
                            }, 1500);
                        } else {
                            showToast('error', 'Gagal Menghapus', data.message || 'Gagal menghapus tagihan');
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        showToast('error', 'Error', 'Terjadi kesalahan saat menghapus tagihan');
                    });
            }
        }

        // Toast Container
        const toastContainer = document.createElement('div');
        toastContainer.id = 'toast-container';
        document.body.appendChild(toastContainer);

        // Fungsi toast notification
        function showToast(type, title, message, duration = 5000) {
            const toastId = 'toast-' + Date.now();
            const iconClass = type === 'success' ? 'bi-check-circle' : type === 'error' ? 'bi-x-circle' : 'bi-info-circle';
            const bgClass = type === 'success' ? 'bg-success' : type === 'error' ? 'bg-danger' : 'bg-primary';

            const toastHtml = `
                <div id="${toastId}" class="toast align-items-center text-white ${bgClass} border-0" role="alert" aria-live="assertive" aria-atomic="true">
                    <div class="d-flex">
                        <div class="toast-body">
                            <i class="bi ${iconClass} me-2"></i>
                            <strong>${title}</strong><br>
                            <small>${message}</small>
                        </div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                    </div>
                </div>
            `;

            $('#toast-container').append(toastHtml);
            const toastElement = document.getElementById(toastId);
            const toast = new bootstrap.Toast(toastElement, { delay: duration });
            toast.show();

            // Auto remove after hide
            toastElement.addEventListener('hidden.bs.toast', () => {
                toastElement.remove();
            });
        }
    </script>

    <!-- Currency Helper -->
    <%- include('../../partials/currency-helper') %>

    <script>
        (function () {
            const currentPath = window.location.pathname.replace(/\/+$/, '');
            const billingTabLinks = Array.from(document.querySelectorAll('.billing-tabs .nav-link'));
            let bestMatch = null;

            billingTabLinks.forEach((link) => {
                const linkPath = new URL(link.href, window.location.origin).pathname.replace(/\/+$/, '');
                const isMatch = currentPath === linkPath || currentPath.startsWith(linkPath + '/');

                if (isMatch && (!bestMatch || linkPath.length > bestMatch.path.length)) {
                    bestMatch = { link, path: linkPath };
                }
            });

            if (bestMatch) {
                billingTabLinks.forEach((link) => link.classList.remove('active'));
                bestMatch.link.classList.add('active');
            }
        })();
    </script>


