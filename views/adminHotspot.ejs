<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Admin Hotspot</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/responsive-admin.css" rel="stylesheet">
    <script>document.documentElement.setAttribute('data-theme', localStorage.getItem('theme') || 'light');</script>
    <style>
        :root {
            --primary-gradient: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
            --success-gradient: linear-gradient(135deg, #198754 0%, #146c43 100%);
            --info-gradient: linear-gradient(135deg, #0dcaf0 0%, #0aa2c0 100%);
            --warning-gradient: linear-gradient(135deg, #ffc107 0%, #cc9a06 100%);
            --danger-gradient: linear-gradient(135deg, #dc3545 0%, #b02a37 100%);
            --secondary-gradient: linear-gradient(135deg, #6c757d 0%, #495057 100%);
            --card-shadow: 0 16px 38px rgba(15, 23, 42, 0.08);
            --card-hover-shadow: 0 24px 46px rgba(15, 23, 42, 0.14);
        }
        body { background: #f5f6fa; }
        [data-theme="dark"] body { background: #0f172a; }
        .form-label { font-weight: 600; }
        .dashboard-hero { position: relative; overflow: hidden; border: 1px solid rgba(148,163,184,.22); border-radius: 24px; padding: 16px 20px; background: linear-gradient(145deg, rgba(255,255,255,.88), rgba(244,247,255,.82)), radial-gradient(circle at top left, rgba(96,165,250,.22), transparent 38%); backdrop-filter: blur(18px); box-shadow: 0 18px 44px rgba(37,99,235,.08); margin-bottom: 1.5rem; }
        .dashboard-hero::before { content: ""; position: absolute; inset: auto -60px -110px auto; width: 220px; height: 220px; border-radius: 999px; background: radial-gradient(circle, rgba(96,165,250,.16), transparent 70%); pointer-events: none; }
        .dashboard-hero h4 { font-size: 2rem; font-weight: 800; letter-spacing: -.03em; color: #1e293b; margin-bottom: .4rem; }
        .dashboard-hero p { color: #64748b; margin-bottom: 0; }
        [data-theme="dark"] .dashboard-hero { background: linear-gradient(145deg, rgba(15,23,42,.88), rgba(17,24,39,.9)), radial-gradient(circle at top left, rgba(56,189,248,.14), transparent 42%); border-color: rgba(148,163,184,.22); box-shadow: 0 20px 42px rgba(2,8,23,.32); }
        [data-theme="dark"] .dashboard-hero h4 { color: #f8fafc !important; }
        [data-theme="dark"] .dashboard-hero p { color: #cbd5e1 !important; }
        .theme-toggle-btn { width: 42px; height: 42px; border-radius: 999px; border: 1px solid rgba(148,163,184,.22); background: rgba(255,255,255,.92); color: #1e293b; display: inline-flex; align-items: center; justify-content: center; flex: 0 0 auto; }
        [data-theme="dark"] .theme-toggle-btn { background: rgba(15,23,42,.88); color: #e6eefc; border-color: rgba(148,163,184,.24); }
        body .main-content .nav.nav-tabs { border-bottom: 1px solid rgba(148,163,184,.24) !important; gap: 1.2rem !important; }
        body .main-content .nav.nav-tabs .nav-item { margin-bottom: 0 !important; }
        body .main-content .nav.nav-tabs .nav-link { border: 0 !important; border-radius: 0 !important; background: transparent !important; box-shadow: none !important; color: #64748b !important; font-weight: 700 !important; padding: .7rem .1rem .85rem !important; display: inline-flex !important; align-items: center !important; gap: .45rem !important; border-bottom: 3px solid transparent !important; }
        body .main-content .nav.nav-tabs .nav-link:hover { color: #2563eb !important; }
        body .main-content .nav.nav-tabs .nav-link.active, body .main-content .nav.nav-tabs .show > .nav-link { background: transparent !important; color: #2563eb !important; border-bottom-color: #2563eb !important; box-shadow: none !important; }
        [data-theme="dark"] body .main-content .nav.nav-tabs { border-bottom-color: rgba(71,85,105,.8) !important; }
        [data-theme="dark"] body .main-content .nav.nav-tabs .nav-link { color: #cbd5e1 !important; }
        [data-theme="dark"] body .main-content .nav.nav-tabs .nav-link.active, [data-theme="dark"] body .main-content .nav.nav-tabs .show > .nav-link { color: #60a5fa !important; border-bottom-color: #60a5fa !important; }
        /* Layout Adjustments */
        .main-content {
            transition: margin-left 0.3s ease;
            padding-top: 20px !important;
        }
        
        @media (min-width: 992px) {
            .sidebar.collapsed + .main-content {
                margin-left: 80px;
                width: calc(100% - 80px);
            }
        }

        .card {
            border: none;
            border-radius: 24px;
            box-shadow: var(--card-shadow);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .card:hover {
            transform: translateY(-5px);
            box-shadow: var(--card-hover-shadow);
        }

        /* Modern Gradient Cards & Headers */
        .card.bg-primary, .card-header.bg-primary {
            background: var(--primary-gradient) !important;
            border: none;
            box-shadow: var(--card-shadow);
        }
        .card.bg-success, .card-header.bg-success {
            background: var(--success-gradient) !important;
            border: none;
            box-shadow: var(--card-shadow);
        }
        .card.bg-info, .card-header.bg-info {
            background: var(--info-gradient) !important;
            border: none;
            color: #fff !important;
            box-shadow: var(--card-shadow);
        }
        .card.bg-warning, .card-header.bg-warning {
            background: var(--warning-gradient) !important;
            border: none;
            color: #fff !important;
            box-shadow: var(--card-shadow);
        }
        .card.bg-danger, .card-header.bg-danger {
            background: var(--danger-gradient) !important;
            border: none;
            box-shadow: var(--card-shadow);
        }
        .card.bg-secondary, .card-header.bg-secondary {
             background: var(--secondary-gradient) !important;
             border: none;
             box-shadow: var(--card-shadow);
        }

        .card-header {
            border-top-left-radius: 15px !important;
            border-top-right-radius: 15px !important;
            border-bottom: 0;
            padding-top: 15px;
            padding-bottom: 15px;
        }

        .stats-card {
            position: relative;
            overflow: hidden;
            isolation: isolate;
            border: 1px solid rgba(255,255,255,0.28) !important;
            border-radius: 22px;
            box-shadow: 0 22px 42px rgba(15, 23, 42, 0.12) !important;
        }
        .stats-card::before {
            content: "";
            position: absolute;
            inset: 0;
            background:
                radial-gradient(circle at top right, rgba(255,255,255,0.24), transparent 42%),
                linear-gradient(180deg, rgba(255,255,255,0.08), transparent 55%);
            pointer-events: none;
        }
        .stats-card::after {
            content: "";
            position: absolute;
            inset: auto -52px -52px auto;
            width: 170px;
            height: 170px;
            border-radius: 999px;
            background: rgba(255,255,255,0.09);
            pointer-events: none;
        }
        .stats-card .card-body {
            position: relative;
            z-index: 1;
            min-height: 110px;
            padding: 1.05rem 1.2rem !important;
            display: flex;
            align-items: center;
            justify-content: flex-start;
            gap: 1rem;
        }
        .stats-card-label {
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.96);
            margin-bottom: 0.25rem;
            line-height: 1.2;
        }
        .stats-card-value {
            font-size: 1.95rem;
            font-weight: 800;
            color: #fff;
            line-height: 1.08;
            letter-spacing: -0.03em;
            text-shadow: 0 10px 24px rgba(0,0,0,0.18);
            margin: 0;
        }
        .stats-card-icon {
            width: 54px;
            height: 54px;
            border-radius: 999px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            background: rgba(255,255,255,0.16) !important;
            color: #fff !important;
            border: 1px solid rgba(255,255,255,0.28);
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.22);
            backdrop-filter: blur(6px);
        }
        .stats-card-icon i {
            font-size: 1.35rem;
            color: #fff !important;
        }
        .card.bg-primary {
            background: linear-gradient(135deg, #1f6feb 0%, #1d4ed8 100%) !important;
        }
        .card.bg-success {
            background: linear-gradient(135deg, #1fbf8f 0%, #0f9f8a 100%) !important;
        }
        .card.bg-danger {
            background: linear-gradient(135deg, #ef476f 0%, #c1121f 100%) !important;
        }
        .card.bg-info {
            background: linear-gradient(135deg, #20b7f5 0%, #0b84d8 100%) !important;
        }
        .card.bg-warning {
            background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%) !important;
        }
        .bg-light-primary,
        .bg-light-success,
        .bg-light-danger,
        .bg-light-info,
        .bg-light-warning {
            background: rgba(255,255,255,0.16) !important;
            border: 1px solid rgba(255,255,255,0.28);
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.22);
        }
        .spin {
            animation: spin 1s linear infinite;
        }
        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
    </style>
</head>
<body data-company-header="<%= company_header || 'Nama Hotspot' %>" data-admin-kontak="<%= adminKontak || 'Kontak Admin' %>">
    <%
        const generationSettings = (typeof voucherGenerationSettings !== 'undefined' && voucherGenerationSettings)
            ? voucherGenerationSettings
            : {
                username_length: '4',
                password_length: '6',
                char_type: 'alphanumeric',
                username_format: 'V{timestamp}',
                account_type: 'voucher',
                password_length_separate: '6'
            };
    %>
    
        <!-- Include Responsive Admin Sidebar -->
        <%- include('partials/admin-responsive-sidebar', { page: 'hotspot', settings: settings }) %>
        
        <main class="main-content">
            <div class="container-fluid">
                <div class="dashboard-hero d-flex justify-content-between align-items-start gap-3">
                    <div>
                        <h4 class="mb-2">User Hotspot</h4>
                        <p>Kelola dan pantau user Hotspot Mikrotik.</p>
                    </div>
                    <button class="theme-toggle-btn" id="themeToggle" type="button" title="Ganti tema"><i class="bi bi-sun-fill text-warning" id="themeIcon"></i></button>
                </div>

                <!-- Tab Navigation -->
                <ul class="nav nav-tabs mb-4">
                    <li class="nav-item">
                        <a class="nav-link <%= page === 'mikrotik' ? 'active' : '' %>" href="/admin/mikrotik">
                            <i class="bi bi-person"></i> User PPPoE
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= page === 'mikrotik-profiles' ? 'active' : '' %>" href="/admin/mikrotik/profiles">
                            <i class="bi bi-person-vcard"></i> Profile PPPoE
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= page === 'hotspot-profiles' ? 'active' : '' %>" href="/admin/mikrotik/hotspot-profiles">
                            <i class="bi bi-broadcast-pin"></i> Profile Hotspot
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= page === 'hotspot' ? 'active' : '' %>" href="/admin/hotspot">
                            <i class="bi bi-person-bounding-box"></i> User Hotspot
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= page === 'voucher' ? 'active' : '' %>" href="/admin/hotspot/voucher">
                            <i class="bi bi-ticket-detailed"></i> Voucher Hotspot
                        </a>
                    </li>
                </ul>

                <h4 class="mb-3">Manajemen User Hotspot</h4>

            <!-- Notifikasi -->
            <% if (success) { %>
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-2"></i> <%= success %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            <% } %>
            
            <% if (error) { %>
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i> <%= error %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            <% } %>

            <div class="row mb-4">
                <div class="col-md-3 mb-3">
                    <div class="card bg-primary text-white stats-card stat-card-modern">
                        <div class="card-body">
                            <div class="stats-card-icon bg-light-primary">
                                <i class="bi bi-person-badge-fill"></i>
                            </div>
                            <div>
                                <div class="stats-card-label">Total User Hotspot</div>
                                <div class="stats-card-value" id="totalUsers"><%= allUsers ? allUsers.length : 0 %></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 mb-3">
                    <div class="card bg-success text-white stats-card stat-card-modern">
                        <div class="card-body">
                            <div class="stats-card-icon bg-light-success">
                                <i class="bi bi-check-circle-fill"></i>
                            </div>
                            <div>
                                <div class="stats-card-label">User Aktif</div>
                                <div class="stats-card-value" id="activeUsers"><%= users ? users.length : 0 %></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 mb-3">
                    <div class="card bg-danger text-white stats-card stat-card-modern">
                        <div class="card-body">
                            <div class="stats-card-icon bg-light-danger">
                                <i class="bi bi-wifi-off"></i>
                            </div>
                            <div>
                                <div class="stats-card-label">User Offline</div>
                                <div class="stats-card-value" id="offlineUsers"><%= allUsers && users ? (allUsers.length - users.length) : 0 %></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 mb-3">
                    <div class="card bg-info text-white stats-card stat-card-modern">
                        <div class="card-body">
                            <div class="stats-card-icon bg-light-info">
                                <i class="bi bi-person-badge-fill"></i>
                            </div>
                            <div>
                                <div class="stats-card-label">Total Profile</div>
                                <div class="stats-card-value" id="profileCount"><%= profiles ? profiles.length : 0 %></div>
                            </div>
                        </div>
                    </div>
                                        <div class="mt-3">
                            <button type="button" class="btn btn-success me-2" onclick="saveVoucherOnlineSettings()">
                                <i class="bi bi-save me-2"></i>Simpan Setting Voucher Online
                            </button>
                            <button type="button" class="btn btn-warning" onclick="resetVoucherOnlineSettings()">
                                <i class="bi bi-arrow-clockwise me-2"></i>Reset ke Profile Pertama
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Voucher Online Settings -->
            <div class="card mb-4">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-globe me-2"></i>Setting Voucher Online</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-3">Konfigurasi paket voucher yang akan ditampilkan di halaman publik (/voucher)</p>

                    <!-- Voucher Generation Settings -->
                    <div class="row mb-4">
                        <div class="col-md-12">
                            <div class="card border-info">
                                <div class="card-header bg-info text-white">
                                    <h6 class="mb-0"><i class="bi bi-gear me-2"></i>Pengaturan Generate Voucher</h6>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-3">
                                            <label class="form-label">Panjang Username:</label>
                                            <select class="form-select" id="voucher_username_length">
                                                <option value="4" <%= (generationSettings.username_length || '4') === '4' ? 'selected' : '' %>>4 karakter</option>
                                                <option value="5" <%= (generationSettings.username_length || '4') === '5' ? 'selected' : '' %>>5 karakter</option>
                                                <option value="6" <%= (generationSettings.username_length || '4') === '6' ? 'selected' : '' %>>6 karakter</option>
                                                <option value="8" <%= (generationSettings.username_length || '4') === '8' ? 'selected' : '' %>>8 karakter</option>
                                            </select>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label">Panjang Password:</label>
                                            <select class="form-select" id="voucher_password_length">
                                                <option value="4" <%= (generationSettings.password_length || '6') === '4' ? 'selected' : '' %>>4 karakter</option>
                                                <option value="5" <%= (generationSettings.password_length || '6') === '5' ? 'selected' : '' %>>5 karakter</option>
                                                <option value="6" <%= (generationSettings.password_length || '6') === '6' ? 'selected' : '' %>>6 karakter</option>
                                                <option value="8" <%= (generationSettings.password_length || '6') === '8' ? 'selected' : '' %>>8 karakter</option>
                                            </select>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label">Tipe Karakter:</label>
                                            <select class="form-select" id="voucher_char_type">
                                                <option value="alphanumeric" <%= (generationSettings.char_type || 'alphanumeric') === 'alphanumeric' ? 'selected' : '' %>>Huruf + Angka</option>
                                                <option value="numeric" <%= (generationSettings.char_type || 'alphanumeric') === 'numeric' ? 'selected' : '' %>>Angka Saja</option>
                                                <option value="alphabetic" <%= (generationSettings.char_type || 'alphanumeric') === 'alphabetic' ? 'selected' : '' %>>Huruf Saja</option>
                                            </select>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label">Format Username:</label>
                                            <select class="form-select" id="voucher_username_format">
                                                <option value="V{timestamp}" <%= (generationSettings.username_format || 'V{timestamp}') === 'V{timestamp}' ? 'selected' : '' %>>V + Timestamp (V123456)</option>
                                                <option value="V{random}" <%= (generationSettings.username_format || 'V{timestamp}') === 'V{random}' ? 'selected' : '' %>>V + Random (VABCD)</option>
                                                <option value="{random}" <%= (generationSettings.username_format || 'V{timestamp}') === '{random}' ? 'selected' : '' %>>Random Saja (ABCD)</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="row mt-3">
                                        <div class="col-md-6">
                                            <label class="form-label">Tipe Akun:</label>
                                            <select class="form-select" id="voucher_account_type" onchange="togglePasswordLengthField()">
                                                <option value="voucher" <%= (generationSettings.account_type || 'voucher') === 'voucher' ? 'selected' : '' %>>Voucher (Username = Password)</option>
                                                <option value="member" <%= (generationSettings.account_type || 'voucher') === 'member' ? 'selected' : '' %>>Member (Username != Password)</option>
                                            </select>
                                            <div class="form-text">
                                                <strong>Voucher:</strong> Username dan password sama (untuk voucher sementara)<br>
                                                <strong>Member:</strong> Username dan password berbeda (untuk member tetap)
                                            </div>
                                        </div>
                                        <div class="col-md-6" id="password_length_separate_field">
                                            <label class="form-label">Panjang Password (jika berbeda):</label>
                                            <select class="form-select" id="voucher_password_length_separate">
                                                <option value="4" <%= (generationSettings.password_length_separate || '6') === '4' ? 'selected' : '' %>>4 karakter</option>
                                                <option value="5" <%= (generationSettings.password_length_separate || '6') === '5' ? 'selected' : '' %>>5 karakter</option>
                                                <option value="6" <%= (generationSettings.password_length_separate || '6') === '6' ? 'selected' : '' %>>6 karakter</option>
                                                <option value="8" <%= (generationSettings.password_length_separate || '6') === '8' ? 'selected' : '' %>>8 karakter</option>
                                            </select>
                                            <div class="form-text">Hanya berlaku jika tipe akun = Member</div>
                                        </div>
                                    </div>
                                    <div class="mt-3">
                                        <button type="button" class="btn btn-info btn-sm" onclick="saveVoucherGenerationSettings()">
                                            <i class="bi bi-save me-1"></i>Simpan Pengaturan Generate
                                        </button>
                                        <button type="button" class="btn btn-warning btn-sm" onclick="testVoucherGeneration()">
                                            <i class="bi bi-play me-1"></i>Test Generate
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <!-- Paket 3k -->
                        <div class="col-md-6 col-lg-4 mb-3">
                            <div class="card border-primary">
                                <div class="card-header bg-primary text-white">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <h6 class="mb-0"><%= voucherOnlineSettings['3k']?.name || '3rb - 1 Hari' %></h6>
                                        <button type="button" class="btn btn-sm btn-outline-light" onclick="editPackageName('3k')">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <div class="mb-2">
                                        <small class="text-muted">Nama Paket:</small>
                                        <input type="text" class="form-control form-control-sm" id="name_3k" value="<%= voucherOnlineSettings['3k']?.name || '3rb - 1 Hari' %>" placeholder="Nama paket">
                                    </div>
                                    <div class="mb-2">
                                        <small class="text-muted">Profile Mikrotik:</small>
                                        <select class="form-select form-select-sm" id="profile_3k">
                                            <% profiles.forEach(function(profile) { %>
                                                <option value="<%= profile.name %>" <%= (voucherOnlineSettings['3k'] && voucherOnlineSettings['3k'].profile === profile.name) ? 'selected' : '' %>><%= profile.name %></option>
                                            <% }); %>
                                        </select>
                                    </div>
                                    <div class="mb-2">
                                        <small class="text-muted">Harga:</small>
                                        <input type="number" class="form-control form-control-sm" id="price_3k" value="<%= voucherOnlineSettings['3k']?.price || 3000 %>">
                                    </div>
                                    <div class="mb-2">
                                        <small class="text-muted">Tipe Durasi:</small>
                                        <select class="form-select form-select-sm" id="duration_type_3k">
                                            <option value="hours" <%= (voucherOnlineSettings['3k']?.duration_type || 'hours') === 'hours' ? 'selected' : '' %>>Jam</option>
                                            <option value="days" <%= (voucherOnlineSettings['3k']?.duration_type || 'hours') === 'days' ? 'selected' : '' %>>Hari</option>
                                        </select>
                                    </div>
                                    <div class="mb-2">
                                        <small class="text-muted">Durasi:</small>
                                        <input type="number" class="form-control form-control-sm" id="duration_3k" value="<%= voucherOnlineSettings['3k']?.duration || 24 %>">
                                    </div>
                                    <div class="mb-2">
                                        <small class="text-muted">Digit Voucher:</small>
                                        <select class="form-select form-select-sm" id="digits_3k">
                                            <option value="4" <%= (voucherOnlineSettings['3k']?.digits || 5) === 4 ? 'selected' : '' %>>4 digit</option>
                                            <option value="5" <%= (voucherOnlineSettings['3k']?.digits || 5) === 5 ? 'selected' : '' %>>5 digit</option>
                                            <option value="6" <%= (voucherOnlineSettings['3k']?.digits || 5) === 6 ? 'selected' : '' %>>6 digit</option>
