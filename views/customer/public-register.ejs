<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Pendaftaran Pelanggan Baru' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #0b1736 0%, #10264f 100%);
            min-height: 100vh;
            color: #fff;
        }
        .card-form {
            background: #ffffff;
            color: #1f2937;
            border: none;
            border-radius: 16px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.2);
        }
        .header-title {
            font-weight: 800;
            letter-spacing: 0.2px;
        }
        .gps-info {
            font-size: 0.85rem;
        }
        .photo-box {
            border: 1px dashed #cbd5e1;
            border-radius: 14px;
            padding: 1rem;
            background: #f8fafc;
        }
        .photo-preview {
            width: 100%;
            max-height: 220px;
            object-fit: cover;
            border-radius: 12px;
            border: 1px solid rgba(15, 23, 42, 0.08);
        }
    </style>
</head>
<body>
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-7 col-xl-6">
                <div class="text-center mb-4">
                    <h1 class="header-title h3 mb-2">Pendaftaran Pelanggan Baru</h1>
                    <p class="text-light mb-0">Isi form berikut, data akan langsung masuk ke admin dan jadwal instalasi.</p>
                </div>

                <div class="card card-form">
                    <div class="card-body p-4 p-md-5">
                        <div id="alertBox" class="alert d-none" role="alert"></div>

                        <form id="registrationForm">
                            <div class="mb-3">
                                <label for="name" class="form-label fw-semibold">Nama Lengkap</label>
                                <input type="text" class="form-control" id="name" name="name" required>
                            </div>

                            <div class="mb-3">
                                <label for="phone" class="form-label fw-semibold">No HP / WhatsApp</label>
                                <input type="text" class="form-control" id="phone" name="phone" placeholder="08xxxxxxxxxx" required>
                            </div>

                            <div class="mb-3">
                                <label for="email" class="form-label fw-semibold">Email</label>
                                <input type="email" class="form-control" id="email" name="email" placeholder="nama@gmail.com">
                            </div>

                            <div class="mb-3">
                                <label for="address" class="form-label fw-semibold">Alamat</label>
                                <textarea class="form-control" id="address" name="address" rows="2" placeholder="Alamat pemasangan"></textarea>
                            </div>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label for="requested_ssid" class="form-label fw-semibold">Nama Wi-Fi yang Diinginkan</label>
                                    <input type="text" class="form-control" id="requested_ssid" name="requested_ssid" placeholder="Contoh: IKDMP-Rakha Putra Andrian">
                                    <div class="form-text">Opsional. Isi jika pelanggan sudah punya nama WiFi yang diinginkan.</div>
                                </div>
                                <div class="col-md-6">
                                    <label for="requested_wifi_password" class="form-label fw-semibold">Password Wi-Fi yang Diinginkan</label>
                                    <input type="text" class="form-control" id="requested_wifi_password" name="requested_wifi_password" placeholder="Contoh: rakha210924">
                                    <div class="form-text">Opsional. Akan diteruskan ke admin dan teknisi untuk persiapan instalasi.</div>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-semibold">Foto Rumah</label>
                                <div class="photo-box">
                                    <div class="d-grid gap-2 d-md-flex">
                                        <button type="button" class="btn btn-outline-primary" id="cameraBtn">Ambil dari Kamera</button>
                                        <button type="button" class="btn btn-outline-secondary" id="galleryBtn">Upload dari Galeri</button>
                                    </div>
                                    <input type="file" id="housePhotoCamera" accept="image/png,image/jpeg,image/jpg,image/*" capture="environment" class="d-none">
                                    <input type="file" id="housePhotoGallery" accept="image/png,image/jpeg,image/jpg,image/*" class="d-none">
                                    <div class="form-text mt-2">Opsional. Foto rumah akan membantu teknisi mengenali lokasi pemasangan dan penanganan gangguan.</div>
                                    <div id="photoPreviewWrap" class="mt-3 d-none">
                                        <img id="photoPreview" class="photo-preview" alt="Preview Foto Rumah">
                                        <div class="small text-muted mt-2" id="photoName"></div>
                                    </div>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="package_id" class="form-label fw-semibold">Pilih Paket</label>
                                <select class="form-select" id="package_id" name="package_id" required>
                                    <option value="">Pilih Paket</option>
                                    <% packages.forEach(function(pkg) { %>
                                        <option value="<%= pkg.id %>" <%= String(selectedPackageId || '') === String(pkg.id) ? 'selected' : '' %>>
                                            <%= pkg.name %> (<%= pkg.speed %>) - Rp <%= Number(pkg.price || 0).toLocaleString('id-ID') %>
                                        </option>
                                    <% }) %>
                                </select>
                                <div class="form-text">Paket yang tersedia: IKDMP 10 Mbps, IKDMP 15 Mbps, IKDMP 20 Mbps.</div>
                            </div>

                            <div class="row g-2">
                                <div class="col-md-6">
                                    <label for="latitude" class="form-label fw-semibold">Latitude</label>
                                    <input type="text" class="form-control" id="latitude" name="latitude" readonly required>
                                </div>
                                <div class="col-md-6">
                                    <label for="longitude" class="form-label fw-semibold">Longitude</label>
                                    <input type="text" class="form-control" id="longitude" name="longitude" readonly required>
                                </div>
                            </div>

                            <div class="mt-3 d-grid gap-2">
                                <button type="button" class="btn btn-outline-primary" id="gpsBtn">
                                    Ambil Lokasi GPS
                                </button>
                                <small class="gps-info text-muted" id="gpsStatus">Belum mengambil lokasi.</small>
                            </div>

                            <div class="d-grid mt-4">
                                <button type="submit" class="btn btn-primary btn-lg" id="submitBtn">Daftar Sekarang</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const gpsBtn = document.getElementById('gpsBtn');
        const gpsStatus = document.getElementById('gpsStatus');
        const latInput = document.getElementById('latitude');
        const lngInput = document.getElementById('longitude');
        const form = document.getElementById('registrationForm');
        const submitBtn = document.getElementById('submitBtn');
        const alertBox = document.getElementById('alertBox');
        const cameraBtn = document.getElementById('cameraBtn');
        const galleryBtn = document.getElementById('galleryBtn');
        const housePhotoCamera = document.getElementById('housePhotoCamera');
        const housePhotoGallery = document.getElementById('housePhotoGallery');
        const photoPreviewWrap = document.getElementById('photoPreviewWrap');
        const photoPreview = document.getElementById('photoPreview');
        const photoName = document.getElementById('photoName');
        let selectedHousePhoto = null;

        function showAlert(type, message) {
            alertBox.className = `alert alert-${type}`;
            alertBox.textContent = message;
            alertBox.classList.remove('d-none');
        }

        function handleSelectedPhoto(file) {
            if (!file) return;

            selectedHousePhoto = file;
            photoName.textContent = `${file.name} - ${(file.size / 1024 / 1024).toFixed(2)} MB`;

            const reader = new FileReader();
            reader.onload = (event) => {
                photoPreview.src = event.target.result;
                photoPreviewWrap.classList.remove('d-none');
            };
            reader.readAsDataURL(file);
        }

        cameraBtn.addEventListener('click', () => housePhotoCamera.click());
        galleryBtn.addEventListener('click', () => housePhotoGallery.click());
        housePhotoCamera.addEventListener('change', (e) => handleSelectedPhoto(e.target.files[0]));
        housePhotoGallery.addEventListener('change', (e) => handleSelectedPhoto(e.target.files[0]));

        gpsBtn.addEventListener('click', () => {
            if (!navigator.geolocation) {
                showAlert('danger', 'Browser tidak mendukung GPS.');
                return;
            }

            gpsBtn.disabled = true;
            gpsBtn.textContent = 'Mengambil Lokasi...';
            gpsStatus.textContent = 'Sedang mengambil lokasi GPS...';

            navigator.geolocation.getCurrentPosition(
                (position) => {
                    const lat = position.coords.latitude;
                    const lng = position.coords.longitude;
                    latInput.value = lat.toFixed(8);
                    lngInput.value = lng.toFixed(8);
                    gpsStatus.textContent = `Lokasi berhasil diambil (akurasi ±${Math.round(position.coords.accuracy)} meter)`;
                    gpsBtn.disabled = false;
                    gpsBtn.textContent = 'Ambil Lokasi GPS';
                },
                () => {
                    gpsStatus.textContent = 'Gagal mengambil lokasi. Pastikan izin lokasi diaktifkan.';
                    gpsBtn.disabled = false;
                    gpsBtn.textContent = 'Ambil Lokasi GPS';
                    showAlert('warning', 'Gagal mengambil lokasi GPS. Coba lagi.');
                },
                {
                    enableHighAccuracy: true,
                    timeout: 15000,
                    maximumAge: 0
                }
            );
        });

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            alertBox.classList.add('d-none');

            if (!latInput.value || !lngInput.value) {
                showAlert('warning', 'Silakan ambil lokasi GPS terlebih dahulu.');
                return;
            }

            submitBtn.disabled = true;
            submitBtn.textContent = 'Memproses...';

            const payload = new FormData();
            payload.append('name', document.getElementById('name').value.trim());
            payload.append('phone', document.getElementById('phone').value.trim());
            payload.append('email', document.getElementById('email').value.trim());
            payload.append('address', document.getElementById('address').value.trim());
            payload.append('requested_ssid', document.getElementById('requested_ssid').value.trim());
            payload.append('requested_wifi_password', document.getElementById('requested_wifi_password').value.trim());
            payload.append('package_id', document.getElementById('package_id').value);
            payload.append('latitude', latInput.value);
            payload.append('longitude', lngInput.value);
            if (selectedHousePhoto) {
                payload.append('house_photo', selectedHousePhoto);
            }

            try {
                const resp = await fetch('/customer/register', {
                    method: 'POST',
                    body: payload
                });
                const data = await resp.json();

                if (data.success) {
                    showAlert('success', `Pendaftaran berhasil. No Job Instalasi: ${data.jobNumber}. Teknisi: ${data.assignedTechnician || 'Belum ditentukan'}`);
                    form.reset();
                    latInput.value = '';
                    lngInput.value = '';
                    gpsStatus.textContent = 'Belum mengambil lokasi.';
                    selectedHousePhoto = null;
                    photoPreviewWrap.classList.add('d-none');
                    photoPreview.src = '';
                    photoName.textContent = '';
                } else {
                    showAlert('danger', data.message || 'Gagal mendaftar.');
                }
            } catch (error) {
                showAlert('danger', 'Terjadi kesalahan jaringan.');
            } finally {
                submitBtn.disabled = false;
                submitBtn.textContent = 'Daftar Sekarang';
            }
        });
    </script>
</body>
</html>

