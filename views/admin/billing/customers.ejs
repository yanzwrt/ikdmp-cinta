                                        </div>

                                        <div class="col-xl-2 col-md-6">
                                            <div class="card summary-card summary-card-3" style="background: linear-gradient(135deg, #ef4444, #dc2626) !important;">
                                                <div class="card-body">
                                                    <div class="summary-body">
                                                        <div class="avatar-sm">
                                                            <span class="avatar-title bg-soft-warning rounded">
                                                                <i class="bi bi-cash-coin"></i>
                                                            </span>
                                                        </div>
                                                        <div class="summary-content">
                                                            <div class="summary-label"
                                                                title="Unpaid Customers">Belum Bayar</div>
                                                            <div class="summary-value">
                                                                <%= customers ? customers.filter(c=> c.payment_status
                                                                    === 'unpaid').length : 0 %>
                                                            </div>
                                                            <div class="summary-note"><i class="bx bx-error-circle"></i> Butuh Tindak Lanjut</div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-xl-2 col-md-6">
                                            <div class="card summary-card summary-card-4" style="background: linear-gradient(135deg, #f59e0b, #d97706) !important;">
                                                <div class="card-body">
                                                    <div class="summary-body">
                                                        <div class="avatar-sm">
                                                            <span class="avatar-title bg-soft-danger rounded">
                                                                <i class="bi bi-exclamation-triangle-fill"></i>
                                                            </span>
                                                        </div>
                                                        <div class="summary-content">
                                                            <div class="summary-label"
                                                                title="Overdue Customers">Isolir</div>
