                                                            </div>
                                                            <div class="summary-note"><i class="bx bx-check-circle"></i> <%= customers ? customers.filter(c=> c.status === 'active').length : 0 %> Aktif</div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-xl-2 col-md-6">
                                            <div class="card summary-card summary-card-2" style="background: linear-gradient(135deg, #10b981, #059669) !important;">
                                                <div class="card-body">
                                                    <div class="summary-body">
                                                        <div class="avatar-sm">
                                                            <span class="avatar-title bg-soft-success rounded">
                                                                <i class="bi bi-cash-stack"></i>
                                                            </span>
                                                        </div>
                                                        <div class="summary-content">
                                                            <div class="summary-label"
                                                                title="Paid Customers">Sudah Bayar</div>
