                                        <div class="col-xl-2 col-md-6">
                                            <div class="card summary-card summary-card-5" style="background: linear-gradient(135deg, #06b6d4, #0284c7) !important;">
                                                <div class="card-body">
                                                    <div class="summary-body">
                                                        <div class="avatar-sm">
                                                            <span class="avatar-title bg-soft-info rounded">
                                                                <i class="bi bi-receipt-cutoff"></i>
                                                            </span>
                                                        </div>
                                                        <div class="summary-content">
                                                            <div class="summary-label"
                                                                title="No Invoice Customers">Non Tagihan</div>
                                                            <div class="summary-value">
                                                                <%= customers ? customers.filter(c=> c.payment_status
                                                                    === 'no_invoice').length : 0 %>
                                                            </div>
                                                            <div class="summary-note"><i class="bx bx-receipt"></i> Belum Ada Invoice</div>
