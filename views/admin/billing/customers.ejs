<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title || 'Kelola Pelanggan' %> - <%= typeof isTechnicianView !=='undefined' && isTechnicianView
                ? 'Portal Teknisi' : 'Admin Portal' %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/boxicons@2.0.7/css/boxicons.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Admin Mobile Optimizations -->
    <link href="/css/admin-mobile.css" rel="stylesheet">
    <link href="/css/responsive-admin.css" rel="stylesheet">
    <link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        :root {
            --bg-body: #f5f7fb;
            --bg-card: #ffffff;
            --text-color: #212529;
            --text-muted: #6c757d;
            --border-color: #eef2f6;
            --card-shadow: 0 4px 20px rgba(0,0,0,0.02);
        }

        /* Dark Mode Variables */
        [data-theme="dark"] {
            --bg-body: #1a1a1a;
            --bg-card: #2d2d2d;
            --text-color: #e0e0e0;
            --text-muted: #a0a0a0;
            --border-color: #404040;
            --card-shadow: 0 4px 20px rgba(0,0,0,0.2);
        }

        body {
            background:
                radial-gradient(circle at top left, rgba(59, 130, 246, 0.12), transparent 24%),
                radial-gradient(circle at 85% 15%, rgba(45, 212, 191, 0.12), transparent 22%),
                linear-gradient(180deg, #f7faff 0%, #eef4ff 44%, #f8fbff 100%);
            color: var(--text-color);
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        body[data-theme="dark"] {
            background:
                radial-gradient(circle at top left, rgba(59, 130, 246, 0.12), transparent 24%),
                radial-gradient(circle at 85% 15%, rgba(20, 184, 166, 0.12), transparent 24%),
                linear-gradient(180deg, #081120 0%, #0b1324 44%, #0a1428 100%);
        }

        .card, .modal-content {
            background-color: var(--bg-card) !important;
            color: var(--text-color);
            border-color: var(--border-color) !important;
        }

        .main-content {
            position: relative;
            z-index: 1;
        }

        .billing-toolbar,
        .billing-tabs-wrap,
        .billing-subhero,
        .billing-section-card {
            position: relative;
            overflow: hidden;
            border: 1px solid rgba(148, 163, 184, 0.18);
            border-radius: 24px;
            background: linear-gradient(145deg, rgba(255,255,255,0.88), rgba(244,247,255,0.82));
            backdrop-filter: blur(16px);
            box-shadow: 0 18px 44px rgba(37, 99, 235, 0.08);
        }

        .billing-toolbar,
        .billing-subhero {
            padding: 16px 20px;
        }

        .billing-tabs-wrap {
            padding: 10px 14px 0;
        }

        .billing-tabs.nav-tabs {
            border-bottom: 0;
            gap: 0.5rem;
            display: flex;
            align-items: stretch;
        }

        .billing-tabs .nav-item {
            flex: 0 0 auto;
            display: block;
        }

        .billing-tabs.nav-tabs .nav-link {
            border: 0 !important;
            border-radius: 999px !important;
            padding: 0.65rem 1rem;
            color: var(--text-muted);
            font-weight: 700;
            width: auto;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.4rem;
            text-align: center;
            background: transparent !important;
            box-shadow: none !important;
            transform: none !important;
        }

        .billing-tabs.nav-tabs .nav-link:hover {
            color: #2563eb;
            background: rgba(37, 99, 235, 0.06) !important;
        }

        .billing-tabs.nav-tabs .nav-link.active,
        .billing-tabs.nav-tabs .show > .nav-link {
            background: linear-gradient(135deg, #2563eb, #4f46e5) !important;
            color: #2563eb !important;
            color: #fff !important;
            box-shadow: 0 10px 24px rgba(37, 99, 235, 0.18) !important;
            transform: none !important;
        }

        .billing-tabs.nav-tabs .nav-link.active::after,
        .billing-tabs.nav-tabs .show > .nav-link::after {
            display: none !important;
        }

        [data-theme="dark"] .billing-tabs.nav-tabs {
            border-bottom-color: rgba(71, 85, 105, 0.8);
        }

        [data-theme="dark"] .billing-tabs.nav-tabs .nav-link {
            color: #cbd5e1 !important;
            background: transparent !important;
        }

        [data-theme="dark"] .billing-tabs.nav-tabs .nav-link.active,
        [data-theme="dark"] .billing-tabs.nav-tabs .show > .nav-link {
            background: linear-gradient(135deg, #2563eb, #4f46e5) !important;
            color: #fff !important;
        }

        [data-theme="dark"] .billing-toolbar,
        [data-theme="dark"] .billing-tabs-wrap,
        [data-theme="dark"] .billing-subhero,
        [data-theme="dark"] .billing-section-card {
            background: linear-gradient(180deg, rgba(30, 41, 59, 0.96), rgba(17, 24, 39, 0.96));
            border-color: rgba(255, 255, 255, 0.08);
            box-shadow: 0 20px 42px rgba(2, 8, 23, 0.36);
        }
        /* Summary cards: samakan proporsi dengan dashboard billing */
        .customer-stats {
            row-gap: 1rem;
        }

        .summary-card {
            position: relative;
            overflow: hidden;
            border: 1px solid rgba(255,255,255,0.28) !important;
            border-radius: 24px !important;
            color: #ffffff !important;
            box-shadow: 0 18px 38px rgba(15, 23, 42, 0.09) !important;
            isolation: isolate;
            transition: transform 0.28s ease, box-shadow 0.28s ease;
            height: 100%;
        }
        .summary-card:hover {
            transform: translateY(-7px);
            box-shadow: 0 28px 52px rgba(15, 23, 42, 0.14) !important;
        }
        .summary-card::before {
            content: "";
            position: absolute;
            inset: 0;
            background:
                radial-gradient(circle at top right, rgba(255,255,255,0.28), transparent 42%),
                linear-gradient(180deg, rgba(255,255,255,0.08), transparent 55%);
            pointer-events: none;
            z-index: 0;
        }
        .summary-card::after {
            content: "";
            position: absolute;
            inset: auto -52px -52px auto;
            width: 170px;
            height: 170px;
            border-radius: 999px;
            background: rgba(255,255,255,0.14);
            pointer-events: none;
            z-index: 0;
        }
        .summary-card .card-body {
            position: relative;
            z-index: 1;
            min-height: 110px;
            padding: 1.05rem 1.2rem !important;
            display: flex;
            align-items: center;
        }
        .summary-card .summary-body {
            display: flex;
            align-items: center;
            gap: 1rem;
            width: 100%;
        }
        .summary-card .summary-content {
            min-width: 0;
            flex: 1 1 auto;
        }
        .summary-card .text-muted,
        .summary-card .summary-label,
        .summary-card .summary-value,
        .summary-card .summary-note,
        .summary-card i,
        .summary-card .fw-bold {
            color: #ffffff !important;
        }
        .summary-card .summary-label {
            font-size: 0.72rem !important;
            letter-spacing: 0.10em !important;
            margin-bottom: 0.2rem !important;
            line-height: 1.2;
            text-transform: uppercase;
            font-weight: 700;
            opacity: 0.95;
        }
        .summary-card .summary-value {
            font-size: 1.95rem !important;
            line-height: 1.15 !important;
            margin-bottom: 0.2rem !important;
            letter-spacing: -0.03em;
            font-weight: 700;
            text-shadow: 0 10px 24px rgba(0,0,0,0.18);
        }
        .summary-card .summary-note {
            font-size: 0.84rem !important;
            line-height: 1.35;
            opacity: 0.96;
        }
        .summary-card-1 { background: linear-gradient(135deg, #4f7cff 0%, #2756d8 100%) !important; }
        .summary-card-2 { background: linear-gradient(135deg, #20c997 0%, #0f9f8a 100%) !important; }
        .summary-card-3 { background: linear-gradient(135deg, #ff5e7b 0%, #d7264c 100%) !important; }
        .summary-card-4 { background: linear-gradient(135deg, #f7b801 0%, #e28a00 100%) !important; }
        .summary-card-5 { background: linear-gradient(135deg, #20b7f5 0%, #0b84d8 100%) !important; }
        .summary-card-6 { background: linear-gradient(135deg, #5f6bff 0%, #3a41d6 100%) !important; }
        .summary-card .avatar-sm {
            position: relative;
            z-index: 1;
            flex: 0 0 auto;
        }

        .billing-subhero {
            border-radius: 24px;
        }

        .billing-subhero h1.h2 {
            margin-bottom: 0;
            color: #1e293b;
            font-weight: 700;
        }

        [data-theme="dark"] .billing-subhero h1.h2 {
            color: #f8fafc;
        }
        .summary-card .avatar-title {
            width: 54px !important;
            height: 54px !important;
            min-width: 54px;
            background: rgba(255,255,255,0.16) !important;
            border: 1px solid rgba(255,255,255,0.28);
            color: #ffffff !important;
            border-radius: 999px !important;
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.22);
            backdrop-filter: blur(6px);
        }
        .summary-card .avatar-title i {
            font-size: 1.45rem !important;
            color: #ffffff !important;
        }
        .summary-card .summary-content > * {
            text-align: left !important;
        }

        .customer-avatar {
            width: 38px;
            height: 38px;
            border-radius: 999px;
            object-fit: cover;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 0.95rem;
            font-weight: 700;
            color: #fff;
            background: linear-gradient(135deg, #2563eb, #4f46e5);
            box-shadow: 0 8px 18px rgba(37, 99, 235, 0.18);
            flex: 0 0 38px;
        }

        .customer-name-cell {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            min-width: 180px;
        }

        .customer-name-meta {
            min-width: 0;
        }
        
        body[data-theme="dark"] .main-content {
            color: #e5edf8;
        }

        body[data-theme="dark"] .summary-card {
            box-shadow: 0 22px 44px rgba(2, 8, 23, 0.42) !important;
        }

        body[data-theme="dark"] .summary-card .avatar-title {
            background: rgba(255,255,255,0.14) !important;
            border-color: rgba(255,255,255,0.24) !important;
        }

        @media (max-width: 768px) {
            .summary-card .card-body {
                min-height: 96px;
                padding: 0.95rem 1rem !important;
            }

            .summary-card .avatar-title {
                width: 44px !important;
                height: 44px !important;
                min-width: 44px;
            }

            .summary-card .avatar-title i {
                font-size: 1.2rem !important;
            }

            .summary-card .summary-label {
                font-size: 0.68rem !important;
            }

            .summary-card .summary-value {
                font-size: 1.35rem !important;
            }

            .summary-card .summary-note {
                font-size: 0.76rem !important;
            }
        }

        [data-theme="dark"] .table {
            color: var(--text-color);
            border-color: var(--border-color);
        }
        
        [data-theme="dark"] .table-hover tbody tr:hover {
            color: var(--text-color);
            background-color: rgba(255,255,255,0.05);
        }

        [data-theme="dark"] .form-control, 
        [data-theme="dark"] .form-select {
            background-color: #2d2d2d;
            border-color: #404040;
            color: #e0e0e0;
        }
        
        [data-theme="dark"] .text-muted {
            color: #a0a0a0 !important;
        }
        [data-theme="dark"] .summary-card .text-muted,
        [data-theme="dark"] .summary-card h3,
        [data-theme="dark"] .summary-card h5,
        [data-theme="dark"] .summary-card i,
        [data-theme="dark"] .summary-card .small,
        [data-theme="dark"] .summary-card .fw-bold {
            color: #ffffff !important;
        }
        
        [data-theme="dark"] .pppoe-dropdown {
            background: #2d2d2d !important;
            border-color: #404040 !important;
        }
        
        [data-theme="dark"] .pppoe-dropdown-item {
            border-bottom-color: #404040;
            color: #e0e0e0;
        }
        
        [data-theme="dark"] .pppoe-dropdown-item:hover {
            background-color: #404040;
        }
        
        [data-theme="dark"] .pppoe-dropdown-item .username {
            color: #e0e0e0;
        }

        [data-theme="dark"] .card-header,
        [data-theme="dark"] .card-footer,
        [data-theme="dark"] .dataTables_wrapper,
        [data-theme="dark"] .dataTables_wrapper .dataTables_length,
        [data-theme="dark"] .dataTables_wrapper .dataTables_filter,
        [data-theme="dark"] .dataTables_wrapper .dataTables_info,
        [data-theme="dark"] .dataTables_wrapper .dataTables_paginate,
        [data-theme="dark"] .dataTables_wrapper label,
        [data-theme="dark"] .dataTables_wrapper .form-label,
        [data-theme="dark"] .dataTables_wrapper .form-text,
        [data-theme="dark"] .table,
        [data-theme="dark"] .table thead th,
        [data-theme="dark"] .table tbody td,
        [data-theme="dark"] .table tbody td a,
        [data-theme="dark"] .table tbody td small,
        [data-theme="dark"] .table tbody td span,
        [data-theme="dark"] .billing-section-card,
        [data-theme="dark"] .billing-section-card .card-title,
        [data-theme="dark"] .billing-section-card .card-header,
        [data-theme="dark"] .billing-section-card .card-body {
            color: #e5edf8 !important;
        }

        [data-theme="dark"] .billing-section-card .card-header {
            background: rgba(17, 24, 39, 0.94) !important;
            border-bottom-color: rgba(148, 163, 184, 0.14) !important;
        }

        [data-theme="dark"] .table {
            --bs-table-bg: transparent;
            --bs-table-color: #e5edf8;
            --bs-table-border-color: rgba(148, 163, 184, 0.16);
            --bs-table-striped-bg: rgba(15, 23, 42, 0.42);
            --bs-table-striped-color: #e5edf8;
            --bs-table-hover-bg: rgba(59, 130, 246, 0.08);
            --bs-table-hover-color: #f8fbff;
        }

        [data-theme="dark"] .table thead th {
            background: rgba(17, 24, 39, 0.96) !important;
            color: #f8fbff !important;
            border-bottom-color: rgba(148, 163, 184, 0.18) !important;
        }

        [data-theme="dark"] .table tbody tr {
            background: rgba(17, 24, 39, 0.74) !important;
        }

        [data-theme="dark"] .table-striped > tbody > tr:nth-of-type(odd) > * {
            color: #e5edf8 !important;
            background-color: rgba(30, 41, 59, 0.82) !important;
        }

        [data-theme="dark"] .table-striped > tbody > tr:nth-of-type(even) > * {
            color: #e5edf8 !important;
            background-color: rgba(17, 24, 39, 0.72) !important;
        }

        [data-theme="dark"] .table-hover > tbody > tr:hover > * {
            color: #f8fbff !important;
            background-color: rgba(59, 130, 246, 0.10) !important;
        }

        [data-theme="dark"] .table-responsive {
            background: rgba(17, 24, 39, 0.78) !important;
            border-radius: 16px;
        }

        [data-theme="dark"] .form-control,
        [data-theme="dark"] .form-select,
        [data-theme="dark"] .dataTables_wrapper .dataTables_filter input,
        [data-theme="dark"] .dataTables_wrapper .dataTables_length select {
            background-color: rgba(15, 23, 42, 0.88) !important;
            border-color: rgba(148, 163, 184, 0.22) !important;
            color: #f8fbff !important;
        }

        [data-theme="dark"] .form-control::placeholder,
        [data-theme="dark"] .dataTables_wrapper .dataTables_filter input::placeholder {
            color: #94a3b8 !important;
        }

        [data-theme="dark"] .form-control:focus,
        [data-theme="dark"] .form-select:focus,
        [data-theme="dark"] .dataTables_wrapper .dataTables_filter input:focus,
        [data-theme="dark"] .dataTables_wrapper .dataTables_length select:focus {
            border-color: rgba(59, 130, 246, 0.45) !important;
            box-shadow: 0 0 0 0.2rem rgba(37, 99, 235, 0.16) !important;
        }

        [data-theme="dark"] .dataTables_wrapper .paginate_button,
        [data-theme="dark"] .dataTables_wrapper .paginate_button a,
        [data-theme="dark"] .page-link {
            color: #e5edf8 !important;
        }

        [data-theme="dark"] .page-link {
            background-color: rgba(15, 23, 42, 0.88) !important;
            border-color: rgba(148, 163, 184, 0.18) !important;
        }

        [data-theme="dark"] .page-item.active .page-link {
            background: linear-gradient(135deg, #2563eb, #38bdf8) !important;
            border-color: transparent !important;
            color: #ffffff !important;
        }

        [data-theme="dark"] .btn-outline-secondary,
        [data-theme="dark"] .btn-outline-primary,
        [data-theme="dark"] .btn-outline-info,
        [data-theme="dark"] .btn-outline-warning,
        [data-theme="dark"] .btn-outline-success,
        [data-theme="dark"] .btn-outline-danger {
            color: #e5edf8 !important;
            border-color: rgba(148, 163, 184, 0.22) !important;
        }

        [data-theme="dark"] .alert-info {
            background: rgba(14, 165, 233, 0.12) !important;
            color: #dbeafe !important;
            border-color: rgba(14, 165, 233, 0.24) !important;
        }

        [data-theme="dark"] .modal-content,
        [data-theme="dark"] .modal-header,
        [data-theme="dark"] .modal-body,
        [data-theme="dark"] .modal-footer {
            color: #e5edf8 !important;
            background-color: #0f172a !important;
            border-color: rgba(148, 163, 184, 0.16) !important;
        }

        [data-theme="dark"] .modal-header.bg-warning,
        [data-theme="dark"] .modal-header.bg-warning.text-dark {
            background: #f59e0b !important;
            color: #111827 !important;
        }
    </style>
    <script>
        // Theme Toggle Functionality
        function toggleTheme() {
            const body = document.body;
            const currentTheme = body.getAttribute('data-theme');
            const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
            
            body.setAttribute('data-theme', newTheme);
            localStorage.setItem('theme', newTheme);
            
            updateThemeButton(newTheme);
        }

        function updateThemeButton(theme) {
            const icon = document.getElementById('themeIcon');
            const text = document.getElementById('themeText');
            const btn = document.getElementById('themeToggle');
            
            if (!icon || !text || !btn) return;

            if (theme === 'dark') {
                icon.className = 'bi bi-moon-stars-fill text-white me-1';
                text.textContent = 'Dark';
                btn.classList.remove('btn-white');
                btn.classList.add('btn-dark');
                // Apply dark mode styles dynamically
                document.documentElement.style.setProperty('--bg-body', '#1a1a1a');
                document.documentElement.style.setProperty('--bg-card', '#2d2d2d');
                document.documentElement.style.setProperty('--text-color', '#ffffff');
                document.documentElement.style.setProperty('--text-muted', '#a0a0a0');
            } else {
                icon.className = 'bi bi-sun-fill text-warning me-1';
                text.textContent = 'Light';
                btn.classList.remove('btn-dark');
                btn.classList.add('btn-white');
                // Apply light mode styles dynamically
                document.documentElement.style.setProperty('--bg-body', '#f5f7fb');
                document.documentElement.style.setProperty('--bg-card', '#ffffff');
                document.documentElement.style.setProperty('--text-color', '#212529');
                document.documentElement.style.setProperty('--text-muted', '#6c757d');
            }
        }

        // Initialize Theme
        document.addEventListener('DOMContentLoaded', () => {
            const savedTheme = localStorage.getItem('theme') || 'light';
            document.body.setAttribute('data-theme', savedTheme);
            updateThemeButton(savedTheme);
        });
    </script>
    <style>
        .toast-container {
            z-index: 9999;
        }

        /* Summary cards: samakan nuansa gradient dashboard billing */
        .row.mb-4 > .col-xl-2 .card:not(.summary-card) {
            border: none !important;
            border-radius: 14px;
            overflow: hidden;
            box-shadow: 0 10px 24px rgba(15, 23, 42, 0.12);
        }

        .row.mb-4 > .col-xl-2:nth-child(5) .card:not(.summary-card) {
            background: linear-gradient(135deg, #3b82f6, #2563eb) !important;
        }

        .row.mb-4 > .col-xl-2:nth-child(6) .card:not(.summary-card) {
            background: linear-gradient(135deg, #10b981, #059669) !important;
        }

        /* Rapikan jarak antar customer di tabel */
        #customersTable tbody td,
        #customersTable tbody td a {
            font-size: 0.92rem;
        }
        #customersTable tbody td {
            padding-top: 0.5rem;
            padding-bottom: 0.5rem;
            vertical-align: middle;
            line-height: 1.25;
        }

        #customersTable tbody tr {
            height: auto;
        }

        #customersTable .btn-group-vertical .btn {
            margin-bottom: 1px;
            padding-top: 0.25rem;
            padding-bottom: 0.25rem;
        }

        /* PPPoE Username styling */
        .spin {
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            from {
                transform: rotate(0deg);
            }

            to {
                transform: rotate(360deg);
            }
        }

        #pppoe_username.border-success {
            border-color: #198754 !important;
            box-shadow: 0 0 0 0.2rem rgba(25, 135, 84, 0.25);
        }

        #pppoe_username.border-warning {
            border-color: #ffc107 !important;
            box-shadow: 0 0 0 0.2rem rgba(255, 193, 7, 0.25);
        }

        /* Custom PPPoE Dropdown Styles */
        .pppoe-dropdown {
            position: fixed !important;
            background: white !important;
            border: 2px solid #007bff !important;
            border-radius: 0.375rem !important;
            max-height: 200px !important;
            overflow-y: auto !important;
            z-index: 99999 !important;
            box-shadow: 0 8px 16px rgba(0, 0, 0, 0.3) !important;
            display: none !important;
            width: 300px !important;
            min-height: 40px !important;
        }

        .pppoe-dropdown.show {
            display: block !important;
        }

        /* Ensure input group has relative positioning */
        .input-group {
            position: relative !important;
        }

        /* Modal z-index fix */
        .modal {
            z-index: 1050 !important;
        }

        .modal-backdrop {
            z-index: 1040 !important;
        }

        .pppoe-dropdown-item {
            padding: 8px 12px;
            cursor: pointer;
            border-bottom: 1px solid #f8f9fa;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .pppoe-dropdown-item:hover {
            background-color: #f8f9fa;
        }

        .pppoe-dropdown-item.active {
            background-color: #e3f2fd;
        }

        .pppoe-dropdown-item .username {
            font-weight: 500;
            color: #333;
        }

        .pppoe-dropdown-item .profile {
            font-size: 0.875rem;
            color: #6c757d;
            background: #e9ecef;
            padding: 2px 6px;
            border-radius: 3px;
            display: none;
            /* Hidden since profile is not needed */
        }

        .pppoe-dropdown-item .status {
            font-size: 0.75rem;
            padding: 1px 4px;
            border-radius: 2px;
        }

        .pppoe-dropdown-item .status.active {
            background: #d4edda;
            color: #155724;
        }

        .pppoe-dropdown-item .status.inactive {
            background: #f8d7da;
            color: #721c24;
        }

        .pppoe-dropdown-no-results {
            padding: 12px;
            text-align: center;
            color: #6c757d;
            font-style: italic;
        }

        /* Input group relative positioning for dropdown */
        .input-group {
            position: relative;
        }

        /* Mobile Responsive Styles */
        @media (max-width: 768px) {
            .main-content {
                padding: 10px !important;
                margin-left: 0 !important;
            }

            /* Header responsive */
            .d-flex.justify-content-between {
                flex-direction: column;
                gap: 15px;
            }

            .btn-group {
                flex-wrap: wrap;
                gap: 5px;
                width: 100%;
            }

            .btn-group .btn {
                font-size: 12px;
                padding: 8px 12px;
                flex: 1;
                min-width: auto;
            }

            /* Summary cards responsive */
            .row.mb-4 .col-xl-2 {
                margin-bottom: 15px;
            }

            .card-body {
                padding: 1rem 0.75rem;
            }

            .card-body h5 {
                font-size: 0.85rem;
            }

            .card-body h3 {
                font-size: 1.5rem;
            }
            .table th,
            .table td {
                padding: 8px 4px;
                white-space: nowrap;
            }
            #customersTable tbody td {
                padding-top: 0.4rem;
                padding-bottom: 0.4rem;
                line-height: 1.2;
            }

            .btn-sm {
                padding: 4px 8px;
                font-size: 11px;
            }

            /* Modal responsive */
            .modal-dialog {
                margin: 10px;
                max-width: calc(100vw - 20px);
            }

            .modal-body {
                padding: 1rem;
            }

            .form-label {
                font-size: 0.9rem;
                margin-bottom: 4px;
            }

            .form-control,
            .form-select {
                padding: 8px 12px;
                font-size: 0.9rem;
            }

            /* Action buttons in table */
            .btn-group-vertical .btn {
                padding: 6px 10px;
                font-size: 11px;
                margin-bottom: 2px;
            }

            /* Search and filter */
            .dataTables_filter input {
                width: 100% !important;
                margin: 0 !important;
            }

            .dataTables_length select {
                width: auto !important;
            }

            /* Pagination */
            .dataTables_paginate {
                text-align: center !important;
            }

            .dataTables_paginate .paginate_button {
                padding: 6px 10px !important;
                margin: 0 2px !important;
            }

            /* Touch friendly buttons */
            .btn {
                min-height: 42px;
                touch-action: manipulation;
            }

            .btn-sm {
                min-height: 36px;
            }

            /* Map responsive (jika ada) */
            #customerMap {
                height: 300px !important;
            }

            /* Checkbox and form controls */
            .form-check-input {
                width: 1.2em;
                height: 1.2em;
            }

            /* Alert messages */
            .alert {
                font-size: 0.9rem;
                padding: 0.5rem;
            }
        }

        @media (max-width: 576px) {
            .h2 {
                font-size: 1.3rem;
            }

            .card {
                margin-bottom: 1rem;
            }

            .table-responsive {
                font-size: 0.8rem;
            }

            .btn-group .btn {
                font-size: 11px;
                padding: 6px 8px;
            }

            /* Stack summary cards vertically on very small screens */
            .col-xl-2.col-md-6 {
                flex: 0 0 50%;
                max-width: 50%;
            }
        }

        /* GPS Button Enhancements */
        #gpsButton,
        #editGpsButton {
            transition: all 0.3s ease;
            position: relative;
        }

        #gpsButton:hover:not(:disabled),
        #editGpsButton:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(40, 167, 69, 0.3);
        }

        #gpsButton:disabled,
        #editGpsButton:disabled {
            transform: none;
            box-shadow: none;
        }

        .bx-spin {
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            from {
                transform: rotate(0deg);
            }

            to {
                transform: rotate(360deg);
            }
        }

        /* Location help styling */
        .accordion-button {
            font-size: 0.9rem;
        }

        .accordion-body ol li {
            margin-bottom: 0.5rem;
        }

        /* Mobile responsive adjustments for GPS buttons */
        @media (max-width: 767.98px) {

            #gpsButton,
            #editGpsButton {
                width: 100%;
                margin-bottom: 0.5rem;
            }

            .d-grid.gap-2.d-md-flex {
                display: block !important;
            }

            .d-grid.gap-2.d-md-flex .btn {
                width: 100%;
                margin-bottom: 0.5rem;
            }
        }
    </style>
</head>

<body>
    <div class="container-fluid">
