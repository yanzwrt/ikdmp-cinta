    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        // Generate Invoices
        document.getElementById('generateInvoicesBtn').addEventListener('click', function () {
            if (confirm('Apakah Anda yakin ingin generate invoice untuk semua pelanggan aktif?')) {
                this.disabled = true;
                this.innerHTML = '<i class="bx bx-loader-alt bx-spin"></i> Generating...';

                fetch('/admin/billing/auto-invoice/generate', {
                    method: 'POST'
                })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            showAlert('success', `Berhasil generate ${data.count} invoice`);
                            setTimeout(() => location.reload(), 2000);
                        } else {
                            showAlert('danger', data.message || 'Gagal generate invoice');
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        showAlert('danger', 'Terjadi kesalahan');
                    })
                    .finally(() => {
                        this.disabled = false;
                        this.innerHTML = '<i class="bx bx-calendar-plus"></i> Generate Invoice Bulan Ini';
                    });
            }
        });

        // Preview Invoices
        document.getElementById('previewInvoicesBtn').addEventListener('click', function () {
            this.disabled = true;
            this.innerHTML = '<i class="bx bx-loader-alt bx-spin"></i> Loading...';

            fetch('/admin/billing/auto-invoice/preview')
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        displayPreview(data.customers);
                        document.getElementById('previewSection').style.display = 'block';
                    } else {
                        showAlert('danger', data.message || 'Gagal memuat preview');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    showAlert('danger', 'Terjadi kesalahan');
                })
                .finally(() => {
                    this.disabled = false;
                    this.innerHTML = '<i class="bx bx-show"></i> Preview Invoice yang Akan Dibuat';
                });
        });

        // Display Preview
        function displayPreview(customers) {
            const tbody = document.getElementById('previewTableBody');
            tbody.innerHTML = '';

            if (customers.length === 0) {
                tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted">Tidak ada pelanggan yang perlu dibuatkan invoice</td></tr>';
                return;
            }

            customers.forEach(customer => {
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td>${customer.username}</td>
                    <td>${customer.name}</td>
                    <td>${customer.package_name || '-'}</td>
                    <td>Rp ${Math.round(parseFloat(customer.package_price || 0)).toLocaleString('id-ID')}</td>
                    <td><span class="badge bg-success">Aktif</span></td>
                `;
                tbody.appendChild(row);
            });
        }

        // Confirm Generate
        document.getElementById('confirmGenerateBtn').addEventListener('click', function () {
            document.getElementById('generateInvoicesBtn').click();
        });

        // Cancel Preview
        document.getElementById('cancelPreviewBtn').addEventListener('click', function () {
            document.getElementById('previewSection').style.display = 'none';
        });

        // Settings form removed

        function showAlert(type, message) {
            const alertHtml = `
                <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `;
            document.querySelector('.main-content').insertAdjacentHTML('afterbegin', alertHtml);
        }
    </script>
    <script>
        (function () {
            const currentPath = window.location.pathname.replace(/\/+$/, '');
            const billingTabLinks = Array.from(document.querySelectorAll('.billing-tabs .nav-link'));
            let bestMatch = null;

            billingTabLinks.forEach((link) => {
                const linkPath = new URL(link.href, window.location.origin).pathname.replace(/\/+$/, '');
                const isMatch = currentPath === linkPath || currentPath.startsWith(linkPath + '/');

                if (isMatch && (!bestMatch || linkPath.length > bestMatch.path.length)) {
                    bestMatch = { link, path: linkPath };
                }
            });

            if (bestMatch) {
                billingTabLinks.forEach((link) => link.classList.remove('active'));
                bestMatch.link.classList.add('active');
            }
        })();
    </script>
    <!-- Mobile Bottom Navbar -->
    <%- include('../../partials/admin-mobile-navbar', { currentPage: 'settings' }) %>
</body>

</html>
