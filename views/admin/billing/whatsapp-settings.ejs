    </main>

    <script>
        let templates = {};
        let allGroups = [];
        let selectedGroups = [];

        // Load templates on page load
        document.addEventListener('DOMContentLoaded', function () {
            loadTemplates();
            loadStatus();
            loadRateLimitSettings();
            loadWAGroups();
            loadProviderSettings();

            // Handle provider selection change
            const providerSelect = document.getElementById('whatsappProvider');
            if (providerSelect) {
                providerSelect.addEventListener('change', function () {
                    handleProviderChange(this.value);
                });
            }

            // Handle provider form submission
            const providerForm = document.getElementById('providerForm');
            if (providerForm) {
                providerForm.addEventListener('submit', async function (e) {
                    e.preventDefault();
                    await saveProviderSettings();
                });
            }

            // Auto-save on toggle change: Rate Limit enabled
            const rateToggle = document.getElementById('enableRateLimit');
            if (rateToggle) {
                rateToggle.addEventListener('change', async function () {
                    try {
                        await saveRateLimitSettings();
                        // success handled inside saveRateLimitSettings via showAlert
                    } catch (e) { }
                });
            }

            // Auto-save on toggle change: WhatsApp Groups enabled
            const groupToggle = document.getElementById('waGroupsEnabled');
            if (groupToggle) {
                groupToggle.addEventListener('change', async function () {
                    try {
                        await saveWAGroups();
                        // success handled inside saveWAGroups via showAlert
                    } catch (e) { }
                });
            }

            // Handle WA Groups form submission
            const waGroupsForm = document.getElementById('waGroupsForm');
            if (waGroupsForm) {
                waGroupsForm.addEventListener('submit', async function (e) {
                    e.preventDefault();
                    await saveWAGroups();
                });
            }

            // Auto-save on toggle change: Dual Mode enabled
            const dualModeToggle = document.getElementById('dualModeEnabled');
            if (dualModeToggle) {
                dualModeToggle.addEventListener('change', async function () {
                    try {
                        await saveProviderSettings();
                        // success handled inside saveProviderSettings via showAlert
                    } catch (e) { }
                });
            }
        });

        // Load WhatsApp Groups settings
        async function loadWAGroups() {
            try {
                const response = await fetch('/admin/settings/data');
                const data = await response.json();

                if (data) {
                    const waGroupsEnabled = data.whatsapp_groups_enabled === true;
                    const waGroupsToggle = document.getElementById('waGroupsEnabled');
                    if (waGroupsToggle) {
                        waGroupsToggle.checked = waGroupsEnabled;
                        handleWAGroupsChange(waGroupsEnabled);
                    }

                    // Load selected technician groups
                    const techGroups = data.whatsapp_technician_groups || [];
                    if (techGroups.length > 0) {
                        selectedGroups = techGroups;
                        updateSelectedGroupsDisplay();
                    }
                }
            } catch (error) {
                console.error('Gagal memuat pengaturan grup WA:', error);
            }
        }

        // Handle WA Groups toggle change
        function handleWAGroupsChange(enabled) {
            const waGroupsConfig = document.getElementById('waGroupsConfig');
            if (waGroupsConfig) {
                waGroupsConfig.style.display = enabled ? 'block' : 'none';
            }
        }

        // Load WhatsApp groups from backend
        async function loadWhatsAppGroups() {
            try {
                const loading = document.getElementById('groupsLoading');
                const groupsList = document.getElementById('groupsList');

                if (loading) loading.style.display = 'inline';

                const response = await fetch('/admin/billing/whatsapp-settings/groups');
                const data = await response.json();

                if (data.success && data.groups) {
                    allGroups = data.groups;
                    renderGroupsList(data.groups);
                } else {
                    groupsList.innerHTML = `<div class="alert alert-warning">${data.message || 'Gagal memuat daftar grup'}</div>`;
                }

                if (loading) loading.style.display = 'none';
            } catch (error) {
                console.error('Gagal memuat grup WhatsApp:', error);
                const groupsList = document.getElementById('groupsList');
                groupsList.innerHTML = `<div class="alert alert-danger">Error: ${error.message}</div>`;
            }
        }

        // Render groups list with checkboxes
        function renderGroupsList(groups) {
            const groupsList = document.getElementById('groupsList');

            if (!groups || groups.length === 0) {
                groupsList.innerHTML = '<div class="text-muted">Tidak ada grup WhatsApp ditemukan</div>';
                return;
            }

            let html = '<div class="list-group">';
            groups.forEach(group => {
                const isSelected = selectedGroups.includes(group.id);
                html += `
                <div class="list-group-item list-group-item-action">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="group_${group.id}"
                               value="${group.id}" ${isSelected ? 'checked' : ''}
                               onchange="toggleGroupSelection('${group.id}')">
                        <label class="form-check-label" for="group_${group.id}">
                            <strong>${group.name}</strong>
                            <br>
                            <small class="text-muted">
                                <i class="bi bi-people"></i> ${group.participants} anggota
                            </small>
                        </label>
                    </div>
                </div>
            `;
            });
            html += '</div>';

            groupsList.innerHTML = html;
        }

        // Toggle group selection
        function toggleGroupSelection(groupId) {
            const index = selectedGroups.indexOf(groupId);
            if (index > -1) {
                selectedGroups.splice(index, 1);
            } else {
                selectedGroups.push(groupId);
            }
            updateSelectedGroupsDisplay();
        }

        // Update selected groups display
        function updateSelectedGroupsDisplay() {
            const selectedGroupsDiv = document.getElementById('selectedGroups');

            if (selectedGroups.length === 0) {
                selectedGroupsDiv.innerHTML = '<span class="text-muted">Belum ada grup yang dipilih</span>';
                return;
            }

            let html = '<div class="d-flex flex-wrap gap-2">';
            selectedGroups.forEach(groupId => {
                const group = allGroups.find(g => g.id === groupId);
                if (group) {
                    html += `
                    <span class="badge bg-primary">
                        ${group.name}
                        <button type="button" class="btn-close btn-close-white ms-1" onclick="toggleGroupSelection('${groupId}')"></button>
                    </span>
                `;
                }
            });
            html += '</div>';

            selectedGroupsDiv.innerHTML = html;
        }

        // Save WA Groups settings
        async function saveWAGroups() {
            try {
                const formData = new FormData(document.getElementById('waGroupsForm'));
                const settings = {};

                formData.forEach((value, key) => {
                    settings[key] = value;
                });

                // Add selected technician groups
                settings.whatsapp_technician_groups = selectedGroups;

                const response = await fetch('/admin/settings/save', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(settings)
                });

                const data = await response.json();

                if (data.success) {
                    showAlert('Pengaturan WhatsApp Groups berhasil disimpan!', 'success');
                } else {
                    showAlert('Error: ' + (data.message || 'Gagal menyimpan pengaturan'), 'danger');
                }
            } catch (error) {
                console.error('Gagal menyimpan pengaturan grup WA:', error);
                showAlert('Gagal menyimpan pengaturan Grup WhatsApp', 'danger');
            }
        }

        // Load provider settings
        async function loadProviderSettings() {
            try {
                const response = await fetch('/admin/settings/data');
                const data = await response.json();

                if (data) {
                    const provider = data.whatsapp_provider || 'baileys';
                    const dualMode = data.whatsapp_dual_mode === true;

                    const providerSelect = document.getElementById('whatsappProvider');
                    if (providerSelect) {
                        providerSelect.value = provider;
                        handleProviderChange(provider);
                    }

                    // Load dual mode setting
                    const dualModeToggle = document.getElementById('dualModeEnabled');
                    if (dualModeToggle) {
                        dualModeToggle.checked = dualMode;
                        handleDualModeChange(dualMode);
                    }

                    // Load Meta API settings if available
                    if (data.whatsapp_meta_api_key) {
                        document.getElementById('metaApiKey').value = data.whatsapp_meta_api_key;
                    }
                    if (data.whatsapp_phone_number_id) {
                        document.getElementById('phoneNumberId').value = data.whatsapp_phone_number_id;
                    }
                    if (data.whatsapp_webhook_url) {
                        document.getElementById('webhookUrl').value = data.whatsapp_webhook_url;
                    }
                    if (data.whatsapp_verify_token) {
                        document.getElementById('verifyToken').value = data.whatsapp_verify_token;
                    }
                }
            } catch (error) {
                console.error('Gagal memuat pengaturan penyedia:', error);
            }
        }

        // Handle provider selection change
        function handleProviderChange(provider) {
            const metaApiConfig = document.getElementById('metaApiConfig');
            const providerStatus = document.getElementById('providerStatus');

            if (provider === 'meta_api') {
                metaApiConfig.style.display = 'block';
                providerStatus.innerHTML = '<i class="bi bi-check-circle"></i> Penyedia Aktif: Meta API';
                providerStatus.className = 'alert alert-success';
            } else {
                metaApiConfig.style.display = 'none';
                providerStatus.innerHTML = '<i class="bi bi-check-circle"></i> Penyedia Aktif: Baileys';
                providerStatus.className = 'alert alert-info';
            }
        }

        // Handle dual mode toggle
        function handleDualModeChange(enabled) {
            const dualModeInfo = document.getElementById('dualModeInfo');
            const metaApiConfig = document.getElementById('metaApiConfig');

            if (enabled) {
                dualModeInfo.style.display = 'block';
                // Show Meta API config when dual mode is enabled
                metaApiConfig.style.display = 'block';
            } else {
                dualModeInfo.style.display = 'none';
                // Hide Meta API config if provider is not meta_api
                const provider = document.getElementById('whatsappProvider').value;
                if (provider !== 'meta_api') {
                    metaApiConfig.style.display = 'none';
                }
            }
        }

        // Save provider settings
        async function saveProviderSettings() {
            try {
                const formData = new FormData(document.getElementById('providerForm'));
                const settings = {};

                formData.forEach((value, key) => {
                    settings[key] = value;
                });

                const response = await fetch('/admin/settings/save', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(settings)
                });

                const data = await response.json();

                if (data.success) {
                    showAlert('Pengaturan penyedia berhasil disimpan! Restart aplikasi untuk menerapkan perubahan.', 'success');
                } else {
                    showAlert('Error: ' + (data.message || 'Gagal menyimpan pengaturan'), 'danger');
                }
            } catch (error) {
                console.error('Gagal menyimpan pengaturan penyedia:', error);
                showAlert('Gagal menyimpan pengaturan penyedia', 'danger');
            }
        }

        // Load templates from server
        async function loadTemplates() {
            try {
                const response = await fetch('/admin/billing/whatsapp-settings/templates');
                const data = await response.json();

                if (data.success) {
                    templates = data.templates;

                    // Populate form fields
                    Object.keys(templates).forEach(key => {
                        const textarea = document.getElementById(`${key}_template`);
                        const toggle = document.getElementById(`${key}_enabled`);

                        if (textarea) {
                            textarea.value = templates[key].template || '';
                        }

                        if (toggle) {
                            toggle.checked = templates[key].enabled !== false; // Default to true if not specified
                        }
                    });
                }
            } catch (error) {
                console.error('Gagal memuat template:', error);
                showAlert('Gagal memuat template', 'danger');
            }
        }

        // Load status information
        async function loadStatus() {
            try {
                const response = await fetch('/admin/billing/whatsapp-settings/status');
                const data = await response.json();

                if (data.success) {
                    document.getElementById('whatsappStatus').textContent = data.whatsappStatus;
                    document.getElementById('activeCustomers').textContent = data.activeCustomers;
                    document.getElementById('pendingInvoices').textContent = data.pendingInvoices;
                    document.getElementById('nextReminder').textContent = data.nextReminder;
                }
            } catch (error) {
                console.error('Gagal memuat status:', error);
            }
        }

        // Save all templates
        async function saveAllTemplates() {
            try {
                // Collect all template data
                const templateData = {};
                Object.keys(templates).forEach(key => {
                    const textarea = document.getElementById(`${key}_template`);
                    const toggle = document.getElementById(`${key}_enabled`);

                    if (textarea) {
                        templateData[key] = {
                            title: templates[key].title,
                            template: textarea.value,
                            enabled: toggle ? toggle.checked : true
                        };
                    }
                });

                const response = await fetch('/admin/billing/whatsapp-settings/templates', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(templateData)
                });

                const data = await response.json();

                if (data.success) {
                    showAlert('Template berhasil disimpan!', 'success');
                } else {
                    showAlert('Gagal menyimpan template: ' + data.message, 'danger');
                }
            } catch (error) {
                console.error('Gagal menyimpan template:', error);
                showAlert('Gagal menyimpan template', 'danger');
            }
        }

        // Test template
        async function testTemplate(templateKey) {
            const phoneNumber = prompt('Masukkan nomor telepon untuk uji coba (6281234567890):');
            if (!phoneNumber) return;

            try {
                const response = await fetch('/admin/billing/whatsapp-settings/test', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        phoneNumber: phoneNumber,
                        templateKey: templateKey
                    })
                });

                const data = await response.json();

                if (data.success) {
                    showAlert('Notifikasi uji berhasil dikirim!', 'success');
                } else {
                    showAlert('Gagal mengirim notifikasi uji: ' + data.message, 'danger');
                }
            } catch (error) {
                console.error('Gagal mengirim notifikasi uji:', error);
                showAlert('Gagal mengirim notifikasi uji', 'danger');
            }
        }

        // Send test notification
        async function sendTestNotification() {
            const phoneNumber = document.getElementById('testPhoneNumber').value;
            const templateType = document.getElementById('testTemplateType').value;

            if (!phoneNumber) {
                showAlert('Silakan masukkan nomor telepon', 'danger');
                return;
            }

            try {
                const response = await fetch('/admin/billing/whatsapp-settings/test', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        phoneNumber: phoneNumber,
                        templateKey: templateType
                    })
                });

                const data = await response.json();

                if (data.success) {
                    showAlert('Notifikasi uji berhasil dikirim!', 'success');
                } else {
                    showAlert('Gagal mengirim notifikasi uji: ' + data.message, 'danger');
                }
            } catch (error) {
                console.error('Gagal mengirim notifikasi uji:', error);
                showAlert('Gagal mengirim notifikasi uji', 'danger');
            }
        }

        // Send broadcast message
        async function sendBroadcast() {
            const broadcastType = document.getElementById('broadcastType').value;
            const message = document.getElementById('broadcastMessage').value;

            if (!message) {
                showAlert('Silakan masukkan pesan', 'danger');
                return;
            }

            const broadcastData = {
                type: broadcastType,
                message: message
            };

            if (broadcastType === 'service_disruption') {
                broadcastData.disruptionType = document.getElementById('disruptionType').value;
                broadcastData.affectedArea = document.getElementById('affectedArea').value;
                broadcastData.estimatedResolution = document.getElementById('estimatedResolution').value;
            }

            if (!confirm('Apakah Anda yakin ingin mengirim broadcast ini ke semua pelanggan aktif?')) {
                return;
            }

            try {
                const response = await fetch('/admin/billing/whatsapp-settings/broadcast', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(broadcastData)
                });

                const data = await response.json();

                if (data.success) {
                    const summary = `Broadcast sukses!\n` +
                        `Pelanggan: ${data.customer_sent || 0} sukses / ${data.customer_failed || 0} gagal\n` +
                        `Grup: ${data.group_sent || 0} sukses / ${data.group_failed || 0} gagal`;
                    showAlert(summary, 'success');
                } else {
                    showAlert('Gagal mengirim broadcast: ' + data.message, 'danger');
                }
            } catch (error) {
                console.error('Gagal mengirim broadcast:', error);
                showAlert('Gagal mengirim broadcast', 'danger');
            }
        }

        // Show alert function (using global function from footer)
        function showAlert(message, type) {
            // Use global showAlert function from footer
            if (typeof window.showAlert === 'function') {
                window.showAlert(message, type);
            } else {
                // Fallback if global function not available
                const alertDiv = document.createElement('div');
                alertDiv.className = `alert alert-${type} alert-dismissible fade show`;
                alertDiv.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;

                document.querySelector('.main-content').insertBefore(alertDiv, document.querySelector('.main-content').firstChild);

                // Auto dismiss after 5 seconds
                setTimeout(() => {
                    if (alertDiv.parentNode) {
                        alertDiv.remove();
                    }
                }, 5000);
            }
        }

        // Function to update template status display
        function updateTemplateStatus() {
            const templateKeys = [
                'invoice_created', 'due_date_reminder', 'payment_received',
                'service_disruption', 'service_announcement', 'service_suspension',
                'service_restoration', 'welcome_message'
            ];

            templateKeys.forEach(key => {
                const toggle = document.getElementById(`${key}_enabled`);
                const textarea = document.getElementById(`${key}_template`);

                if (toggle && textarea) {
                    // Update textarea style based on toggle state
                    if (toggle.checked) {
                        textarea.classList.remove('template-disabled');
                        textarea.classList.add('template-enabled');
                        textarea.disabled = false;
                    } else {
                        textarea.classList.remove('template-enabled');
                        textarea.classList.add('template-disabled');
                        textarea.disabled = true;
                    }
                }
            });
        }

        // Function to enable all templates
        function enableAllTemplates() {
            const toggles = document.querySelectorAll('input[type="checkbox"][id$="_enabled"]');
            toggles.forEach(toggle => {
                toggle.checked = true;
            });
            updateTemplateStatus();
            showAlert('Semua template diaktifkan!', 'success');
        }

        // Function to disable all templates
        function disableAllTemplates() {
            const toggles = document.querySelectorAll('input[type="checkbox"][id$="_enabled"]');
            toggles.forEach(toggle => {
                toggle.checked = false;
            });
            updateTemplateStatus();
            showAlert('Semua template dinonaktifkan!', 'warning');
        }

        // Add event listeners for toggles
        document.addEventListener('DOMContentLoaded', function () {
            const toggles = document.querySelectorAll('input[type="checkbox"][id$="_enabled"]');
            toggles.forEach(toggle => {
                toggle.addEventListener('change', updateTemplateStatus);
            });

            // Initial status update
            updateTemplateStatus();
        });

        // Load rate limit settings
        async function loadRateLimitSettings() {
            try {
                const response = await fetch('/admin/billing/whatsapp-settings/rate-limit');
                const data = await response.json();

                if (data.success) {
                    const settings = data.settings;
                    document.getElementById('maxMessagesPerBatch').value = settings.maxMessagesPerBatch || 10;
                    document.getElementById('delayBetweenBatches').value = settings.delayBetweenBatches || 30;
                    document.getElementById('delayBetweenMessages').value = settings.delayBetweenMessages || 2;
                    document.getElementById('maxRetries').value = settings.maxRetries || 2;
                    document.getElementById('dailyMessageLimit').value = settings.dailyMessageLimit || 0;
                    document.getElementById('enableRateLimit').checked = settings.enabled !== false;
                }
            } catch (error) {
                console.error('Gagal memuat pengaturan batas laju:', error);
                showAlert('Gagal memuat pengaturan batas laju', 'danger');
            }
        }

        // Save rate limit settings
        async function saveRateLimitSettings() {
            try {
                const settings = {
                    maxMessagesPerBatch: parseInt(document.getElementById('maxMessagesPerBatch').value) || 10,
                    delayBetweenBatches: parseInt(document.getElementById('delayBetweenBatches').value) || 30,
                    delayBetweenMessages: parseInt(document.getElementById('delayBetweenMessages').value) || 2,
                    maxRetries: parseInt(document.getElementById('maxRetries').value) || 2,
                    dailyMessageLimit: parseInt(document.getElementById('dailyMessageLimit').value) || 0,
                    enabled: document.getElementById('enableRateLimit').checked
                };

                // Validate settings
                if (settings.maxMessagesPerBatch < 1 || settings.maxMessagesPerBatch > 100) {
                    showAlert('Maksimal pesan per batch harus antara 1-100', 'danger');
                    return;
                }

                if (settings.delayBetweenBatches < 1 || settings.delayBetweenBatches > 300) {
                    showAlert('Jeda antar batch harus antara 1-300 detik', 'danger');
                    return;
                }

                if (settings.delayBetweenMessages < 0 || settings.delayBetweenMessages > 10) {
                    showAlert('Jeda antar pesan harus antara 0-10 detik', 'danger');
                    return;
                }

                if (settings.maxRetries < 0 || settings.maxRetries > 5) {
                    showAlert('Maksimal retry harus antara 0-5', 'danger');
                    return;
                }

                if (settings.dailyMessageLimit < 0 || settings.dailyMessageLimit > 1000) {
                    showAlert('Batas harian harus antara 0-1000', 'danger');
                    return;
                }

                const response = await fetch('/admin/billing/whatsapp-settings/rate-limit', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(settings)
                });

                const data = await response.json();

                if (data.success) {
                    showAlert('Pengaturan batas laju berhasil disimpan!', 'success');
                } else {
                    showAlert('Gagal menyimpan pengaturan: ' + data.message, 'danger');
                }
            } catch (error) {
                console.error('Gagal menyimpan pengaturan batas laju:', error);
                showAlert('Gagal menyimpan pengaturan batas laju', 'danger');
            }
        }

        // Reset rate limit settings to default
        function resetRateLimitSettings() {
            if (confirm('Apakah Anda yakin ingin mereset pengaturan ke default?')) {
                document.getElementById('maxMessagesPerBatch').value = 10;
                document.getElementById('delayBetweenBatches').value = 30;
                document.getElementById('delayBetweenMessages').value = 2;
                document.getElementById('maxRetries').value = 2;
                document.getElementById('dailyMessageLimit').value = 0;
                document.getElementById('enableRateLimit').checked = true;
                showAlert('Pengaturan telah direset ke default', 'info');
            }
        }

        // Load WhatsApp groups
        async function loadWAGroups() {
            try {
                const response = await fetch('/admin/billing/whatsapp-settings/groups');
                const data = await response.json();
                if (data.success) {
                    document.getElementById('waGroupsEnabled').checked = data.groups.enabled !== false;
                    const ids = (data.groups.ids || []).join('\n');
                    document.getElementById('waGroupIds').value = ids;
                }
            } catch (error) {
                console.error('Gagal memuat grup WhatsApp:', error);
                showAlert('Gagal memuat grup WhatsApp', 'danger');
            }
        }

        // Save WhatsApp groups
        async function saveWAGroups() {
            try {
                const enabled = document.getElementById('waGroupsEnabled').checked;
                const idsRaw = document.getElementById('waGroupIds').value || '';
                const ids = idsRaw.split(/\r?\n/).map(s => s.trim()).filter(Boolean);

                const response = await fetch('/admin/billing/whatsapp-settings/groups', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ enabled, ids })
                });
                const data = await response.json();
                if (data.success) showAlert('Pengaturan grup WhatsApp disimpan!', 'success');
                else showAlert('Gagal menyimpan grup: ' + data.message, 'danger');
            } catch (error) {
                console.error('Gagal menyimpan grup WhatsApp:', error);
                showAlert('Error menyimpan grup WhatsApp', 'danger');
            }
        }

        function resetWAGroupsToDefault() {
            document.getElementById('waGroupsEnabled').checked = true;
            document.getElementById('waGroupIds').value = '';
        }
    </script>

