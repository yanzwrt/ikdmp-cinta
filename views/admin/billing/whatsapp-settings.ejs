<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pengaturan WhatsApp - Portal Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/boxicons@2.0.7/css/boxicons.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Admin Mobile Optimizations -->
    <link href="/css/admin-mobile.css" rel="stylesheet">
    <link href="/css/responsive-admin.css" rel="stylesheet">
    
    <!-- Dark Mode Script -->
    <script>
        const theme = localStorage.getItem('theme') || 'light';
        document.documentElement.setAttribute('data-theme', theme);
    </script>
    <style>
        /* Dark Mode Styles */
        [data-theme="dark"] {
            --bg-color: #1a1c23;
            --text-color: #e2e8f0;
            --card-bg: #24262d;
            --border-color: #4a5568;
            --sidebar-bg: #1a1c23;
            --input-bg: #2d3748;
        }
        
        [data-theme="dark"] body {
            background-color: var(--bg-color);
            color: var(--text-color);
        }

        [data-theme="dark"] .status-card,
        [data-theme="dark"] .template-card {
            background-color: var(--card-bg);
            border-color: var(--border-color);
            color: var(--text-color);
        }
        
        [data-theme="dark"] .template-title {
            color: var(--text-color);
        }
        
        [data-theme="dark"] .template-description {
            color: #a0aec0;
        }
        
        [data-theme="dark"] .template-header {
            border-bottom-color: var(--border-color);
        }
        
        [data-theme="dark"] .form-control,
        [data-theme="dark"] .form-select {
            background-color: var(--input-bg);
            border-color: var(--border-color);
            color: var(--text-color);
        }
        
        [data-theme="dark"] .variable-list {
            background-color: var(--input-bg);
            color: var(--text-color);
        }
        
        [data-theme="dark"] .variable-item {
            background-color: #4a5568;
            color: #e2e8f0;
        }
        
        [data-theme="dark"] .template-disabled {
            background-color: #2d3748 !important;
            opacity: 0.6;
        }
        
        [data-theme="dark"] .template-enabled {
            background-color: var(--input-bg) !important;
            opacity: 1;
        }

        [data-theme="dark"] .list-group-item {
            background-color: var(--card-bg);
            border-color: var(--border-color);
            color: var(--text-color);
        }
        
        [data-theme="dark"] .list-group-item-action:hover {
            background-color: var(--border-color);
        }

        /* Layout Adjustments */
        .main-content {
            transition: margin-left 0.3s ease;
            padding-top: 20px !important;
        }
        
        @media (min-width: 992px) {
            .sidebar.collapsed + .main-content {
                margin-left: 80px;
                width: calc(100% - 80px);
            }
        }
    
        .status-card {
            background: white;
            border-radius: 15px;
            padding: 1.5rem;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
            margin-bottom: 2rem;
            border-left: 5px solid #667eea;
        }

        .template-card {
            background: white;
            border-radius: 15px;
            padding: 1.5rem;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
            margin-bottom: 2rem;
            border: 1px solid #e9ecef;
        }

        .template-header {
            display: flex;
            justify-content: between;
            align-items: center;
            margin-bottom: 1rem;
            padding-bottom: 1rem;
            border-bottom: 2px solid #f8f9fa;
        }

        .template-title {
            font-weight: bold;
            color: #2c3e50;
            margin: 0;
        }

        .template-description {
            color: #6c757d;
            font-size: 0.9rem;
            margin-top: 0.5rem;
        }

        .form-control,
        .form-select {
            border-radius: 10px;
            border: 2px solid #e9ecef;
            padding: 0.75rem 1rem;
            transition: all 0.3s ease;
        }

        .form-control:focus,
        .form-select:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
        }

        .btn {
            border-radius: 10px;
            padding: 0.75rem 1.5rem;
            font-weight: 500;
            transition: all 0.3s ease;
            border: none;
        }

        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
        }

        .btn-success {
            background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        }

        .btn-warning {
            background: linear-gradient(135deg, #ffc107 0%, #fd7e14 100%);
        }

        .btn-danger {
            background: linear-gradient(135deg, #dc3545 0%, #e83e8c 100%);
        }

        .alert {
            border-radius: 10px;
            border: none;
        }

        .form-check-input:checked {
            background-color: #28a745;
            border-color: #28a745;
        }

        .form-check-input:not(:checked) {
            background-color: #dc3545;
            border-color: #dc3545;
        }

        .template-disabled {
            opacity: 0.6;
            background-color: #f8f9fa !important;
        }

        .template-enabled {
            opacity: 1;
            background-color: #fff !important;
        }

        .variable-item {
            display: inline-block;
            background: #e9ecef;
            padding: 2px 8px;
            margin: 2px;
            border-radius: 4px;
            font-size: 0.8rem;
            color: #495057;
        }

        .variable-list {
            margin-bottom: 1rem;
            padding: 0.5rem;
            background: #f8f9fa;
            border-radius: 5px;
        }
    </style>
</head>

<body>
    <!-- Include Sidebar -->
    <%- include('../../partials/billing-responsive-sidebar', { page: 'whatsapp-settings' }) %>

    <!-- Main content -->
    <main class="main-content">
        <div class="container-fluid">
            <style>
                .nav.nav-tabs {
                    border-bottom: 1px solid rgba(148, 163, 184, 0.24) !important;
                    gap: 1.1rem !important;
                }

                .nav.nav-tabs .nav-link {
                    border: 0 !important;
                    border-radius: 0 !important;
                    background: transparent !important;
                    box-shadow: none !important;
                    color: #64748b !important;
                    font-weight: 700 !important;
                    padding: 0.7rem 0.05rem 0.8rem !important;
                    display: inline-flex !important;
                    align-items: center !important;
                    gap: 0.45rem !important;
                    border-bottom: 3px solid transparent !important;
                }

                .nav.nav-tabs .nav-link:hover {
                    color: #2563eb !important;
                }

                .nav.nav-tabs .nav-link.active {
                    color: #2563eb !important;
                    border-bottom-color: #2563eb !important;
                }

                [data-theme="dark"] .nav.nav-tabs {
                    border-bottom-color: rgba(71, 85, 105, 0.5) !important;
                }

                [data-theme="dark"] .nav.nav-tabs .nav-link {
                    color: #cbd5e1 !important;
                }

                [data-theme="dark"] .nav.nav-tabs .nav-link.active {
                    color: #60a5fa !important;
                    border-bottom-color: #60a5fa !important;
                }
            </style>
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h3 class="mb-0">Pengaturan</h3>
            </div>

            <!-- Tab Navigation -->
            <ul class="nav nav-tabs mb-4">
                        <li class="nav-item">
                            <a class="nav-link <%= typeof page !== 'undefined' && page === 'payment-settings' ? 'active' : '' %>" data-settings-tab="payment-settings"
                                href="/admin/billing/payment-settings">
                                <i class="bi bi-cog"></i> Pengaturan Pembayaran
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= typeof page !== 'undefined' && page === 'whatsapp-settings' ? 'active' : '' %>" data-settings-tab="whatsapp-settings"
                                href="/admin/billing/whatsapp-settings">
                                <i class="bi bi-chat-dots"></i> Pengaturan WhatsApp
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= typeof page !== 'undefined' && page === 'service-suspension' ? 'active' : '' %>" data-settings-tab="service-suspension"
                                href="/admin/billing/service-suspension">
                                <i class="bi bi-pause-circle"></i> Pengaturan ISOLIR
                            </a>
                        </li>
                    </ul>
            <script>
                (function () {
                    const path = window.location.pathname;
                    let activeKey = 'payment-settings';
                    if (path.includes('/whatsapp-settings')) activeKey = 'whatsapp-settings';
                    if (path.includes('/service-suspension')) activeKey = 'service-suspension';
                    document.querySelectorAll('[data-settings-tab]').forEach(tab => {
                        const isActive = tab.getAttribute('data-settings-tab') === activeKey;
                        tab.classList.toggle('active', isActive);
                        tab.style.borderBottomColor = isActive ? '#2563eb' : 'transparent';
                        tab.style.color = isActive ? '#2563eb' : '';
                    });
                })();
            </script>

                    <div
                        class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                        <h1 class="h2">
                            <i class="bx bx-whatsapp"></i> Pengaturan WhatsApp
                        </h1>
                    </div>

                    <!-- Status Cards -->
                    <div class="row">
                        <div class="col-md-3">
                            <div class="status-card">
                                <h5><i class="bi bi-whatsapp text-success"></i> Status WhatsApp</h5>
                                <p class="mb-0" id="whatsappStatus">Memeriksa...</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="status-card">
                                <h5><i class="bi bi-people text-primary"></i> Pelanggan Aktif</h5>
                                <p class="mb-0" id="activeCustomers">Memuat...</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="status-card">
                                <h5><i class="bi bi-receipt text-warning"></i> Tagihan Tertunda</h5>
                                <p class="mb-0" id="pendingInvoices">Memuat...</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="status-card">
                                <h5><i class="bi bi-calendar-check text-info"></i> Pengingat Berikutnya</h5>
                                <p class="mb-0" id="nextReminder">Memuat...</p>
                            </div>
                        </div>
                    </div>

                    <!-- WhatsApp Provider Selection Section -->
                    <div class="row">
                        <div class="col-12">
                            <div class="template-card">
                                <div class="template-header">
                                    <h4 class="template-title">
                                        <i class="bi bi-toggle-on"></i> Penyedia WhatsApp
                                    </h4>
                                </div>

                                <div class="template-description">
                                    Pilih provider WhatsApp yang akan digunakan untuk mengirim pesan. Baileys
                                    menggunakan WhatsApp Web (gratis), Meta API menggunakan API resmi Facebook
                                    (berbayar).
                                    <br><br>
                                    <strong class="text-danger">⚠️ Meta API Khusus Broadcast:</strong>
                                    <ul class="mb-0">
                                        <li>Meta API hanya untuk <strong>broadcast tagihan & info</strong> (outbound)
                                        </li>
                                        <li>Tidak support command handling (REG, STATUS, MENU, dll)</li>
                                        <li>Gunakan Baileys atau Dual Mode untuk fitur lengkap</li>
                                    </ul>
                                </div>

                                <form id="providerForm">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <label for="whatsappProvider" class="form-label">
                                                    <i class="bi bi-whatsapp"></i> Pilih Provider
                                                </label>
                                                <select class="form-select" id="whatsappProvider"
                                                    name="whatsapp_provider">
                                                    <option value="baileys" selected>Baileys (WhatsApp Web - Gratis)
                                                    </option>
                                                    <option value="meta_api">Meta API (Official - Berbayar)</option>
                                                </select>
                                                <div class="form-text mt-2">
                                                    <small>
                                                        <strong>Baileys:</strong> Gratis, menggunakan WhatsApp Web,
                                                        mudah diblokir<br>
                                                        <strong>Meta API:</strong> Berbayar, stabil, membutuhkan API Key
                                                        dari Meta
                                                    </small>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <label class="form-label">
                                                    <i class="bi bi-info-circle"></i> Status Penyedia
                                                </label>
                                                <div class="alert alert-info" id="providerStatus">
                                                    <i class="bi bi-check-circle"></i> Penyedia Aktif: Baileys
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Dual Mode Option -->
                                    <div class="row mt-3">
                                        <div class="col-12">
                                            <div class="form-check form-switch mb-2">
                                                <input class="form-check-input" type="checkbox" id="dualModeEnabled"
                                                    name="whatsapp_dual_mode">
                                                <label class="form-check-label" for="dualModeEnabled">
                                                    <strong>Aktifkan Dual Mode (Baileys + Meta API)</strong>
                                                </label>
                                            </div>
                                            <div class="alert alert-warning" id="dualModeInfo" style="display: none;">
                                                <i class="bi bi-info-circle"></i>
                                                <strong>Dual Mode Aktif:</strong><br>
                                                <small>
                                                    • Baileys: Command handling (REG, STATUS, MENU)<br>
                                                    • Meta API: Broadcast massal yang stabil<br>
                                                </small>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Meta API Configuration (Hidden by default) -->
                                    <div id="metaApiConfig" style="display: none;">
                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="mb-3">
                                                    <label for="metaApiKey" class="form-label">
                                                        <i class="bi bi-key"></i> Kunci API Meta
                                                    </label>
                                                    <input type="password" class="form-control" id="metaApiKey"
                                                        name="whatsapp_meta_api_key"
                                                        placeholder="Masukkan API Key dari Meta">
                                                    <div class="form-text">Dapatkan dari Meta for Developers</div>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="mb-3">
                                                    <label for="phoneNumberId" class="form-label">
                                                        <i class="bi bi-phone"></i> ID Nomor Telepon
                                                    </label>
                                                    <input type="text" class="form-control" id="phoneNumberId"
                                                        name="whatsapp_phone_number_id"
                                                        placeholder="Masukkan ID Nomor Telepon">
                                                    <div class="form-text">ID dari Akun WhatsApp Business</div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="mb-3">
                                                    <label for="webhookUrl" class="form-label">
                                                        <i class="bi bi-link"></i> URL Webhook
                                                    </label>
                                                    <input type="url" class="form-control" id="webhookUrl"
                                                        name="whatsapp_webhook_url"
                                                        placeholder="https://domainanda.com/webhook/whatsapp">
                                                    <div class="form-text">URL untuk menerima pesan masuk</div>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="mb-3">
                                                    <label for="verifyToken" class="form-label">
                                                        <i class="bi bi-shield-lock"></i> Verify Token
                                                    </label>
                                                    <input type="text" class="form-control" id="verifyToken"
                                                        name="whatsapp_verify_token"
                                                        placeholder="Token verifikasi webhook">
                                                    <div class="form-text">Token untuk verifikasi webhook</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="mt-3">
                                        <button type="submit" class="btn btn-primary">
                                            <i class="bi bi-save"></i> Simpan Pengaturan Provider
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- WhatsApp Groups Section -->
                    <div class="row">
                        <div class="col-12">
                            <div class="template-card">
                                <div class="template-header">
                                    <h4 class="template-title">
                                        <i class="bi bi-people-fill"></i> Grup WhatsApp
                                    </h4>
                                </div>

                                <div class="template-description">
                                    Pilih grup WhatsApp untuk menerima broadcast notifikasi (misal: grup teknisi,
                                    grup admin, dll).
                                </div>

                                <form id="waGroupsForm">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="mb-3">
                                                <label class="form-label">
                                                    <i class="bi bi-toggle-on"></i> Aktifkan Grup WhatsApp
                                                </label>
                                                <div class="form-check form-switch">
                                                    <input class="form-check-input" type="checkbox" id="waGroupsEnabled"
                                                        name="whatsapp_groups_enabled">
                                                    <label class="form-check-label" for="waGroupsEnabled">
                                                        <strong>Aktifkan broadcast ke Grup WhatsApp</strong>
                                                    </label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div id="waGroupsConfig" style="display: none;">
                                        <div class="alert alert-info">
                                            <i class="bi bi-info-circle"></i>
                                            <strong>Info:</strong> Pilih grup yang akan menerima broadcast notifikasi.
                                            Pastikan WhatsApp sudah terhubung untuk melihat daftar grup.
                                        </div>

                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="mb-3">
                                                    <button type="button" class="btn btn-primary btn-sm"
                                                        onclick="loadWhatsAppGroups()">
                                                        <i class="bi bi-sync"></i> Muat Ulang Daftar Grup
                                                    </button>
                                                    <span id="groupsLoading" class="ms-2" style="display: none;">
                                                        <i class="bi bi-spinner-border spin"></i> Memuat...
                                                    </span>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="mb-3">
                                                    <label class="form-label">
                                                        <i class="bi bi-list-check"></i> Pilih Grup Teknisi
                                                    </label>
                                                    <div id="groupsList" class="border rounded p-3"
                                                        style="max-height: 300px; overflow-y: auto;">
                                                        <div class="text-muted">
                                                            <small>Klik "Muat Ulang Daftar Grup" untuk melihat daftar
                                                                grup WhatsApp</small>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="mb-3">
                                                    <label class="form-label">
                                                        <i class="bi bi-check2-square"></i> Grup Terpilih
                                                    </label>
                                                    <div id="selectedGroups" class="border rounded p-2"
                                                        style="min-height: 50px;">
                                                        <span class="text-muted">Belum ada grup yang dipilih</span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="mt-3">
                                        <button type="submit" class="btn btn-primary">
                                            <i class="bi bi-save"></i> Simpan Pengaturan Grup
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- Rate Limiting Settings Section -->
                    <div class="row">
                        <div class="col-12">
                            <div class="template-card">
                                <div class="template-header">
                                    <h4 class="template-title">
                                        <i class="bi bi-speedometer2"></i> Pengaturan Batas Laju
                                    </h4>
                                </div>

                                <div class="template-description">
                                    Konfigurasi pengaturan pengiriman pesan untuk menghindari pemblokiran dari WhatsApp.
                                    Atur jumlah pesan maksimal per batch dan jeda waktu antar pengiriman.
                                </div>

                                <form id="rateLimitForm">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <label for="maxMessagesPerBatch" class="form-label">
                                                    <i class="bi bi-envelope"></i> Maksimal Pesan per Batch
                                                </label>
                                                <input type="number" class="form-control" id="maxMessagesPerBatch"
                                                    min="1" max="100" value="10"
                                                    placeholder="Jumlah pesan maksimal yang dikirim sekaligus">
                                                <div class="form-text">Rekomendasi: 5-20 pesan per batch untuk
                                                    menghindari pemblokiran</div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <label for="delayBetweenBatches" class="form-label">
                                                    <i class="bi bi-clock"></i> Jeda Antar Batch (detik)
                                                </label>
                                                <input type="number" class="form-control" id="delayBetweenBatches"
                                                    min="1" max="300" value="30"
                                                    placeholder="Jeda waktu antar batch pengiriman">
                                                <div class="form-text">Rekomendasi: 30-60 detik untuk keamanan</div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <label for="delayBetweenMessages" class="form-label">
                                                    <i class="bi bi-hourglass-split"></i> Jeda Antar Pesan (detik)
                                                </label>
                                                <input type="number" class="form-control" id="delayBetweenMessages"
                                                    min="0" max="10" value="2"
                                                    placeholder="Jeda waktu antar pesan dalam batch">
                                                <div class="form-text">Rekomendasi: 1-3 detik untuk stabilitas</div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <label for="maxRetries" class="form-label">
                                                    <i class="bi bi-arrow-repeat"></i> Maksimal Retry
                                                </label>
                                                <input type="number" class="form-control" id="maxRetries" min="0"
                                                    max="5" value="2" placeholder="Jumlah percobaan ulang jika gagal">
                                                <div class="form-text">Rekomendasi: 2-3 kali untuk efisiensi</div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <label for="dailyMessageLimit" class="form-label">
                                                    <i class="bi bi-calendar-day"></i> Batas Harian (opsional)
                                                </label>
                                                <input type="number" class="form-control" id="dailyMessageLimit" min="0"
                                                    max="1000" value="0" placeholder="0 = tidak terbatas">
                                                <div class="form-text">Batasi total pesan per hari (0 = tidak terbatas)
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <div class="form-check form-switch mt-4">
                                                    <input class="form-check-input" type="checkbox" id="enableRateLimit"
                                                        checked>
                                                    <label class="form-check-label" for="enableRateLimit">
                                                        <strong>Aktifkan Batas Laju</strong>
                                                    </label>
                                                </div>
                                                <div class="form-text">Nonaktifkan untuk pengiriman tanpa batasan (tidak
