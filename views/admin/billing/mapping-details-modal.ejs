                                        </div>
                                        <small class="text-muted d-block mt-2">Jika diubah ke maintenance atau inactive, pelanggan di ODP ini akan menerima notifikasi otomatis.</small>
                                    </td>
                                </tr>
                            </table>
                            <div class="odp-summary-card">
                                <h6 class="text-primary mb-3">Ringkasan Port</h6>
                                <div class="odp-stat-grid mt-0">
                                    <div class="odp-stat-card">
                                        <span class="label">Capacity</span>
                                        <span class="value" id="odp-capacity">-</span>
                                    </div>
                                    <div class="odp-stat-card">
                                        <span class="label">Used Ports</span>
                                        <span class="value" id="odp-used-ports">-</span>
                                    </div>
                                </div>
                                <div class="odp-usage-block">
                                    <h6 class="text-primary mb-2">Port Usage</h6>
                                    <div class="progress mb-2">
                                        <div class="progress-bar" id="odp-progress-bar" role="progressbar" style="width: 0%">
                                            0 / 0 ports
                                        </div>
                                    </div>
                                    <small class="text-muted" id="odp-capacity-text">0% capacity used</small>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="odp-info-card h-100">
                            <h6 class="text-primary mb-3">Location Information</h6>
                            <table class="table table-sm mb-0">
                                <tr><td><strong>Address:</strong></td><td id="odp-address">-</td></tr>
                                <tr><td><strong>Latitude:</strong></td><td id="odp-latitude">-</td></tr>
                                <tr><td><strong>Longitude:</strong></td><td id="odp-longitude">-</td></tr>
                                <tr><td><strong>Installation Date:</strong></td><td id="odp-installation-date">-</td></tr>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="edit-odp-btn">Edit ODP</button>
            </div>
        </div>
    </div>
</div>

