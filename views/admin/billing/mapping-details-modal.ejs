<!-- ODP Details Modal -->
<style>
    .odp-photo-panel {
        background: linear-gradient(180deg, #f8fbff 0%, #edf4ff 100%);
        border: 1px solid rgba(37, 99, 235, 0.12);
        border-radius: 18px;
        padding: 14px;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.8);
    }

    .odp-photo-label {
        display: inline-flex;
        align-items: center;
        font-weight: 700;
        color: #2563eb;
        margin-bottom: 12px;
    }

    .odp-photo-preview {
        display: block;
        width: auto;
        max-width: 100%;
        max-height: 260px;
        margin: 0 auto;
        border-radius: 16px;
        border: 1px solid rgba(148, 163, 184, 0.22);
        box-shadow: 0 12px 28px rgba(15, 23, 42, 0.10);
        background: #fff;
    }

    .odp-stats-card {
        background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
        border: 1px solid rgba(37, 99, 235, 0.10);
        border-radius: 18px;
        padding: 16px;
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.06);
    }

    .odp-info-card {
        background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
        border: 1px solid rgba(37, 99, 235, 0.10);
        border-radius: 18px;
        padding: 16px;
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.06);
    }

    .odp-stat-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
        margin-top: 14px;
    }

    .odp-stat-card {
        background: linear-gradient(180deg, #f8fbff 0%, #eef5ff 100%);
        border: 1px solid rgba(37, 99, 235, 0.08);
        border-radius: 14px;
        padding: 12px 14px;
    }

    .odp-stat-card .label {
        display: block;
        font-size: 0.78rem;
        font-weight: 700;
        color: #64748b;
        margin-bottom: 4px;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .odp-stat-card .value {
        display: block;
        font-size: 1.15rem;
        font-weight: 800;
        color: #0f172a;
    }

    .odp-usage-block {
        margin-top: 16px;
    }

    .odp-photo-section,
    .odp-stats-section {
        margin-top: 18px;
    }

    .odp-photo-panel.centered {
        max-width: 100%;
        margin: 0 auto;
    }

    .odp-photo-figure {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 260px;
        border-radius: 16px;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(239, 246, 255, 0.96));
        border: 1px solid rgba(148, 163, 184, 0.18);
        padding: 16px;
    }

    .odp-summary-card {
        margin-top: 16px;
    }

    .odp-usage-block .progress {
        height: 14px;
        border-radius: 999px;
        background: rgba(226, 232, 240, 0.9);
        overflow: hidden;
    }

    .odp-usage-block .progress-bar {
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 700;
        min-width: 76px;
        display: flex;
        align-items: center;
        justify-content: center;
        white-space: nowrap;
        overflow: visible;
        line-height: 1;
        padding: 0 10px;
    }

    [data-theme="dark"] .odp-photo-panel,
    [data-theme="dark"] .odp-stats-card,
    [data-theme="dark"] .odp-info-card {
        background: linear-gradient(180deg, rgba(30, 41, 59, 0.96), rgba(15, 23, 42, 0.92));
        border-color: rgba(96, 165, 250, 0.22);
        box-shadow: 0 18px 32px rgba(2, 8, 23, 0.24);
    }

    [data-theme="dark"] .odp-photo-label {
        color: #93c5fd;
    }

    [data-theme="dark"] .odp-photo-preview {
        border-color: rgba(148, 163, 184, 0.28);
        background: rgba(15, 23, 42, 0.95);
    }

    [data-theme="dark"] .odp-photo-figure {
        background: linear-gradient(180deg, rgba(30, 41, 59, 0.82), rgba(15, 23, 42, 0.96));
        border-color: rgba(148, 163, 184, 0.20);
    }

    [data-theme="dark"] .odp-stat-card {
        background: linear-gradient(180deg, rgba(30, 41, 59, 0.92), rgba(15, 23, 42, 0.88));
        border-color: rgba(96, 165, 250, 0.12);
    }

    [data-theme="dark"] .odp-stat-card .label {
        color: #94a3b8;
    }

    [data-theme="dark"] .odp-stat-card .value {
        color: #f8fafc;
    }

    @media (max-width: 767.98px) {
        .odp-photo-figure {
            min-height: 220px;
        }
    }
</style>
<div class="modal fade" id="odpDetailsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
