<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manajemen Pengeluaran - Admin Portal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/boxicons@2.0.7/css/boxicons.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Admin Mobile Optimizations -->
    <link href="/css/admin-mobile.css" rel="stylesheet">
    <link href="/css/responsive-admin.css" rel="stylesheet">
    <style>
        .text-purple {
            color: #6f42c1 !important;
        }

        .border-purple {
            border-left: 4px solid #6f42c1 !important;
        }

        .main-content {
            background-color: #f8f9fa;
            min-height: 100vh;
        }

        :root {
            --bg-body: #f5f7fb;
            --bg-card: #ffffff;
            --text-color: #212529;
            --text-muted: #6c757d;
            --border-color: #eef2f6;
            --card-shadow: 0 4px 20px rgba(0,0,0,0.02);
        }

        /* Dark Mode Variables */
        [data-theme="dark"] {
            --bg-body: #1a1a1a;
            --bg-card: #2d2d2d;
            --text-color: #e0e0e0;
            --text-muted: #a0a0a0;
            --border-color: #404040;
            --card-shadow: 0 4px 20px rgba(0,0,0,0.2);
        }

        body {
            background-color: var(--bg-body);
            color: var(--text-color);
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        .card, .modal-content {
            background-color: var(--bg-card) !important;
            color: var(--text-color);
            border-color: var(--border-color) !important;
        }
        
        [data-theme="dark"] .main-content {
            background-color: var(--bg-body);
        }
        
        [data-theme="dark"] .table {
            color: var(--text-color);
            border-color: var(--border-color);
        }
        
        [data-theme="dark"] .table-hover tbody tr:hover {
            color: var(--text-color);
            background-color: rgba(255,255,255,0.05);
        }

        [data-theme="dark"] .form-control, 
        [data-theme="dark"] .form-select {
            background-color: #2d2d2d;
            border-color: #404040;
            color: #e0e0e0;
        }
        
        [data-theme="dark"] .text-muted {
            color: #a0a0a0 !important;
        }

        [data-theme="dark"] .nav-tabs .nav-link {
             color: var(--text-muted);
        }
        
        [data-theme="dark"] .nav-tabs .nav-link.active {
             background-color: var(--bg-body);
             border-color: var(--border-color) var(--border-color) var(--bg-body);
             color: var(--text-color);
        }

        .billing-tabs-wrap {
            margin-bottom: 1.5rem;
            padding: 0.55rem 0.75rem;
            border: 1px solid rgba(148, 163, 184, 0.18);
            border-radius: 20px;
            background: linear-gradient(145deg, rgba(255,255,255,0.88), rgba(244,247,255,0.82));
            backdrop-filter: blur(16px);
            box-shadow: 0 14px 34px rgba(37, 99, 235, 0.08);
        }

        [data-theme="dark"] .billing-tabs-wrap {
            background: linear-gradient(145deg, rgba(15,23,42,0.88), rgba(17,24,39,0.9));
            border-color: rgba(148, 163, 184, 0.16);
            box-shadow: 0 18px 36px rgba(2, 8, 23, 0.32);
        }

        .billing-tabs.nav-tabs {
            border-bottom: 0;
            gap: 0.5rem;
            align-items: center;
        }

        .billing-tabs.nav-tabs .nav-item {
            flex: 0 0 auto;
            display: block;
        }

        .billing-tabs.nav-tabs .nav-link {
            position: relative;
            border: 0;
            border-radius: 999px;
            padding: 0.9rem 1rem 1rem;
            color: var(--text-muted);
            font-weight: 700;
            width: auto;
            display: inline-flex;
            align-items: center;
            justify-content: flex-start;
            gap: 0.4rem;
            text-align: left;
            transform: translateY(2px);
        }

        .billing-tabs.nav-tabs .nav-link.active,
        .billing-tabs.nav-tabs .show > .nav-link {
            background: linear-gradient(135deg, #2563eb, #4f46e5) !important;
            color: #fff !important;
            box-shadow: 0 10px 24px rgba(37, 99, 235, 0.18);
            transform: translateY(0);
        }

        .billing-tabs.nav-tabs .nav-link.active::after,
        .billing-tabs.nav-tabs .show > .nav-link::after {
            content: "";
            position: absolute;
            left: 50%;
            bottom: 6px;
            transform: translateX(-50%);
            width: 34px;
            height: 4px;
            border-radius: 999px;
            background: rgba(255,255,255,0.92);
        }

        [data-theme="dark"] .billing-tabs.nav-tabs .nav-link {
            color: #cbd5e1 !important;
        }

        [data-theme="dark"] .billing-tabs.nav-tabs .nav-link.active,
        [data-theme="dark"] .billing-tabs.nav-tabs .show > .nav-link {
            background: linear-gradient(135deg, #2563eb, #4f46e5) !important;
            color: #ffffff !important;
        }
    </style>
    <script>
        // Theme Toggle Functionality
        function toggleTheme() {
            const body = document.body;
            const currentTheme = body.getAttribute('data-theme');
            const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
            
            body.setAttribute('data-theme', newTheme);
            localStorage.setItem('theme', newTheme);
            
            updateThemeButton(newTheme);
        }

        function updateThemeButton(theme) {
            const icon = document.getElementById('themeIcon');
            const text = document.getElementById('themeText');
            const btn = document.getElementById('themeToggle');
            
            if (!icon || !text || !btn) return;

            if (theme === 'dark') {
                icon.className = 'bi bi-moon-stars-fill text-white me-1';
                text.textContent = 'Dark';
                btn.classList.remove('btn-white');
                btn.classList.add('btn-dark');
                // Apply dark mode styles dynamically
                document.documentElement.style.setProperty('--bg-body', '#1a1a1a');
                document.documentElement.style.setProperty('--bg-card', '#2d2d2d');
                document.documentElement.style.setProperty('--text-color', '#ffffff');
                document.documentElement.style.setProperty('--text-muted', '#a0a0a0');
            } else {
                icon.className = 'bi bi-sun-fill text-warning me-1';
                text.textContent = 'Light';
                btn.classList.remove('btn-dark');
                btn.classList.add('btn-white');
                // Apply light mode styles dynamically
                document.documentElement.style.setProperty('--bg-body', '#f5f7fb');
                document.documentElement.style.setProperty('--bg-card', '#ffffff');
                document.documentElement.style.setProperty('--text-color', '#212529');
                document.documentElement.style.setProperty('--text-muted', '#6c757d');
            }
        }

        // Initialize Theme
        document.addEventListener('DOMContentLoaded', () => {
            const savedTheme = localStorage.getItem('theme') || 'light';
            document.body.setAttribute('data-theme', savedTheme);
            updateThemeButton(savedTheme);
        });
    </script>
</head>

<body>
    <div class="container-fluid">
        <div class="row">
            <%- include('../../partials/billing-responsive-sidebar', { page: 'payments' }) %>
                <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 main-content">
                    <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3">
                        <h3 class="h3 mb-0">Pembayaran & Keuangan</h3>
                        <button class="btn btn-white shadow-sm border rounded-pill px-3" id="themeToggle" onclick="toggleTheme()">
                            <i class="bi bi-sun-fill text-warning me-1" id="themeIcon"></i> <span class="small fw-bold" id="themeText">Light</span>
                        </button>
                    </div>

                    <!-- Tab Navigation -->
                    <div class="billing-tabs-wrap mb-4">
                    <ul class="nav nav-tabs billing-tabs">
                        <li class="nav-item">
                            <a class="nav-link <%= typeof page !== 'undefined' && page === 'payments' ? 'active' : '' %>"
                                href="/admin/billing/payments">
                                <i class="bi bi-credit-card"></i> Transaksi Kolektor
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= typeof page !== 'undefined' && page === 'all-payments' ? 'active' : '' %>"
                                href="/admin/billing/all-payments">
                                <i class="bi bi-list-ul"></i> Riwayat Pembayaran
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= typeof page !== 'undefined' && page === 'financial-report' ? 'active' : '' %>"
                                href="/admin/billing/financial-report">
                                <i class="bi bi-line-chart"></i> Laporan Keuangan
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= typeof page !== 'undefined' && page === 'reports' ? 'active' : '' %>"
                                href="/admin/billing/reports">
                                <i class="bi bi-analytics"></i> Laporan Analisis
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= typeof page !== 'undefined' && page === 'expenses' ? 'active' : '' %>"
                                href="/admin/billing/expenses">
                                <i class="bi bi-money-withdraw"></i> Manajemen Pengeluaran
                            </a>
                        </li>
                    </ul>
                    </div>

                    <div
                        class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                        <h1 class="h2"><i class="bx bx-money-withdraw"></i> Manajemen Pengeluaran</h1>
                        <div>
                            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addExpenseModal">
                                <i class="bx bx-plus"></i> Tambah Pengeluaran
                            </button>
                        </div>
                    </div>

                    <!-- Filter Section -->
                    <div class="card mb-4">
                        <div class="card-body">
                            <form method="GET" class="row g-3 align-items-end">
                                <div class="col-md-3">
                                    <label class="form-label">Tanggal Mulai</label>
                                    <input type="date" class="form-control" name="start_date" value="<%= startDate %>">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Tanggal Selesai</label>
                                    <input type="date" class="form-control" name="end_date" value="<%= endDate %>">
                                </div>
                                <div class="col-md-3">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="bx bx-search"></i> Filter
                                    </button>
                                    <a href="/admin/billing/expenses" class="btn btn-outline-secondary ms-2">
                                        <i class="bx bx-refresh"></i> Reset
                                    </a>
                                    <button type="button" class="btn btn-outline-success ms-2" onclick="exportToCSV()">
                                        <i class="bx bx-download"></i> Export CSV
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Summary Cards -->
                    <div class="row mb-4">
                        <div class="col-md-3">
                            <div class="card border-danger">
                                <div class="card-body">
                                    <div class="d-flex align-items-center">
                                        <div class="me-3">
                                            <i class="bx bx-trending-down text-danger" style="font-size: 2rem;"></i>
                                        </div>
                                        <div>
                                            <div class="h4 text-danger">
                                                Rp <%= (expenses && expenses.length> 0) ? expenses.reduce((sum, exp) =>
                                                    sum + (exp.amount || 0), 0).toLocaleString('id-ID') : '0' %>
                                            </div>
                                            <div class="text-muted">Total Pengeluaran</div>
                                            <small class="text-muted">
                                                <%= (expenses && expenses.length> 0) ? expenses.length : 0 %> transaksi
                                            </small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-warning">
                                <div class="card-body">
                                    <div class="d-flex align-items-center">
                                        <div class="me-3">
                                            <i class="bx bx-category text-warning" style="font-size: 2rem;"></i>
                                        </div>
                                        <div>
                                            <div class="h4 text-warning">
                                                <%= (expenses && expenses.length> 0) ? [...new Set(expenses.map(exp =>
                                                    exp.category))].length : 0 %>
                                            </div>
                                            <div class="text-muted">Kategori Aktif</div>
                                            <small class="text-muted">Berbagai jenis pengeluaran</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-info">
                                <div class="card-body">
                                    <div class="d-flex align-items-center">
                                        <div class="me-3">
                                            <i class="bx bx-calendar text-info" style="font-size: 2rem;"></i>
                                        </div>
                                        <div>
                                            <div class="h4 text-info">
                                                <%= (expenses && expenses.length> 0) ? Math.round(expenses.reduce((sum,
                                                    exp) => sum + (exp.amount || 0), 0) / expenses.length) : 0 %>
                                            </div>
                                            <div class="text-muted">Rata-rata per Transaksi</div>
                                            <small class="text-muted">Dalam Rupiah</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card border-purple">
                                <div class="card-body">
                                    <div class="d-flex align-items-center">
                                        <div class="me-3">
                                            <i class="bx bx-user-check text-purple" style="font-size: 2rem;"></i>
                                        </div>
                                        <div>
                                            <div class="h4 text-purple" id="commissionTotal">
                                                Rp 0
                                            </div>
                                            <div class="text-muted">Komisi Kolektor</div>
                                            <small class="text-muted">Biaya operasional</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Expenses Table -->
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title mb-0">Daftar Pengeluaran</h5>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Tanggal</th>
                                            <th>Deskripsi</th>
                                            <th>Kategori</th>
                                            <th>Jumlah</th>
                                            <th>Metode Pembayaran</th>
                                            <th>Catatan</th>
                                            <th>Aksi</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (expenses && expenses.length> 0) { %>
                                            <% expenses.forEach(function(expense) { %>
                                                <tr data-id="<%= expense.id %>">
                                                    <td>
                                                        <%= new Date(expense.expense_date).toLocaleDateString('id-ID')
                                                            %>
                                                    </td>
                                                    <td>
                                                        <%= expense.description %>
                                                    </td>
                                                    <td><span class="badge bg-info">
                                                            <%= expense.category %>
                                                        </span></td>
                                                    <td class="text-danger">Rp <%= (expense.amount ||
                                                            0).toLocaleString('id-ID') %>
                                                    </td>
                                                    <td>
                                                        <%= expense.payment_method || '-' %>
                                                    </td>
                                                    <td>
                                                        <%= expense.notes || '-' %>
                                                    </td>
                                                    <td>
                                                        <button class="btn btn-sm btn-warning"
                                                            onclick="editExpense('<%= expense.id %>')">Edit</button>
                                                        <button class="btn btn-sm btn-danger"
                                                            onclick="deleteExpense('<%= expense.id %>')">Hapus</button>
                                                    </td>
                                                </tr>
                                                <% }); %>
                                                    <% } else { %>
                                                        <tr>
                                                            <td colspan="7" class="text-center text-muted">
                                                                Tidak ada data pengeluaran
                                                            </td>
                                                        </tr>
                                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </main>
    </div>

    <!-- Hidden element to store expenses data for export -->
    <script id="expensesData" type="application/json"><%= JSON.stringify(expenses || []) %></script>

    <!-- Add Expense Modal -->
    <div class="modal fade" id="addExpenseModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Tambah Pengeluaran</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form id="addExpenseForm">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="description" class="form-label">Deskripsi *</label>
                            <input type="text" class="form-control" id="description" name="description" required>
                        </div>
                        <div class="mb-3">
                            <label for="amount" class="form-label">Jumlah *</label>
                            <input type="number" class="form-control" id="amount" name="amount" step="0.01" required>
                        </div>
                        <div class="mb-3">
                            <label for="category" class="form-label">Kategori *</label>
                            <select class="form-select" id="category" name="category" required>
                                <option value="">Pilih Kategori</option>
                                <option value="Operasional">Operasional</option>
                                <option value="Gaji">Gaji</option>
                                <option value="Utilitas">Utilitas</option>
                                <option value="Maintenance">Maintenance</option>
                                <option value="Marketing">Marketing</option>
                                <option value="Lainnya">Lainnya</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="expense_date" class="form-label">Tanggal Pengeluaran *</label>
                            <input type="date" class="form-control" id="expense_date" name="expense_date" required>
                        </div>
                        <div class="mb-3">
                            <label for="payment_method" class="form-label">Metode Pembayaran</label>
                            <select class="form-select" id="payment_method" name="payment_method">
                                <option value="">Pilih Metode</option>
                                <option value="Cash">Cash</option>
                                <option value="Transfer Bank">Transfer Bank</option>
                                <option value="E-Wallet">E-Wallet</option>
                                <option value="Kartu Kredit">Kartu Kredit</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="notes" class="form-label">Catatan</label>
                            <textarea class="form-control" id="notes" name="notes" rows="3"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                        <button type="submit" class="btn btn-primary">Simpan</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Edit Expense Modal -->
    <div class="modal fade" id="editExpenseModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Pengeluaran</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form id="editExpenseForm">
                    <input type="hidden" id="edit_id" name="id">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="edit_description" class="form-label">Deskripsi *</label>
                            <input type="text" class="form-control" id="edit_description" name="description" required>
                        </div>
                        <div class="mb-3">
                            <label for="edit_amount" class="form-label">Jumlah *</label>
                            <input type="number" class="form-control" id="edit_amount" name="amount" step="0.01"
                                required>
                        </div>
                        <div class="mb-3">
                            <label for="edit_category" class="form-label">Kategori *</label>
                            <select class="form-select" id="edit_category" name="category" required>
                                <option value="">Pilih Kategori</option>
                                <option value="Operasional">Operasional</option>
                                <option value="Gaji">Gaji</option>
                                <option value="Utilitas">Utilitas</option>
                                <option value="Maintenance">Maintenance</option>
                                <option value="Marketing">Marketing</option>
                                <option value="Lainnya">Lainnya</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="edit_expense_date" class="form-label">Tanggal Pengeluaran *</label>
                            <input type="date" class="form-control" id="edit_expense_date" name="expense_date" required>
                        </div>
                        <div class="mb-3">
                            <label for="edit_payment_method" class="form-label">Metode Pembayaran</label>
                            <select class="form-select" id="edit_payment_method" name="payment_method">
                                <option value="">Pilih Metode</option>
                                <option value="Cash">Cash</option>
                                <option value="Transfer Bank">Transfer Bank</option>
                                <option value="E-Wallet">E-Wallet</option>
                                <option value="Kartu Kredit">Kartu Kredit</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="edit_notes" class="form-label">Catatan</label>
                            <textarea class="form-control" id="edit_notes" name="notes" rows="3"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                        <button type="submit" class="btn btn-primary">Update</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Set default date to today
        document.getElementById('expense_date').value = new Date().toISOString().split('T')[0];

        // Load commission data
        async function loadCommissionData() {
            try {
                const startDate = document.querySelector('input[name="start_date"]').value;
                const endDate = document.querySelector('input[name="end_date"]').value;

                let url = '/admin/billing/api/commission-stats';
                if (startDate && endDate) {
                    url += `?start_date=${startDate}&end_date=${endDate}`;
                }

                const response = await fetch(url);
                const result = await response.json();

                if (result.success) {
                    const commissionTotal = result.data.totalCommissionExpenses || 0;
                    document.getElementById('commissionTotal').textContent =
                        'Rp ' + commissionTotal.toLocaleString('id-ID');
                }
            } catch (error) {
                console.error('Error loading commission data:', error);
            }
        }

        // Load commission data on page load
        loadCommissionData();

        // Export to CSV function
        function exportToCSV() {
            const expensesDataElement = document.getElementById('expensesData');
            if (!expensesDataElement) {
                alert('Tidak ada data untuk di-export');
                return;
            }

            const expenses = JSON.parse(expensesDataElement.textContent);
            const csvHeaders = ['Tanggal', 'Deskripsi', 'Kategori', 'Jumlah', 'Metode Pembayaran', 'Catatan'];

            const csvRows = [csvHeaders.join(',')];

            expenses.forEach(expense => {
                const row = [
                    `"${new Date(expense.expense_date).toLocaleDateString('id-ID')}"`,
                    `"${expense.description.replace(/"/g, '""')}"`,
                    `"${expense.category}"`,
                    `"${expense.amount}"`,
                    `"${expense.payment_method || ''}"`,
                    `"${(expense.notes || '').replace(/"/g, '""')}"`
                ];
                csvRows.push(row.join(','));
            });

            const csvContent = csvRows.join('\n');
            const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `pengeluaran-${new Date().toISOString().split('T')[0]}.csv`;
            a.click();
            URL.revokeObjectURL(url);
        }

        // Add expense form submission
        document.getElementById('addExpenseForm').addEventListener('submit', async function (e) {
            e.preventDefault();
            const formData = new FormData(this);
            const data = Object.fromEntries(formData.entries());

            try {
                const response = await fetch('/admin/billing/api/expenses', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await response.json();
                if (result.success) {
                    alert(result.message);
                    document.getElementById('addExpenseModal').querySelector('.btn-close').click();
                    document.getElementById('addExpenseForm').reset();
                    setTimeout(() => window.location.reload(), 1000);
                } else {
                    alert(result.message);
                }
            } catch (error) {
                alert('Terjadi kesalahan saat menyimpan data');
            }
        });

        // Edit expense
        function editExpense(id) {
            const row = document.querySelector(`tr[data-id="${id}"]`);
            const cells = row.cells;

            document.getElementById('edit_id').value = id;
            document.getElementById('edit_description').value = cells[1].textContent;
            document.getElementById('edit_amount').value = cells[3].textContent.replace('Rp ', '').replace(/\./g, '');
            document.getElementById('edit_category').value = cells[2].querySelector('.badge').textContent;
            document.getElementById('edit_expense_date').value = cells[0].textContent.split('/').reverse().join('-');
            document.getElementById('edit_payment_method').value = cells[4].textContent === '-' ? '' : cells[4].textContent;
            document.getElementById('edit_notes').value = cells[5].textContent === '-' ? '' : cells[5].textContent;

            new bootstrap.Modal(document.getElementById('editExpenseModal')).show();
        }

        // Edit expense form submission
        document.getElementById('editExpenseForm').addEventListener('submit', async function (e) {
            e.preventDefault();
            const formData = new FormData(this);
            const data = Object.fromEntries(formData.entries());
            const id = data.id;
            delete data.id;

            try {
                const response = await fetch(`/admin/billing/api/expenses/${id}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await response.json();
                if (result.success) {
                    alert(result.message);
                    document.getElementById('editExpenseModal').querySelector('.btn-close').click();
                    setTimeout(() => window.location.reload(), 1000);
                } else {
                    alert(result.message);
                }
            } catch (error) {
                alert('Terjadi kesalahan saat mengupdate data');
            }
        });

        // Delete expense
        async function deleteExpense(id) {
            if (!confirm('Apakah Anda yakin ingin menghapus pengeluaran ini?')) return;

            try {
                const response = await fetch(`/admin/billing/api/expenses/${id}`, {
                    method: 'DELETE'
                });

                const result = await response.json();
                if (result.success) {
                    alert(result.message);
                    setTimeout(() => window.location.reload(), 1000);
                } else {
                    alert(result.message);
                }
            } catch (error) {
                alert('Terjadi kesalahan saat menghapus data');
            }
        }
    </script>
    <script>
        (function () {
            const currentPath = window.location.pathname.replace(/\/+$/, '');
            const billingTabLinks = Array.from(document.querySelectorAll('.billing-tabs .nav-link'));
            let bestMatch = null;

            billingTabLinks.forEach((link) => {
                const linkPath = new URL(link.href, window.location.origin).pathname.replace(/\/+$/, '');
                const isMatch = currentPath === linkPath || currentPath.startsWith(linkPath + '/');

                if (isMatch && (!bestMatch || linkPath.length > bestMatch.path.length)) {
                    bestMatch = { link, path: linkPath };
                }
            });

            if (bestMatch) {
                billingTabLinks.forEach((link) => link.classList.remove('active'));
                bestMatch.link.classList.add('active');
            }
        })();
    </script>

