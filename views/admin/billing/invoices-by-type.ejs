<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoice per Tipe - Admin Billing</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/boxicons@2.0.7/css/boxicons.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/admin-mobile.css" rel="stylesheet">
    <link href="/css/responsive-admin.css" rel="stylesheet">
    <script>
        const theme = localStorage.getItem('theme') || 'light';
        document.documentElement.setAttribute('data-theme', theme);
    </script>
    <style>
        :root {
            --bg-card: #ffffff;
            --text-color: #212529;
            --text-muted: #6c757d;
            --border-color: #eef2f6;
        }

        [data-theme="dark"] {
            --bg-card: #2d2d2d;
            --text-color: #e0e0e0;
            --text-muted: #a0a0a0;
            --border-color: #404040;
        }

        body {
            background:
                radial-gradient(circle at top left, rgba(59, 130, 246, 0.12), transparent 24%),
                radial-gradient(circle at 85% 15%, rgba(45, 212, 191, 0.12), transparent 22%),
                linear-gradient(180deg, #f7faff 0%, #eef4ff 44%, #f8fbff 100%);
            color: var(--text-color);
        }

        [data-theme="dark"] body {
            background:
                radial-gradient(circle at top left, rgba(59, 130, 246, 0.12), transparent 24%),
                radial-gradient(circle at 85% 15%, rgba(20, 184, 166, 0.12), transparent 24%),
                linear-gradient(180deg, #081120 0%, #0b1324 44%, #0a1428 100%);
        }

        .main-content {
            position: relative;
            z-index: 1;
        }

        .billing-toolbar,
        .billing-panel,
        .billing-tabs-wrap {
            position: relative;
            overflow: hidden;
            border: 1px solid rgba(148, 163, 184, 0.18);
            border-radius: 24px;
            background: linear-gradient(145deg, rgba(255,255,255,0.88), rgba(244,247,255,0.82));
            backdrop-filter: blur(16px);
            box-shadow: 0 18px 44px rgba(37, 99, 235, 0.08);
        }

        .billing-toolbar,
        .billing-panel {
            padding: 16px 20px;
            margin-bottom: 1.5rem;
        }

        .theme-icon-btn {
            width: 46px;
            height: 46px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            padding: 0;
            flex: 0 0 auto;
        }

        .billing-tabs-wrap {
            padding: 0.55rem 0.75rem;
            margin-bottom: 1.5rem;
        }

        .invoice-page-toolbar {
            margin-top: 1rem;
            margin-bottom: 1rem;
        }

        .invoice-page-tabs {
            margin-bottom: 1.25rem !important;
        }

        [data-theme="dark"] .billing-toolbar,
        [data-theme="dark"] .billing-panel,
        [data-theme="dark"] .billing-tabs-wrap {
            background: linear-gradient(145deg, rgba(15,23,42,0.88), rgba(17,24,39,0.9));
            border-color: rgba(148, 163, 184, 0.16);
            box-shadow: 0 20px 42px rgba(2, 8, 23, 0.32);
        }

        .billing-tabs.nav-tabs,
        .type-tabs.nav-tabs {
            border-bottom: 0;
            gap: 1rem;
            padding: 0 0.35rem;
        }

        .billing-tabs .nav-link,
        .type-tabs .nav-link {
            border: 0;
            border-bottom: 3px solid transparent;
            border-radius: 0;
            background: transparent !important;
            color: var(--text-muted);
            font-weight: 700;
            padding: 0.85rem 0.1rem 0.7rem;
            box-shadow: none !important;
        }

        .billing-tabs .nav-link.active,
        .type-tabs .nav-link.active {
            color: #2563eb !important;
            border-bottom-color: #2563eb;
        }

        .billing-tabs .nav-link:hover,
        .type-tabs .nav-link:hover {
            color: #2563eb !important;
        }

        .invoice-stats-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .invoice-stat-card {
            position: relative;
            overflow: hidden;
            border-radius: 22px;
            padding: 1.25rem 1.35rem;
            color: #fff;
            box-shadow: 0 16px 34px rgba(37, 99, 235, 0.14);
            min-height: 118px;
        }

        .invoice-stat-card::after {
            content: "";
            position: absolute;
            right: -18px;
            bottom: -24px;
            width: 128px;
            height: 128px;
            border-radius: 999px;
            background: rgba(255,255,255,0.14);
        }

        .invoice-stat-card .label {
            position: relative;
            z-index: 1;
            font-size: 0.78rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            opacity: 0.95;
        }

        .invoice-stat-card .value {
            position: relative;
            z-index: 1;
            font-size: 2rem;
            font-weight: 800;
            line-height: 1.1;
            margin-top: 0.4rem;
        }

        .invoice-stat-card .subtext {
            position: relative;
            z-index: 1;
            font-size: 0.84rem;
            opacity: 0.9;
            margin-top: 0.35rem;
        }

        .invoice-stat-card.total-card { background: linear-gradient(135deg, #2563eb, #4f46e5); }
        .invoice-stat-card.paid-card { background: linear-gradient(135deg, #10b981, #06b6d4); }
        .invoice-stat-card.unpaid-card { background: linear-gradient(135deg, #ef4444, #f97316); }
        .invoice-stat-card.revenue-card { background: linear-gradient(135deg, #f59e0b, #fb7185); }

        .invoice-type-chip {
            display: inline-flex;
            align-items: center;
            border-radius: 999px;
            padding: 0.3rem 0.6rem;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.03em;
        }

        .invoice-type-monthly { background: rgba(37, 99, 235, 0.14); color: #2563eb; }
        .invoice-type-voucher { background: rgba(139, 92, 246, 0.15); color: #7c3aed; }
        .invoice-type-manual { background: rgba(245, 158, 11, 0.16); color: #d97706; }

        .table,
        .table td,
        .table th,
        .card,
        .card-body,
        .card-header,
        .form-label,
        .form-select,
        .form-control,
        .text-dark,
        .text-body {
            color: var(--text-color) !important;
        }

        .card,
        .modal-content,
        .table-responsive,
        .form-select,
        .form-control {
            background-color: var(--bg-card) !important;
            border-color: var(--border-color) !important;
        }

        .text-muted,
        small.text-muted,
        .table small,
        .card-subtitle {
            color: var(--text-muted) !important;
        }

        .btn-close {
            filter: none;
        }

        [data-theme="dark"] .btn-close {
            filter: invert(1) grayscale(100%);
        }

        [data-theme="dark"] .invoice-type-monthly { color: #93c5fd; }
        [data-theme="dark"] .invoice-type-voucher { color: #c4b5fd; }
        [data-theme="dark"] .invoice-type-manual { color: #fdba74; }

        [data-theme="dark"] .billing-toolbar h1,
        [data-theme="dark"] .billing-toolbar .text-muted,
        [data-theme="dark"] .billing-panel h5,
        [data-theme="dark"] .billing-tabs .nav-link,
        [data-theme="dark"] .type-tabs .nav-link,
        [data-theme="dark"] .table thead th,
        [data-theme="dark"] .table tbody td,
        [data-theme="dark"] .table tbody td small,
        [data-theme="dark"] .form-label,
        [data-theme="dark"] .badge,
        [data-theme="dark"] .btn-outline-primary,
        [data-theme="dark"] .btn-outline-secondary {
            color: #e5edf8 !important;
        }

        [data-theme="dark"] .table {
            --bs-table-bg: transparent;
            --bs-table-color: #e5edf8;
            --bs-table-border-color: rgba(148, 163, 184, 0.18);
            --bs-table-hover-color: #f8fbff;
            --bs-table-hover-bg: rgba(59, 130, 246, 0.12);
        }

        [data-theme="dark"] .table thead th {
            background: rgba(15, 23, 42, 0.9) !important;
            color: #f8fbff !important;
            border-bottom-color: rgba(148, 163, 184, 0.2) !important;
        }

        [data-theme="dark"] .table tbody tr {
            background: rgba(15, 23, 42, 0.68) !important;
        }

        [data-theme="dark"] .table tbody td {
            border-color: rgba(148, 163, 184, 0.16) !important;
        }

        [data-theme="dark"] .form-select {
            background-color: rgba(15, 23, 42, 0.9) !important;
            color: #f8fbff !important;
            border-color: rgba(148, 163, 184, 0.22) !important;
        }

        [data-theme="dark"] .form-select:focus {
            border-color: rgba(59, 130, 246, 0.5) !important;
            box-shadow: 0 0 0 0.2rem rgba(37, 99, 235, 0.16) !important;
        }

        [data-theme="dark"] .billing-panel,
        [data-theme="dark"] .table-responsive {
            background: linear-gradient(145deg, rgba(15,23,42,0.86), rgba(17,24,39,0.9)) !important;
        }

        @media (max-width: 991.98px) {
            .invoice-stats-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (max-width: 575.98px) {
            .invoice-stats-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <%- include('../../partials/billing-responsive-sidebar', { page: 'invoices' }) %>

        <main class="main-content px-md-4">
            <div class="billing-toolbar invoice-page-toolbar d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center gap-3">
                <h3 class="h3 mb-0">Invoice</h3>
                <button class="btn btn-white shadow-sm border theme-icon-btn" id="themeToggle" onclick="toggleTheme()" aria-label="Toggle theme">
                    <i class="bi bi-sun-fill text-warning" id="themeIcon"></i>
                </button>
            </div>

            <div class="billing-tabs-wrap invoice-page-tabs">
                <ul class="nav nav-tabs billing-tabs">
                    <li class="nav-item">
                        <a class="nav-link <%= typeof subPage !== 'undefined' && subPage === 'invoices' ? 'active' : '' %>" href="/admin/billing/invoices">
                            <i class="bi bi-receipt me-1"></i> Buat Invoice
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= typeof subPage !== 'undefined' && subPage === 'auto-invoice' ? 'active' : '' %>" href="/admin/billing/auto-invoice">
                            <i class="bi bi-calendar-check me-1"></i> Auto Invoice
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= typeof subPage !== 'undefined' && subPage === 'invoices-by-type' ? 'active' : '' %>" href="/admin/billing/invoices-by-type">
                            <i class="bi bi-list-ul me-1"></i> Invoice per Tipe
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= typeof subPage !== 'undefined' && subPage === 'invoice-list' ? 'active' : '' %>" href="/admin/billing/invoice-list">
                            <i class="bi bi-collection me-1"></i> Semua Invoice
                        </a>
                    </li>
                </ul>
            </div>

            <div class="billing-toolbar d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <h1 class="h3 mb-1"><i class="bx bx-receipt me-2"></i>Invoice per Tipe</h1>
                    <div class="text-muted">Pilih bulan untuk melihat jumlah tagihan dan pendapatan tiap jenis invoice dengan lebih akurat.</div>
                </div>
                <form method="GET" action="/admin/billing/invoices-by-type" class="d-flex align-items-center gap-2 flex-wrap">
                    <label for="monthFilter" class="form-label mb-0 fw-semibold">Filter Periode</label>
                    <select name="month" id="monthFilter" class="form-select rounded-pill" onchange="this.form.submit()">
                        <% monthOptions.forEach(function(month) { %>
                            <option value="<%= month.value %>" <%= selectedMonth === month.value ? 'selected' : '' %>><%= month.label %></option>
                        <% }) %>
                    </select>
                    <select name="year" id="yearFilter" class="form-select rounded-pill" onchange="this.form.submit()">
                        <% availableYears.forEach(function(year) { %>
                            <option value="<%= year %>" <%= selectedYear === year ? 'selected' : '' %>><%= year %></option>
                        <% }) %>
                    </select>
                </form>
            </div>

            <div class="billing-tabs-wrap">
                <ul class="nav nav-tabs type-tabs" id="invoiceTypeTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="monthly-tab" data-bs-toggle="tab" data-bs-target="#monthly" type="button" role="tab">
                            <i class="bx bx-calendar me-1"></i> Bulanan (<%= monthlyStats.total_invoices || 0 %>)
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="voucher-tab" data-bs-toggle="tab" data-bs-target="#voucher" type="button" role="tab">
                            <i class="bx bx-ticket me-1"></i> Voucher (<%= voucherStats.total_invoices || 0 %>)
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="manual-tab" data-bs-toggle="tab" data-bs-target="#manual" type="button" role="tab">
                            <i class="bx bx-edit me-1"></i> Manual (<%= manualStats.total_invoices || 0 %>)
                        </button>
                    </li>
                </ul>
            </div>

            <div class="tab-content" id="invoiceTypeTabContent">
                <div class="tab-pane fade show active" id="monthly" role="tabpanel">
                    <div class="invoice-stats-grid">
                        <div class="invoice-stat-card total-card">
                            <div class="label">Total Tagihan</div>
                            <div class="value"><%= monthlyStats.total_invoices || 0 %></div>
                            <div class="subtext">Invoice bulanan pada bulan terpilih</div>
                        </div>
                        <div class="invoice-stat-card paid-card">
                            <div class="label">Lunas</div>
                            <div class="value"><%= monthlyStats.paid_invoices || 0 %></div>
                            <div class="subtext">Tagihan bulanan sudah dibayar</div>
                        </div>
                        <div class="invoice-stat-card unpaid-card">
                            <div class="label">Belum Lunas</div>
                            <div class="value"><%= monthlyStats.unpaid_invoices || 0 %></div>
                            <div class="subtext">Tagihan bulanan masih terbuka</div>
                        </div>
                        <div class="invoice-stat-card revenue-card">
                            <div class="label">Pendapatan</div>
                            <div class="value">Rp <%= (monthlyStats.total_revenue || 0).toLocaleString('id-ID') %></div>
                            <div class="subtext">Pendapatan bulanan di bulan terpilih</div>
                        </div>
                    </div>
                    <div class="billing-panel">
                        <h5 class="mb-3">Tagihan Bulanan</h5>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead>
                                    <tr>
                                        <th>Invoice #</th>
                                        <th>Pelanggan</th>
                                        <th>Paket</th>
                                        <th>Jumlah</th>
                                        <th>Status</th>
                                        <th>Jatuh Tempo</th>
                                        <th>Aksi</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (monthlyInvoices && monthlyInvoices.length > 0) { %>
                                        <% monthlyInvoices.forEach(function(invoice) { %>
                                            <% const normalizedStatus = String(invoice.status || '').trim().toLowerCase(); %>
                                            <tr>
                                                <td>
                                                    <span class="invoice-type-chip invoice-type-monthly">BULANAN</span><br>
                                                    <small class="text-muted"><%= invoice.invoice_number %></small>
                                                </td>
                                                <td>
                                                    <strong><%= invoice.customer_name %></strong><br>
                                                    <small class="text-muted"><%= invoice.customer_phone %></small>
                                                </td>
                                                <td><%= invoice.package_name || '-' %></td>
                                                <td>Rp <%= (invoice.amount || 0).toLocaleString('id-ID') %></td>
                                                <td>
                                                    <% if (normalizedStatus === 'paid') { %>
                                                        <span class="badge bg-success rounded-pill px-3">Lunas</span>
                                                    <% } else { %>
                                                        <span class="badge bg-warning text-dark rounded-pill px-3"><%= normalizedStatus === 'overdue' ? 'Terlambat' : 'Belum Lunas' %></span>
                                                    <% } %>
                                                </td>
                                                <td><%= invoice.due_date ? new Date(invoice.due_date).toLocaleDateString('id-ID') : '-' %></td>
                                                <td>
                                                    <a href="/admin/billing/invoices/<%= invoice.id %>" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                                        <i class="bx bx-show me-1"></i> Lihat
                                                    </a>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="7" class="text-center text-muted py-4">Tidak ada data pada bulan ini</td>
                                        </tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="voucher" role="tabpanel">
                    <div class="invoice-stats-grid">
                        <div class="invoice-stat-card total-card">
                            <div class="label">Total Voucher</div>
                            <div class="value"><%= voucherStats.total_invoices || 0 %></div>
                            <div class="subtext">Invoice voucher pada bulan terpilih</div>
                        </div>
                        <div class="invoice-stat-card paid-card">
                            <div class="label">Lunas</div>
                            <div class="value"><%= voucherStats.paid_invoices || 0 %></div>
                            <div class="subtext">Voucher yang sudah dibayar</div>
                        </div>
                        <div class="invoice-stat-card unpaid-card">
                            <div class="label">Belum Lunas</div>
                            <div class="value"><%= voucherStats.unpaid_invoices || 0 %></div>
                            <div class="subtext">Voucher yang masih terbuka</div>
                        </div>
                        <div class="invoice-stat-card revenue-card">
                            <div class="label">Pendapatan</div>
                            <div class="value">Rp <%= (voucherStats.total_revenue || 0).toLocaleString('id-ID') %></div>
                            <div class="subtext">Pendapatan voucher di bulan terpilih</div>
                        </div>
                    </div>
                    <div class="billing-panel">
                        <h5 class="mb-3">Tagihan Voucher</h5>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead>
                                    <tr>
                                        <th>Invoice #</th>
                                        <th>Pelanggan</th>
                                        <th>Paket Voucher</th>
                                        <th>Jumlah</th>
                                        <th>Status</th>
                                        <th>Jatuh Tempo</th>
                                        <th>Aksi</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (voucherInvoices && voucherInvoices.length > 0) { %>
                                        <% voucherInvoices.forEach(function(invoice) { %>
                                            <% const normalizedStatus = String(invoice.status || '').trim().toLowerCase(); %>
                                            <tr>
                                                <td>
                                                    <span class="invoice-type-chip invoice-type-voucher">VOUCHER</span><br>
                                                    <small class="text-muted"><%= invoice.invoice_number %></small>
                                                </td>
                                                <td>
                                                    <strong><%= invoice.customer_name %></strong><br>
                                                    <small class="text-muted"><%= invoice.customer_phone %></small>
                                                </td>
                                                <td><%= invoice.package_name || '-' %></td>
                                                <td>Rp <%= (invoice.amount || 0).toLocaleString('id-ID') %></td>
                                                <td>
                                                    <% if (normalizedStatus === 'paid') { %>
                                                        <span class="badge bg-success rounded-pill px-3">Lunas</span>
                                                    <% } else { %>
                                                        <span class="badge bg-warning text-dark rounded-pill px-3"><%= normalizedStatus === 'overdue' ? 'Terlambat' : 'Belum Lunas' %></span>
                                                    <% } %>
                                                </td>
                                                <td><%= invoice.due_date ? new Date(invoice.due_date).toLocaleDateString('id-ID') : '-' %></td>
                                                <td>
                                                    <a href="/admin/billing/invoices/<%= invoice.id %>" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                                        <i class="bx bx-show me-1"></i> Lihat
                                                    </a>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="7" class="text-center text-muted py-4">Tidak ada data pada bulan ini</td>
                                        </tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="manual" role="tabpanel">
                    <div class="invoice-stats-grid">
                        <div class="invoice-stat-card total-card">
                            <div class="label">Total Manual</div>
                            <div class="value"><%= manualStats.total_invoices || 0 %></div>
                            <div class="subtext">Invoice manual pada bulan terpilih</div>
                        </div>
                        <div class="invoice-stat-card paid-card">
                            <div class="label">Lunas</div>
                            <div class="value"><%= manualStats.paid_invoices || 0 %></div>
                            <div class="subtext">Invoice manual yang sudah dibayar</div>
                        </div>
                        <div class="invoice-stat-card unpaid-card">
                            <div class="label">Belum Lunas</div>
                            <div class="value"><%= manualStats.unpaid_invoices || 0 %></div>
                            <div class="subtext">Invoice manual yang masih terbuka</div>
                        </div>
                        <div class="invoice-stat-card revenue-card">
                            <div class="label">Pendapatan</div>
                            <div class="value">Rp <%= (manualStats.total_revenue || 0).toLocaleString('id-ID') %></div>
                            <div class="subtext">Pendapatan manual di bulan terpilih</div>
                        </div>
                    </div>
                    <div class="billing-panel">
                        <h5 class="mb-3">Tagihan Manual</h5>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead>
                                    <tr>
                                        <th>Invoice #</th>
                                        <th>Pelanggan</th>
                                        <th>Paket/Deskripsi</th>
                                        <th>Jumlah</th>
                                        <th>Status</th>
                                        <th>Jatuh Tempo</th>
                                        <th>Aksi</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (manualInvoices && manualInvoices.length > 0) { %>
                                        <% manualInvoices.forEach(function(invoice) { %>
                                            <% const normalizedStatus = String(invoice.status || '').trim().toLowerCase(); %>
                                            <tr>
                                                <td>
                                                    <span class="invoice-type-chip invoice-type-manual">MANUAL</span><br>
                                                    <small class="text-muted"><%= invoice.invoice_number %></small>
                                                </td>
                                                <td>
                                                    <strong><%= invoice.customer_name %></strong><br>
                                                    <small class="text-muted"><%= invoice.customer_phone %></small>
                                                </td>
                                                <td><%= invoice.package_name || invoice.description || '-' %></td>
                                                <td>Rp <%= (invoice.amount || 0).toLocaleString('id-ID') %></td>
                                                <td>
                                                    <% if (normalizedStatus === 'paid') { %>
                                                        <span class="badge bg-success rounded-pill px-3">Lunas</span>
                                                    <% } else { %>
                                                        <span class="badge bg-warning text-dark rounded-pill px-3"><%= normalizedStatus === 'overdue' ? 'Terlambat' : 'Belum Lunas' %></span>
                                                    <% } %>
                                                </td>
                                                <td><%= invoice.due_date ? new Date(invoice.due_date).toLocaleDateString('id-ID') : '-' %></td>
                                                <td>
                                                    <a href="/admin/billing/invoices/<%= invoice.id %>" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                                        <i class="bx bx-show me-1"></i> Lihat
                                                    </a>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="7" class="text-center text-muted py-4">Tidak ada data pada bulan ini</td>
                                        </tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleTheme() {
            const html = document.documentElement;
            const currentTheme = html.getAttribute('data-theme') || 'light';
            const nextTheme = currentTheme === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', nextTheme);
            localStorage.setItem('theme', nextTheme);
            updateThemeButton();
        }

        function updateThemeButton() {
            const currentTheme = document.documentElement.getAttribute('data-theme') || 'light';
            const icon = document.getElementById('themeIcon');
            if (!icon) return;

            if (currentTheme === 'dark') {
                icon.className = 'bi bi-moon-stars-fill text-light';
            } else {
                icon.className = 'bi bi-sun-fill text-warning';
            }
        }

        document.addEventListener('DOMContentLoaded', updateThemeButton);
    </script>
</body>
</html>
