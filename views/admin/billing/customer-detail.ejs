<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Detail Pelanggan - Admin Portal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/boxicons@2.0.7/css/boxicons.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Admin Mobile Optimizations -->
    <link href="/css/admin-mobile.css" rel="stylesheet">
    <link href="/css/responsive-admin.css" rel="stylesheet">

    <script>
        const theme = localStorage.getItem('theme') || 'light';
        document.documentElement.setAttribute('data-theme', theme);
    </script>

    <style>
        [data-theme="dark"] {
            --bg-color: #1a1c23;
            --text-color: #e2e8f0;
            --card-bg: #24262d;
            --border-color: #4a5568;
            --sidebar-bg: #1a1c23;
            --input-bg: #2d3748;
        }

        [data-theme="dark"] body {
            background-color: var(--bg-color);
            color: var(--text-color);
        }

        [data-theme="dark"] .card {
            background-color: var(--card-bg);
            border-color: var(--border-color);
            color: var(--text-color);
        }

        [data-theme="dark"] .card-header {
            border-bottom-color: var(--border-color);
        }

        [data-theme="dark"] .table {
            color: var(--text-color);
        }

        [data-theme="dark"] .table thead th {
            border-bottom-color: var(--border-color);
            color: var(--text-color);
        }

        [data-theme="dark"] .table td {
            border-bottom-color: var(--border-color);
        }

        [data-theme="dark"] .table-striped > tbody > tr:nth-of-type(odd) > * {
            color: var(--text-color);
            background-color: rgba(255, 255, 255, 0.05);
        }

        [data-theme="dark"] .table-hover > tbody > tr:hover > * {
            color: var(--text-color);
            background-color: rgba(255, 255, 255, 0.1);
        }

        [data-theme="dark"] .modal-content {
            background-color: var(--card-bg);
            border-color: var(--border-color);
            color: var(--text-color);
        }

        [data-theme="dark"] .modal-header,
        [data-theme="dark"] .modal-footer {
            border-color: var(--border-color);
        }

        [data-theme="dark"] .btn-close {
            filter: invert(1) grayscale(100%) brightness(200%);
        }

        [data-theme="dark"] .form-control,
        [data-theme="dark"] .form-select,
        [data-theme="dark"] .input-group-text {
            background-color: var(--input-bg);
            border-color: var(--border-color);
            color: var(--text-color);
        }

        [data-theme="dark"] .breadcrumb-item a {
            color: #63b3ed;
        }

        [data-theme="dark"] .breadcrumb-item.active {
            color: #a0aec0;
        }

        [data-theme="dark"] .breadcrumb-item + .breadcrumb-item::before {
            color: #a0aec0;
        }

        .main-content {
            transition: margin-left 0.3s ease;
            padding-top: 20px !important;
        }

        .photo-card {
            border: 1px solid rgba(148, 163, 184, 0.16);
            border-radius: 20px;
            background: linear-gradient(180deg, rgba(255,255,255,0.92), rgba(248,250,252,0.96));
            padding: 14px;
            box-shadow: 0 16px 36px rgba(15, 23, 42, 0.08);
        }

        .photo-card img {
            width: 100%;
            max-height: 280px;
            object-fit: contain;
            border-radius: 16px;
            background: linear-gradient(180deg, rgba(241,245,249,0.96), rgba(226,232,240,0.92));
            border: 1px solid rgba(148, 163, 184, 0.18);
            padding: 10px;
        }

        .photo-empty {
            min-height: 220px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 16px;
            border: 1px dashed rgba(148, 163, 184, 0.3);
            color: #64748b;
            background: rgba(248, 250, 252, 0.88);
            text-align: center;
            padding: 1rem;
        }

        @media (min-width: 992px) {
            .sidebar.collapsed + .main-content {
                margin-left: 80px;
                width: calc(100% - 80px);
            }
        }

        [data-theme="dark"] .photo-card {
            background: linear-gradient(180deg, rgba(30,41,59,0.94), rgba(17,24,39,0.96));
            border-color: rgba(148, 163, 184, 0.16);
            box-shadow: 0 18px 38px rgba(2, 8, 23, 0.34);
        }

        [data-theme="dark"] .photo-card img {
            background: linear-gradient(180deg, rgba(15,23,42,0.88), rgba(30,41,59,0.94));
            border-color: rgba(148, 163, 184, 0.18);
        }

        [data-theme="dark"] .photo-empty {
            background: rgba(15,23,42,0.78);
            color: #cbd5e1;
            border-color: rgba(148, 163, 184, 0.24);
        }
    </style>
</head>

<body>
    <%- include('../../partials/billing-responsive-sidebar', { page: 'customers' }) %>

    <main class="main-content">
        <div class="container-fluid">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">
                    <i class="bx bx-user"></i> Detail Pelanggan
                </h1>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/admin/billing/customers">Pelanggan</a></li>
                        <li class="breadcrumb-item active" aria-current="page">
                            <%= customer.name %>
                        </li>
                    </ol>
                </nav>
            </div>

            <!-- Customer Info Card -->
            <div class="row">
                <div class="col-lg-6 mb-4">
                    <div class="card h-100">
                        <div class="card-header">
                            <h5 class="card-title mb-0">
                                <i class="bx bx-user-circle"></i> Informasi Pelanggan
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <strong>Username:</strong>
                                <%= customer ? customer.username : 'N/A' %>
                            </div>
                            <div class="mb-3">
                                <strong>Nama:</strong>
                                <%= customer ? customer.name : 'N/A' %>
                            </div>
                            <div class="mb-3">
                                <strong>Telepon:</strong>
                                <%= customer && customer.phone ? customer.phone : '-' %>
                            </div>
                            <div class="mb-3">
                                <strong>Email:</strong>
                                <%= customer && customer.email ? customer.email : '-' %>
                            </div>
                            <div class="mb-3">
                                <strong>Alamat:</strong>
                                <%= customer && customer.address ? customer.address : '-' %>
                            </div>
                            <div class="mb-3">
                                <strong>Status:</strong>
                                <% if (customer && customer.status === 'active') { %>
                                    <span class="badge bg-success">Aktif</span>
                                <% } else if (customer && customer.status === 'inactive') { %>
                                    <span class="badge bg-secondary">Tidak Aktif</span>
                                <% } else if (customer && customer.status === 'suspended') { %>
                                    <span class="badge bg-warning">Ditangguhkan</span>
                                <% } else { %>
                                    <span class="badge bg-secondary">Tidak Diketahui</span>
                                <% } %>
                            </div>
                            <div class="mb-3">
                                <strong>Bergabung:</strong>
                                <%= customer && customer.join_date ? new Date(customer.join_date).toLocaleDateString('id-ID') : 'N/A' %>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-3 mb-4">
                    <div class="card h-100">
                        <div class="card-header">
                            <h5 class="card-title mb-0">
                                <i class="bx bx-user-circle"></i> Foto Profil
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="photo-card">
                                <% if (customer && customer.profile_photo) { %>
                                    <img src="/img/customer-profiles/<%= customer.profile_photo %>" alt="Foto Profil <%= customer.name %>">
                                <% } else { %>
                                    <div class="photo-empty">
                                        Belum ada foto profil
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-3 mb-4">
                    <div class="card h-100">
                        <div class="card-header">
                            <h5 class="card-title mb-0">
                                <i class="bx bx-image-alt"></i> Foto Rumah
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="photo-card">
                                <% if (customer && customer.house_photo) { %>
                                    <img src="/img/customer-houses/<%= customer.house_photo %>" alt="Foto Rumah <%= customer.name %>">
                                <% } else { %>
                                    <div class="photo-empty">
                                        Belum ada foto rumah
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-12 mb-4">
                    <div class="card h-100">
                        <div class="card-header">
                            <h5 class="card-title mb-0">
                                <i class="bx bx-package"></i> Paket Internet
                            </h5>
                        </div>
                        <div class="card-body">
                            <% if (customer && customer.package_name) { %>
                                <div class="mb-3">
                                    <strong>Nama Paket:</strong>
                                    <%= customer.package_name %>
                                </div>
                                <div class="mb-3">
                                    <strong>Kecepatan:</strong>
                                    <%= customer.package_speed %>
                                </div>
                                <div class="mb-3">
                                    <strong>Harga:</strong> Rp <%= customer.package_price ? parseFloat(customer.package_price).toLocaleString('id-ID') : '0' %>
                                </div>
                            <% } else { %>
                                <div class="alert alert-warning">
                                    <i class="bx bx-alert"></i> Pelanggan belum memiliki paket internet
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Invoices Table -->
            <div class="row">
                <div class="col-12 mb-4">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title mb-0">
                                <i class="bx bx-receipt"></i> Riwayat Tagihan
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-centered table-nowrap table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>No. Tagihan</th>
                                            <th>Paket</th>
                                            <th>Jumlah</th>
                                            <th>Status</th>
                                            <th>Jatuh Tempo</th>
                                            <th>Tanggal Dibuat</th>
                                            <th>Aksi</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (invoices && invoices.length > 0) { %>
                                            <% invoices.forEach(function(invoice) { %>
                                                <tr>
                                                    <td>
                                                        <span class="text-body fw-bold">
                                                            <%= invoice ? invoice.invoice_number : 'N/A' %>
                                                        </span>
                                                    </td>
                                                    <td>
                                                        <%= invoice ? invoice.package_name : 'N/A' %>
                                                    </td>
                                                    <td>
                                                        Rp <%= invoice && invoice.amount ? parseFloat(invoice.amount).toLocaleString('id-ID') : '0' %>
                                                    </td>
                                                    <td>
                                                        <% if (invoice && invoice.status === 'paid') { %>
                                                            <span class="badge bg-success">Lunas</span>
                                                        <% } else if (invoice && invoice.status === 'unpaid') { %>
                                                            <% if (invoice.due_date && new Date(invoice.due_date) < new Date()) { %>
                                                                <span class="badge bg-danger">Terlambat</span>
                                                            <% } else { %>
                                                                <span class="badge bg-warning">Belum Lunas</span>
                                                            <% } %>
                                                        <% } else { %>
                                                            <span class="badge bg-secondary">Tidak Diketahui</span>
                                                        <% } %>
                                                    </td>
                                                    <td>
                                                        <% if (invoice && invoice.due_date) { %>
                                                            <% if (new Date(invoice.due_date) < new Date() && invoice.status === 'unpaid') { %>
                                                                <span class="text-danger">
                                                                    <%= new Date(invoice.due_date).toLocaleDateString('id-ID') %>
                                                                </span>
                                                            <% } else { %>
                                                                <%= new Date(invoice.due_date).toLocaleDateString('id-ID') %>
                                                            <% } %>
                                                        <% } else { %>
                                                            N/A
                                                        <% } %>
                                                    </td>
                                                    <td>
                                                        <%= invoice && invoice.created_at ? new Date(invoice.created_at).toLocaleDateString('id-ID') : 'N/A' %>
                                                    </td>
                                                    <td>
                                                        <% if (invoice) { %>
                                                            <div class="btn-group" role="group">
                                                                <button type="button"
                                                                    class="btn btn-sm btn-outline-primary view-invoice-btn"
                                                                    data-id="<%= invoice.id %>"
                                                                    data-bs-toggle="tooltip"
                                                                    data-bs-placement="top"
                                                                    title="Lihat Detail">
                                                                    <i class="bi bi-eye"></i>
                                                                </button>

                                                                <% if (invoice.status === 'unpaid') { %>
                                                                    <button type="button"
                                                                        class="btn btn-sm btn-outline-success mark-paid-btn"
                                                                        data-id="<%= invoice.id %>"
                                                                        data-invoice-number="<%= invoice.invoice_number %>"
                                                                        data-amount="<%= invoice.amount %>"
                                                                        data-bs-toggle="tooltip"
                                                                        data-bs-placement="top"
                                                                        title="Tandai Lunas">
                                                                        <i class="bi bi-cash-coin"></i>
                                                                    </button>
                                                                <% } %>

                                                                <button type="button"
                                                                    class="btn btn-sm btn-outline-info print-invoice-btn"
                                                                    data-id="<%= invoice.id %>"
                                                                    data-bs-toggle="tooltip"
                                                                    data-bs-placement="top"
                                                                    title="Cetak Invoice">
                                                                    <i class="bi bi-printer"></i>
                                                                </button>
                                                            </div>
                                                        <% } else { %>
                                                            <span class="text-muted">N/A</span>
                                                        <% } %>
                                                    </td>
                                                </tr>
                                            <% }); %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="7" class="text-center text-muted">Belum ada tagihan</td>
                                            </tr>
                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Trouble Reports Table -->
            <div class="row mt-4">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header d-flex align-items-center">
                            <h5 class="card-title mb-0">
                                <i class="bi bi-exclamation-triangle me-1"></i> Riwayat Laporan Gangguan
                            </h5>
                            <span class="badge bg-light text-dark ms-2">
                                <%= troubleReports && troubleReports.length ? troubleReports.length : 0 %> laporan
                            </span>
                            <a href="/admin/trouble" class="btn btn-sm btn-outline-primary ms-auto">Kelola Semua</a>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-centered table-nowrap table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>ID</th>
                                            <th>Tanggal</th>
                                            <th>Kategori</th>
                                            <th>Lokasi</th>
                                            <th>Status</th>
                                            <th>Catatan Terakhir</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (typeof troubleReports !== 'undefined' && troubleReports && troubleReports.length > 0) { %>
                                            <% troubleReports.slice().reverse().forEach(function(rep) { %>
                                                <tr>
                                                    <td>#<%= rep.id %></td>
                                                    <td><%= rep.created_at ? new Date(rep.created_at).toLocaleString('id-ID') : '-' %></td>
                                                    <td><%= rep.category || '-' %></td>
                                                    <td><%= rep.location || '-' %></td>
                                                    <td>
                                                        <span class="badge <%= 
                                                            rep.status === 'open' ? 'bg-danger' : 
                                                            rep.status === 'in_progress' ? 'bg-warning text-dark' : 
                                                            rep.status === 'resolved' ? 'bg-success' : 
                                                            'bg-secondary' %>">
                                                            <%= rep.status || '-' %>
                                                        </span>
                                                    </td>
                                                    <td style="max-width: 360px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                                        <%= rep.notes && rep.notes.length ? rep.notes[rep.notes.length - 1] : '-' %>
                                                    </td>
                                                </tr>
                                            <% }); %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="6" class="text-center text-muted">Belum ada laporan gangguan</td>
                                            </tr>
                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Mark as Paid Modal -->
    <div class="modal fade" id="markAsPaidModal" tabindex="-1" aria-labelledby="markAsPaidModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="markAsPaidModalLabel">Tandai Sebagai Lunas</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="markAsPaidForm">
                    <div class="modal-body">
                        <input type="hidden" id="paidInvoiceId" name="invoice_id">
                        <div class="mb-3">
                            <label for="paymentMethod" class="form-label">Metode Pembayaran *</label>
                            <select class="form-select" id="paymentMethod" name="payment_method" required>
                                <option value="">Pilih Metode Pembayaran</option>
                                <option value="cash">Tunai</option>
                                <option value="transfer">Transfer Bank</option>
                                <option value="qris">QRIS</option>
                                <option value="ewallet">E-Wallet</option>
                                <option value="other">Lainnya</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="paymentNotes" class="form-label">Catatan Pembayaran</label>
                            <textarea class="form-control" id="paymentNotes" name="notes" rows="3" placeholder="Catatan pembayaran (opsional)"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                        <button type="submit" class="btn btn-success">Tandai Lunas</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl);
            });

            document.addEventListener('click', function (e) {
                const viewBtn = e.target.closest('.view-invoice-btn');
                if (viewBtn) {
                    const id = viewBtn.getAttribute('data-id');
                    window.open(`/admin/billing/invoices/${id}`, '_blank');
                    return;
                }

                const printBtn = e.target.closest('.print-invoice-btn');
                if (printBtn) {
                    const id = printBtn.getAttribute('data-id');
                    window.open(`/admin/billing/invoices/${id}/print`, '_blank');
                    return;
                }

                const paidBtn = e.target.closest('.mark-paid-btn');
                if (paidBtn) {
                    const id = paidBtn.getAttribute('data-id');
                    const invoiceNumber = paidBtn.getAttribute('data-invoice-number');

                    document.getElementById('paidInvoiceId').value = id;
                    document.getElementById('markAsPaidModalLabel').textContent = `Tandai Sebagai Lunas - ${invoiceNumber}`;

                    const modalEl = document.getElementById('markAsPaidModal');
                    const modal = new bootstrap.Modal(modalEl);
                    modal.show();
                }
            });

            const markAsPaidForm = document.getElementById('markAsPaidForm');
            if (markAsPaidForm) {
                markAsPaidForm.addEventListener('submit', function (e) {
                    e.preventDefault();

                    const formData = new FormData(this);
                    const data = Object.fromEntries(formData);
                    const invoiceId = data.invoice_id;
                    const paymentMethod = data.payment_method;
                    const notes = data.notes;

                    if (!paymentMethod) {
                        alert('Mohon pilih metode pembayaran');
                        return;
                    }

                    const submitBtn = this.querySelector('button[type="submit"]');
                    const originalText = submitBtn.innerHTML;
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = 'Memproses...';

                    fetch(`/admin/billing/api/invoices/${invoiceId}`)
                        .then(response => response.json())
                        .then(invoiceData => {
                            if (!invoiceData.success) {
                                throw new Error('Failed to get invoice data');
                            }

                            const invoiceAmount = parseFloat(invoiceData.invoice.amount);

                            return fetch('/admin/billing/payments', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json',
                                },
                                body: JSON.stringify({
                                    invoice_id: invoiceId,
                                    amount: invoiceAmount,
                                    payment_method: paymentMethod,
                                    reference_number: '',
                                    notes: notes || ''
                                })
                            });
                        })
                        .then(response => response.json())
                        .then(result => {
                            if (!result.success) {
                                throw new Error(result.message || 'Gagal mencatat pembayaran');
                            }

                            const modalEl = document.getElementById('markAsPaidModal');
                            const modalInstance = bootstrap.Modal.getInstance(modalEl);
                            if (modalInstance) {
                                modalInstance.hide();
                            }

                            markAsPaidForm.reset();
                            alert('✅ Tagihan berhasil ditandai sebagai lunas!');
                            setTimeout(() => location.reload(), 1000);
                        })
                        .catch(error => {
                            console.error('Error:', error);
                            alert('❌ Terjadi kesalahan saat menandai tagihan sebagai lunas');
                        })
                        .finally(() => {
                            submitBtn.disabled = false;
                            submitBtn.innerHTML = originalText;
                        });
                });
            }
        });
    </script>

    <!-- Mobile Bottom Navbar -->
    <%- include('../../partials/admin-mobile-navbar', { currentPage: 'customers' }) %>
</body>

</html>
