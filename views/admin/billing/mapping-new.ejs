                height: 42px !important;
                min-width: 42px !important;
                max-height: 42px !important;
                border-radius: 12px !important;
                background-size: 20px 20px !important;
            }

            .leaflet-bottom.leaflet-right .leaflet-control-layers-expanded {
                width: 172px !important;
                padding: 10px !important;
            }

            .leaflet-bottom.leaflet-right .leaflet-control-layers-base label,
            .leaflet-bottom.leaflet-right .leaflet-control-layers-overlays label {
                font-size: 12px !important;
                padding: 5px 7px !important;
            }
        }
</style>

    <!-- Add SVG defs for arrowhead -->
    <svg style="display: none;">
        <defs>
            <marker id="arrowhead" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
                <polygon points="0 0, 10 3.5, 0 7" fill="#28a745" />
            </marker>
        </defs>
    </svg>
</head>

<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Include<!-- Sidebar -->
            <%- include('../../partials/admin-responsive-sidebar', { page: 'mapping-new' }) %>

                <!-- Main content -->
                <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 main-content">
                    <div class="row g-3 align-items-stretch mb-4 pt-2">
                        <div class="col-12">
                            <div class="dashboard-hero d-flex justify-content-between align-items-start gap-3">
                                <div>
                                    <h4 class="mb-2"><%= title || 'Network Mapping' %></h4>
                                    <p>Kelola dan pantau data network mapping.</p>
                                </div>
                                <button class="btn btn-white shadow-sm border-0 rounded-pill" id="themeToggle" type="button" title="Ganti tema">
                                    <i class="bi bi-sun-fill text-warning" id="themeIcon"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Tab Navigation -->
                    <ul class="nav nav-tabs mb-4">
                        <li class="nav-item">
                            <a class="nav-link <%= typeof page !== 'undefined' && page === 'mapping-new' ? 'active' : '' %>"
                                href="/admin/mapping-new">
                                <i class="bi bi-map"></i> Network Mapping
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= typeof page !== 'undefined' && page === 'cable-network-odp' ? 'active' : '' %>"
                                href="/admin/cable-network/odp">
                                <i class="bi bi-diagram-2"></i> ODP
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= typeof page !== 'undefined' && page === 'cable-network-cables' ? 'active' : '' %>"
                                href="/admin/cable-network/cables">
                                <i class="bi bi-bezier2"></i> Cable Routes
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link <%= typeof page !== 'undefined' && page === 'cable-network-analytics' ? 'active' : '' %>"
                                href="/admin/cable-network/analytics">
                                <i class="bi bi-bar-chart-line"></i> Analytics
                            </a>
                        </li>
                    </ul>
                    <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 mobile-header-visible"
                        style="border-bottom: 1px solid rgba(148, 163, 184, 0.24);">
                        <h1 class="h2 fw-bold mb-0">
                            <i class="bx bx-map me-2"></i>Network Mapping
                        </h1>
                        <div class="btn-toolbar mb-2 mb-md-0">
                            <div class="btn-group me-2">
                                <a href="/admin/cable-network/odp" class="btn btn-outline-primary rounded-pill">
                                    <i class="fas fa-network-wired"></i> Manage ODP
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="map-container">
                        <!-- Loading Indicator -->
                        <div id="loading" class="loading">
                            <div class="text-center">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <div class="mt-2">Loading network data...</div>
                            </div>
                        </div>

                        <!-- Map -->
                        <div id="map"></div>
                    </div>

                    <!-- Panels Below Map -->
                    <div class="panels-row">
                        <!-- Control Panel -->
                        <div class="panel-col">
                            <div class="control-panel">
                                <h5><i class="fas fa-cogs"></i> Layer Controls</h5>

                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="showCustomers" checked>
                                    <label class="form-check-label" for="showCustomers">
                                        <i class="fas fa-user text-primary"></i> Customers
                                    </label>
                                </div>

                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="showONU" checked>
                                    <label class="form-check-label" for="showONU">
                                        <i class="fas fa-broadcast-tower text-success"></i> ONU Devices
                                    </label>
                                </div>

                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="showODP" checked>
                                    <label class="form-check-label" for="showODP">
                                        <i class="fas fa-broadcast-tower text-warning"></i> ODPs
                                    </label>
                                </div>

                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="showCables" checked>
                                    <label class="form-check-label" for="showCables">
                                        <i class="fas fa-plug text-info"></i> Cables & Network
                                    </label>
                                </div>
                            </div>
                        </div>

                        <!-- Statistics Panel -->
                        <div class="panel-col">
                            <div class="stats-panel">
                                <h6><i class="fas fa-chart-bar"></i> Network Statistics</h6>
                                <div class="stats-item">
                                    <span>Customers:</span>
                                    <span id="totalCustomers">-</span>
                                </div>
                                <div class="stats-item">
                                    <span>ONU Devices:</span>
                                    <span id="totalONU">-</span>
                                </div>
                                <div class="stats-item">
                                    <span class="status-online">Online:</span>
                                    <span id="onlineONU" class="status-online">-</span>
                                </div>
                                <div class="stats-item">
                                    <span class="status-offline">Offline:</span>
                                    <span id="offlineONU" class="status-offline">-</span>
                                </div>
                                <div class="stats-item">
                                    <span>ODPs:</span>
                                    <span id="totalODP">-</span>
                                </div>
                                <div class="stats-item">
                                    <span>Cables:</span>
                                    <span id="totalCables">-</span>
                                </div>
                                <div class="stats-item">
                                    <span>Backbone:</span>
                                    <span id="totalBackbone">-</span>
                                </div>

                                <!-- Legend -->
                                <div class="mt-3 pt-2 border-top">
                                    <h6 class="mb-2"><i class="fas fa-info-circle"></i> Legend</h6>
                                    <div class="legend-item">
                                        <div class="legend-color online"></div>
                                        <span>ONU Online</span>
                                    </div>
                                    <div class="legend-item">
                                        <div class="legend-color offline"></div>
                                        <span>ONU Offline</span>
                                    </div>
                                    <div class="legend-item">
                                        <div class="legend-color cable-connected"></div>
                                        <span>Cable Connected</span>
                                    </div>
                                    <div class="legend-item">
                                        <div class="legend-color cable-disconnected"></div>
                                        <span>Cable Disconnected</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Mobile Toggle Buttons -->
                    <button class="mobile-toggle control-toggle" id="controlToggle" title="Show Layer Controls">
                        <i class="fas fa-cogs"></i>
                    </button>
                    <button class="mobile-toggle stats-toggle" id="statsToggle" title="Show Network Statistics">
                        <i class="fas fa-chart-bar"></i>
                    </button>
                    <button class="mobile-toggle layer-toggle" id="layerToggle" title="Show Base Maps & Layers">
                        <i class="fas fa-layer-group"></i>
                    </button>
                </main>
    </div>

    <!-- Include Details Modals -->
    <%- include('mapping-details-modal.ejs') %>

        <!-- Leaflet JS -->
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

        <!-- Bootstrap JS -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

        <script>
            // Global variables
            let map;
            let networkData = {};
            let customerLayer, onuLayer, odpLayer, cableLayer, backboneLayer;

            // Initialize map
            function initMap() {
                console.log('ðŸ—ºï¸ Initializing map with satellite view as default...');

                // Create map centered on Garut
                map = L.map('map').setView([-7.1599, 108.0612], 13);

                                // Add enhanced tile layers with multiple options
                const voyagerTheme = L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
                    attribution: '© OpenStreetMap © CARTO',
                    subdomains: 'abcd',
                    maxZoom: 20
                });

                const lightTheme = L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
                    attribution: '© OpenStreetMap © CARTO',
                    subdomains: 'abcd',
                    maxZoom: 20
                });

                const darkTheme = L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
                    attribution: '© OpenStreetMap © CARTO',
                    subdomains: 'abcd',
                    maxZoom: 20
                });

                const topoTheme = L.tileLayer('https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png', {
                    maxZoom: 17,
                    attribution: '© OpenTopoMap'
                });

                const satelliteTheme = L.tileLayer('http://{s}.google.com/vt/lyrs=s,h&x={x}&y={y}&z={z}', {
                    maxZoom: 20,
                    subdomains: ['mt0', 'mt1', 'mt2', 'mt3'],
                    attribution: '© Google Maps'
                });

                // Add default satellite theme
                satelliteTheme.addTo(map);

                // Create base layers object
                const baseLayers = {
                    "Satellite": satelliteTheme,
                    "Peta Utama": voyagerTheme,
                    "Peta Terang": lightTheme,
                    "Peta Gelap": darkTheme,
                    "Topografi": topoTheme
                };

                // Initialize layers
                customerLayer = L.layerGroup().addTo(map);
                onuLayer = L.layerGroup().addTo(map);
                odpLayer = L.layerGroup().addTo(map);
                cableLayer = L.layerGroup().addTo(map);
                backboneLayer = L.layerGroup().addTo(map);

                // Create overlay layers object
                const overlayLayers = {
                    "ODPs": odpLayer,
                    "Customers": customerLayer,
                    "Cable Routes": cableLayer,
                    "Backbone": backboneLayer,
                    "ONU Devices": onuLayer
                };

                // Add layer control (collapsed by default)
                const layerControl = L.control.layers(baseLayers, overlayLayers, {
                    position: 'bottomright',
                    collapsed: true
                }).addTo(map);

                                // Sync layer control with Google Maps style button
                setTimeout(() => {
                    const layerControlElement = document.querySelector('.leaflet-control-layers');
                    if (layerControlElement) {
                        layerControlElement.style.display = 'block';
                        layerControlElement.style.visibility = 'visible';
                        layerControlElement.style.opacity = '1';
                        layerControlElement.style.position = '';
                        layerControlElement.style.top = '';
                        layerControlElement.style.right = '';
                        layerControlElement.style.left = '';
                        layerControlElement.style.bottom = '';
                        layerControlElement.style.transform = '';
                        layerControlElement.style.width = '';
                        layerControlElement.style.maxHeight = 'none';
                        layerControlElement.style.overflowY = 'visible';
                        layerControlElement.classList.remove('show');
                    }
                }, 100);

                console.log('âœ… Map initialized successfully with satellite view as default');

                // Load network data
                loadNetworkData();
                
                // Auto refresh every 30 seconds
                setInterval(() => {
                    console.log('ðŸ”„ Auto-refreshing network data...');
                    loadNetworkData();
                }, 30000);
            }

            // Create custom marker icons
            function createODPIcon() {
                return L.divIcon({
                    className: 'custom-odp-icon',
                    html: `
                    <div class="odp-marker">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 1L3 5V11C3 16.55 6.16 21.74 12 23C17.84 21.74 21 16.55 21 11V5L12 1Z" fill="#4a6baf"/>
                            <path d="M12 1L3 5V11C3 16.55 6.16 21.74 12 23V1Z" fill="#3a5a9c"/>
                            <path d="M12 13C13.6569 13 15 11.6569 15 10C15 8.34315 13.6569 7 12 7C10.3431 7 9 8.34315 9 10C9 11.6569 10.3431 13 12 13Z" fill="white"/>
                        </svg>
                    </div>
                `,
                    iconSize: [24, 24],
                    iconAnchor: [12, 12]
                });
            }

            function createCustomerIcon() {
                return L.divIcon({
                    className: 'custom-customer-icon',
                    html: '<div class="customer-marker"><i class="fas fa-home"></i></div>',
                    iconSize: [25, 25],
                    iconAnchor: [12, 12]
                });
            }

            function createONUIcon(status = 'online') {
                const isOffline = status && status.toLowerCase() === 'offline';
                const iconClass = isOffline ? 'fas fa-wifi-slash' : 'fas fa-wifi';
                const markerClass = isOffline ? 'onu-marker offline' : 'onu-marker online';

                return L.divIcon({
                    className: 'custom-onu-icon',
                    html: `<div class="${markerClass}"><i class="${iconClass}"></i></div>`,
                    iconSize: [20, 20],
                    iconAnchor: [10, 10]
                });
            }

            // Load network data from API
            async function loadNetworkData() {
                try {
                    console.log('ðŸ“¡ Loading network data...');

                    const response = await fetch('/admin/api/mapping/new');
                    const result = await response.json();

                    if (result.success) {
                        networkData = result.data;
                        console.log('âœ… Network data loaded:', networkData);

                        // Render all data
                        renderNetworkData();

                        // Update statistics
                        updateStatistics();

                        // Hide loading
                        document.getElementById('loading').style.display = 'none';

                    } else {
                        console.error('âŒ Failed to load network data:', result.error);
                        throw new Error(result.error || 'Failed to load network data');
                    }

                } catch (error) {
                    console.error('âŒ Error loading network data:', error);
                    document.getElementById('loading').innerHTML = `
                    <div class="text-center text-danger">
                        <i class="fas fa-exclamation-triangle fa-2x mb-2"></i>
                        <div>Error loading network data</div>
                        <small>${error.message}</small>
                    </div>
                `;
                }
            }

            // Render all network data
            function renderNetworkData() {
                try {
                    console.log('ðŸŽ¨ Rendering network data...');

                    // Clear existing layers
                    clearLayers();

                    // Render customers
                    if (networkData.customers?.length > 0) {
                        renderCustomers(networkData.customers);
                    }

                    // Render ONU devices
                    if (networkData.onuDevices?.length > 0) {
                        renderONUDevices(networkData.onuDevices);
                    }

                    // Render ODPs
                    if (networkData.odps?.length > 0) {
                        renderODPs(networkData.odps);
                    }

                    // Render cables
                    if (networkData.cables?.length > 0) {
                        renderCables(networkData.cables);
                    }

                    // Render backbone cables
                    if (networkData.backboneCables?.length > 0) {
                        renderBackboneCables(networkData.backboneCables);
                    }

                    // Add data flow animations
                    addDataFlowAnimations();

                    // Fit map to data
                    fitToBounds();

                    console.log('âœ… Network data rendered successfully');

                } catch (error) {
                    console.error('âŒ Error rendering network data:', error);
                    throw error;
                }
            }

            // Clear all layers
            function clearLayers() {
                console.log('ðŸ§¹ Clearing all layers...');

                if (customerLayer) customerLayer.clearLayers();
                if (onuLayer) onuLayer.clearLayers();
                if (odpLayer) odpLayer.clearLayers();
                if (cableLayer) cableLayer.clearLayers();
                if (backboneLayer) backboneLayer.clearLayers();

                console.log('âœ… All layers cleared');
            }

            // Render customers
            function renderCustomers(customers) {
                console.log(`ðŸ‘¥ Rendering ${customers.length} customers...`);

                customers.forEach(customer => {
                    if (customer.latitude && customer.longitude) {
                        const marker = L.marker([customer.latitude, customer.longitude], {
                            icon: createCustomerIcon()
                        }).addTo(customerLayer);

                        const popupContent = `
                        <div class="custom-popup">
                            <div class="popup-header">
                                <h6><i class="fas fa-home"></i> ${customer.name}</h6>
                            </div>
                            <div class="popup-body">
                                ${customer.house_photo ? `<div class="popup-photo-wrap"><img class="popup-photo" src="/img/customer-houses/${customer.house_photo}" alt="Foto Rumah ${customer.name || ''}"></div>` : ''}
                                <p><strong>Phone:</strong> ${customer.phone || 'N/A'}</p>
                                <p><strong>Address:</strong> ${customer.address || 'N/A'}</p>
                                <p><strong>Status:</strong> <span class="status-${customer.status}">${customer.status}</span></p>
                                <p><strong>Package:</strong> ${customer.package_name || customer.package || customer.package_id || 'N/A'}</p>
                            </div>
                            <div class="popup-footer">
                                <button class="btn btn-sm btn-primary" onclick="viewCustomerDetails(${customer.id})">
                                    <i class="fas fa-eye"></i> View Details
                                </button>
                            </div>
                        </div>
                    `;

                        marker.bindPopup(popupContent);
                    }
                });

                console.log(`âœ… Loaded ${customers.length} customer markers from database`);
            }

            // Render ONU devices
            function renderONUDevices(devices) {
                console.log(`ðŸ“¡ Rendering ${devices.length} ONU devices...`);

                devices.forEach(device => {
                    if (device.latitude && device.longitude) {
                        const status = device.status;
                        const marker = L.marker([device.latitude, device.longitude], {
                            icon: createONUIcon(status)
                        });

                        const isOffline = status && status.toLowerCase() === 'offline';
                        // Force offline devices to be on top
                        if (isOffline) {
                            marker.setZIndexOffset(1000);
                        }
                        marker.addTo(onuLayer);

                        const statusClass = device.status?.toLowerCase() === 'offline' ? 'status-offline' : 'status-online';
                        const statusIcon = device.status?.toLowerCase() === 'offline' ? 'fas fa-wifi-slash' : 'fas fa-wifi';

                        // Determine RX Power color
                        const rxPower = parseFloat(device.rxPower);
                        let rxPowerClass = 'danger';
                        if (rxPower > -25) rxPowerClass = 'success';
                        else if (rxPower > -30) rxPowerClass = 'warning';

                        const popupContent = `
                        <div class="custom-popup" style="max-width: 450px;">
                            <div class="popup-header">
                                <h6><i class="${statusIcon}"></i> ${device.customerName || device.name || 'ONU Device'}</h6>
                            </div>
                            <div class="popup-body" style="max-height: 450px; overflow-y: auto;">
                                <h6 class="mt-2 mb-2 border-bottom pb-1"><i class="fas fa-info-circle"></i> Device Info</h6>
                                <p style="margin: 4px 0;"><strong>ID:</strong> ${device.id || 'N/A'}</p>
                                <p style="margin: 4px 0;"><strong>Serial:</strong> ${device.serialNumber || 'N/A'}</p>
                                <p style="margin: 4px 0;"><strong>Model:</strong> ${device.model || 'N/A'}</p>
                                <p style="margin: 4px 0;"><strong>Status:</strong> <span class="badge bg-${device.status?.toLowerCase() === 'offline' ? 'danger' : 'success'}">${device.status || 'Unknown'}</span></p>
                                <p style="margin: 4px 0;"><strong>IP Address:</strong> ${device.ipAddress || 'N/A'}</p>
                                <p style="margin: 4px 0;"><strong>MAC Address:</strong> ${device.macAddress || 'N/A'}</p>
                                <p style="margin: 4px 0;"><strong>Firmware:</strong> ${device.firmware || 'N/A'}</p>
                                <p style="margin: 4px 0;"><strong>Hardware:</strong> ${device.hardware || 'N/A'}</p>
                                
                                <h6 class="mt-3 mb-2 border-bottom pb-1"><i class="fas fa-wifi"></i> WiFi & Signal</h6>
                                <p style="margin: 4px 0;"><strong>RX Power:</strong> <span class="badge bg-${rxPowerClass}">${device.rxPower || 'N/A'} dBm</span></p>
                                <p style="margin: 4px 0;"><strong>TX Power:</strong> ${device.txPower || 'N/A'}</p>
                                <p style="margin: 4px 0;"><strong>Temperature:</strong> ${device.temperature || 'N/A'}</p>
                                <p style="margin: 4px 0;"><strong>Uptime:</strong> ${device.uptime || 'N/A'}</p>
                                
                                <div class="mt-3 p-2 bg-light rounded">
                                    <h6 class="mb-2"><i class="fas fa-edit"></i> Edit WiFi Settings</h6>
                                    <div class="mb-2">
                                        <label class="form-label mb-1" style="font-size: 12px; font-weight: 600;">SSID:</label>
                                        <div class="input-group input-group-sm">
                                            <input type="text" class="form-control" id="popup-ssid-${device.id}" value="${device.ssid || ''}" placeholder="Enter SSID">
                                            <button class="btn btn-primary" type="button" onclick="savePopupSSID('${device.id}')">
                                                <i class="fas fa-save"></i> Save
                                            </button>
                                        </div>
                                    </div>
                                    <div class="mb-0">
                                        <label class="form-label mb-1" style="font-size: 12px; font-weight: 600;">WiFi Password:</label>
                                        <div class="input-group input-group-sm">
                                            <input type="password" class="form-control" id="popup-password-${device.id}" placeholder="Enter Password">
                                            <button class="btn btn-outline-secondary" type="button" onclick="togglePopupPassword('${device.id}')">
                                                <i class="fas fa-eye"></i>
                                            </button>
                                            <button class="btn btn-warning" type="button" onclick="savePopupPassword('${device.id}')">
                                                <i class="fas fa-key"></i> Save
                                            </button>
                                        </div>
                                    </div>
                                </div>
                                
                                <h6 class="mt-3 mb-2 border-bottom pb-1"><i class="fas fa-user"></i> Customer Info</h6>
                                ${device.customerHousePhoto ? `<div class="popup-photo-wrap"><img class="popup-photo" src="/img/customer-houses/${device.customerHousePhoto}" alt="Foto Rumah ${device.customerName || ''}"></div>` : ''}
                                <p style="margin: 4px 0;"><strong>Name:</strong> ${device.customerName || 'N/A'}</p>
                                <p style="margin: 4px 0;"><strong>Phone:</strong> ${device.customerPhone || 'N/A'}</p>
                                <p style="margin: 4px 0;"><strong>PPPoE:</strong> ${device.customerPPPoE || 'N/A'}</p>
                                <p style="margin: 4px 0;"><strong>Package:</strong> ${device.customerPackage || 'N/A'}</p>
                                ${device.customerStatus ? `<p style="margin: 4px 0;"><strong>Status Layanan:</strong> <span class="badge bg-${device.customerStatus === 'active' ? 'success' : device.customerStatus === 'suspended' ? 'warning' : 'danger'}">${device.customerStatus === 'active' ? 'Aktif' : device.customerStatus === 'suspended' ? 'Suspend' : device.customerStatus}</span></p>` : ''}
                                ${device.paymentStatus ? `<p style="margin: 4px 0;"><strong>Status Pembayaran:</strong> <span class="badge bg-${device.paymentStatus === 'paid' ? 'success' : device.paymentStatus === 'pending' ? 'warning' : 'danger'}">${device.paymentStatus === 'paid' ? 'Lunas' : device.paymentStatus === 'pending' ? 'Pending' : device.paymentStatus === 'unpaid' ? 'Belum Bayar' : device.paymentStatus}</span></p>` : ''}
                                ${device.lastPaymentDate ? `<p style="margin: 4px 0;"><strong>Pembayaran Terakhir:</strong> ${new Date(device.lastPaymentDate).toLocaleDateString('id-ID')}</p>` : ''}
                                ${device.nextBillingDate ? `<p style="margin: 4px 0;"><strong>Tagihan Berikutnya:</strong> ${new Date(device.nextBillingDate).toLocaleDateString('id-ID')}</p>` : ''}
                                ${device.customerPhone ? `<div class="mt-2"><button class="btn btn-sm btn-primary" onclick="viewCustomerDetails('${device.customerPhone}')"><i class="fas fa-user-circle"></i> Detail Pelanggan Lengkap</button></div>` : ''}
                                <h6 class="mt-3 mb-2 border-bottom pb-1"><i class="fas fa-map-marker-alt"></i> Location</h6>
