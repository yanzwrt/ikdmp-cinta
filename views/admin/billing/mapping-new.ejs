                let hasData = false;

                // Add all coordinates to bounds
                if (networkData.customers) {
                    networkData.customers.forEach(customer => {
                        if (customer.latitude && customer.longitude) {
                            bounds.extend([customer.latitude, customer.longitude]);
                            hasData = true;
                        }
                    });
