                if (networkData.odps) {
                    networkData.odps.forEach(odp => {
                        if (odp.latitude && odp.longitude) {
                            bounds.extend([odp.latitude, odp.longitude]);
                            hasData = true;
                        }
                    });
                }

                if (hasData) {
