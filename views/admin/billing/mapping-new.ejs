            // Action functions for modals
            function editODP(odpId) {
                console.log('Edit ODP:', odpId);

                // Temukan data ODP dari networkData terlebih dahulu
                let odp = networkData.odps?.find(o => o.id == odpId);

                if (!odp) {
                    // Jika tidak ditemukan di networkData, fetch dari server
                    fetch(`/admin/odp/${odpId}`)
                        .then(response => response.json())
                        .then(data => {
                            if (data.success && data.data) {
                                // Simpan data ke networkData untuk penggunaan berikutnya
                                if (!networkData.odps) {
                                    networkData.odps = [];
                                }

                                // Perbarui atau tambahkan data ODP
                                const existingIndex = networkData.odps.findIndex(o => o.id == odpId);
                                if (existingIndex >= 0) {
                                    networkData.odps[existingIndex] = data.data;
                                } else {
                                    networkData.odps.push(data.data);
                                }

                                // Lanjutkan dengan populate form
                                populateODPForm(data.data);
                            } else {
                                alert('ODP not found');
                            }
                        })
                        .catch(error => {
                            console.error('Error fetching ODP details:', error);
                            alert('Error fetching ODP details: ' + error.message);
                        });
                } else {
                    // Jika ditemukan di networkData, langsung populate form
                    populateODPForm(odp);
                }
            }

