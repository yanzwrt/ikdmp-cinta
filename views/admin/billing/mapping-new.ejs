            async function saveOdpStatusQuick(buttonEl) {
                const odpId = buttonEl.getAttribute('data-odp-id');
                const currentStatus = (buttonEl.getAttribute('data-current-status') || 'inactive').toLowerCase();
                const statusSelect = document.getElementById('odp-status-select');

                if (!odpId || !statusSelect) {
                    alert('Data ODP tidak ditemukan');
                    return;
                }

                const newStatus = String(statusSelect.value || 'inactive').toLowerCase();
                const currentOdp = (networkData.odps || []).find(o => String(o.id) === String(odpId)) || {};
                let forceNotification = false;

                if (newStatus === currentStatus && (newStatus === 'maintenance' || newStatus === 'inactive')) {
                    forceNotification = confirm(`Status ODP sudah ${newStatus}. Kirim ulang notifikasi ke pelanggan yang terhubung ke ODP ini?`);
                    if (!forceNotification) {
                        return;
                    }
                } else if ((newStatus === 'maintenance' || newStatus === 'inactive') && currentStatus !== newStatus) {
                    const shouldSend = confirm(`Ubah status ODP menjadi ${newStatus} dan kirim notifikasi ke pelanggan yang terhubung?`);
                    if (!shouldSend) {
                        return;
                    }
                }

                const originalHtml = buttonEl.innerHTML;
                buttonEl.disabled = true;
                buttonEl.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Menyimpan...';

                try {
                    const headers = {
                        'Content-Type': 'application/json'
                    };
                    const csrfTokenMeta = document.querySelector('meta[name="csrf-token"]');
                    if (csrfTokenMeta) {
                        headers['X-CSRF-TOKEN'] = csrfTokenMeta.getAttribute('content');
                    }

                    const response = await fetch(`/admin/cable-network/odp/${odpId}`, {
                        method: 'PUT',
                        headers,
                        body: JSON.stringify({
                            status: newStatus,
                            force_notification: forceNotification
                        })
                    });

                    const rawText = await response.text();
                    let data;
                    try {
                        data = JSON.parse(rawText);
                    } catch (_) {
                        throw new Error(rawText || 'Respons server tidak valid');
                    }

                    if (!response.ok || !data.success) {
                        throw new Error(data.message || 'Gagal mengupdate status ODP');
                    }

                    const updatedOdp = data.data || {};
                    const odpIndex = networkData.odps?.findIndex(o => String(o.id) === String(odpId));
                    if (odpIndex >= 0) {
                        networkData.odps[odpIndex] = {
                            ...networkData.odps[odpIndex],
                            ...updatedOdp
                        };
                    }

                    showODPDetailsModalWithData({
                        ...currentOdp,
                        ...updatedOdp,
                        status: updatedOdp.status || newStatus
                    }, false);

                    alert(data.message || 'Status ODP berhasil diperbarui');
                } catch (error) {
                    console.error('Error updating ODP status from mapping:', error);
                    alert(error.message || 'Gagal mengupdate status ODP');
                } finally {
                    buttonEl.disabled = false;
                    buttonEl.innerHTML = originalHtml;
                }
            }

