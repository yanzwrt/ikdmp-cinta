            // Render cables with animation
            function renderCables(cables) {
                console.log(`ðŸ”Œ Rendering ${cables.length} cables with animation...`);

                // Add SVG defs for arrow markers if not exists
                if (!document.getElementById('arrowhead-defs')) {
                    const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
                    svg.style.display = 'none';
                    svg.innerHTML = `
                    <defs id="arrowhead-defs">
                        <marker id="arrowhead" viewBox="0 0 10 10" refX="9" refY="5" 
                                markerWidth="6" markerHeight="6" orient="auto">
                            <path d="M 0 0 L 10 5 L 0 10 z" fill="#28a745" />
                        </marker>
                        <marker id="arrowhead-disconnected" viewBox="0 0 10 10" refX="9" refY="5" 
                                markerWidth="6" markerHeight="6" orient="auto">
                            <path d="M 0 0 L 10 5 L 0 10 z" fill="#dc3545" />
                        </marker>
                    </defs>
                `;
                    document.body.appendChild(svg);
                }

                cables.forEach((cable, index) => {
                    if (cable.coordinates && cable.coordinates.length >= 2) {
                        // Determine cable status based on connected ONU status
                        let cableStatus = 'connected';
                        let cableClass = 'cable-line connected';

                        // Check if cable is connected to any offline ONU
                        if (networkData.onuDevices) {
                            const connectedONU = networkData.onuDevices.find(onu =>
                                onu.odpName === cable.from || onu.odpName === cable.to
                            );
                            if (connectedONU && connectedONU.status && connectedONU.status.toLowerCase() === 'offline') {
                                cableStatus = 'disconnected';
                                cableClass = 'cable-line disconnected';
                            }
                        }

                        // Create the polyline with animation
                        const polyline = L.polyline(cable.coordinates, {
                            color: cableStatus === 'connected' ? '#28a745' : '#dc3545',
                            weight: cableStatus === 'connected' ? 3 : 2,
                            opacity: 0.8,
                            dashArray: cableStatus === 'connected' ? '10, 5' : '5, 5',
                            lineCap: 'round',
                            className: cableClass
                        });

                        // Add animation effect
                        if (cableStatus === 'connected') {
                            // Wait for the path to be rendered
                            setTimeout(() => {
                                try {
                                    if (polyline._path) {
                                        const length = polyline._path.getTotalLength ? polyline._path.getTotalLength() : 100;
                                        polyline._path.style.strokeDasharray = '10, 5';
                                        polyline._path.style.strokeDashoffset = length;

                                        // Animate the dash offset
                                        const animate = () => {
                                            if (!polyline._path) return;

                                            const currentOffset = parseFloat(polyline._path.style.strokeDashoffset) || 0;
                                            if (currentOffset <= -length) {
                                                polyline._path.style.strokeDashoffset = length;
                                            } else {
                                                polyline._path.style.strokeDashoffset = currentOffset - 0.5;
                                            }
                                            requestAnimationFrame(animate);
                                        };

                                        // Start animation
                                        requestAnimationFrame(animate);
                                    }
                                } catch (error) {
                                    console.error('Error animating cable:', error);
                                }
                            }, 500 + (index * 100)); // Add delay to ensure path is rendered
                        }

                        // Add popup with cable info
                        polyline.bindPopup(`
                        <div class="popup-content">
                            <div class="popup-title">
                                <i class="fas fa-plug"></i> Cable Route
                            </div>
                            <div class="popup-info">
                                <p><strong>From:</strong> ${cable.from || 'N/A'}</p>
                                <p><strong>To:</strong> ${cable.to || 'N/A'}</p>
                                <p><strong>Type:</strong> ${cable.type || 'Access Cable'}</p>
                                <p><strong>Status:</strong> 
                                    <span class="status-badge ${cableStatus === 'connected' ? 'status-online' : 'status-offline'}">
                                        ${cableStatus === 'connected' ? 'Connected' : 'Disconnected'}
                                    </span>
                                </p>
                                ${cable.length ? `<p><strong>Length:</strong> ${cable.length} m</p>` : ''}
                                ${cable.port_number ? `<p><strong>Port:</strong> ${cable.port_number}</p>` : ''}
                            </div>
                        </div>
                    `);

                        // Add hover effect
                        polyline.on('mouseover', function () {
                            this.setStyle({
                                weight: this.options.weight + 1,
                                opacity: 1
                            });
                        });

                        polyline.on('mouseout', function () {
                            this.setStyle({
                                weight: cableStatus === 'connected' ? 3 : 2,
                                opacity: 0.8
                            });
                        });

                        // Add to layer
                        cableLayer.addLayer(polyline);
                    }
                });

                console.log(`âœ… Rendered ${cables.length} cables with animation`);
            }

