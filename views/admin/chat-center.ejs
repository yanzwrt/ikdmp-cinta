<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/responsive-admin.css" rel="stylesheet">
    <style>
        body { background: #eef4ff; }
        .chat-center-card { border: 0; border-radius: 24px; box-shadow: 0 18px 40px rgba(37,99,235,.08); }
        .chat-conversation { display:flex; gap:14px; align-items:flex-start; padding:16px; border-radius:20px; color:inherit; border:1px solid rgba(148,163,184,.16); background:#fff; transition:.2s ease; }
        .chat-conversation:hover { transform: translateY(-2px); box-shadow: 0 14px 28px rgba(15,23,42,.08); }
        .chat-avatar { width:52px; height:52px; border-radius:16px; background:linear-gradient(135deg,#6d4bff,#8b5cf6); color:#fff; display:flex; align-items:center; justify-content:center; font-weight:700; overflow:hidden; flex-shrink:0; }
        .chat-avatar img { width:100%; height:100%; object-fit:cover; }
        .chat-center-actions { display:flex; gap:10px; align-items:center; }
        .chat-target-list { max-height: 280px; overflow-y: auto; display:flex; flex-direction:column; gap:8px; }
        .chat-target-item { display:flex; align-items:center; gap:10px; padding:10px 12px; border-radius:14px; border:1px solid rgba(148,163,184,.18); background:#fff; cursor:pointer; }
        .chat-target-item:hover { border-color:#8b5cf6; background:#faf7ff; }
        .chat-target-avatar { width:38px; height:38px; border-radius:12px; overflow:hidden; background:linear-gradient(135deg,#6d4bff,#8b5cf6); color:#fff; display:flex; align-items:center; justify-content:center; font-weight:700; flex-shrink:0; }
        .chat-target-avatar img { width:100%; height:100%; object-fit:cover; }
    </style>
</head>
<body>
<%
    const formatWib = (value) => {
        if (!value) return '-';
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) return '-';
        return new Intl.DateTimeFormat('id-ID', {
            timeZone: 'Asia/Jakarta',
            day: '2-digit',
            month: '2-digit',
            year: 'numeric',
            hour: '2-digit',
            minute: '2-digit',
            second: '2-digit'
        }).format(date) + ' WIB';
    };
    const photoDirForRole = (role) => role === 'agent'
        ? 'agent-profiles'
        : role === 'collector'
            ? 'collector-profiles'
            : role === 'customer'
                ? 'customer-profiles'
                : 'technician-profiles';
    const senderLabelFor = (item) => item.lastSenderRole === 'admin'
        ? 'Admin'
        : item.lastSenderRole === 'technician'
            ? 'Teknisi'
            : item.role;
%>
<div class="container-fluid">
    <div class="row">
        <%- include('../partials/admin-responsive-sidebar', { page: 'chats', settings: settings, versionInfo: versionInfo, versionBadge: versionBadge }) %>
        <main class="col-md-10 ms-sm-auto main-content py-4">
            <div class="d-flex justify-content-between align-items-center mb-3 gap-3">
                <div>
                    <h2 class="mb-1">Chat Center</h2>
                    <div class="text-muted">Percakapan admin dengan customer, agent, collector, dan teknisi.</div>
                </div>
                <div class="chat-center-actions">
                    <button type="button" class="btn btn-primary rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#newChatModal">
                        <i class="bi bi-plus-lg me-2"></i>Tambah Chat
                    </button>
                </div>
            </div>
            <div class="card chat-center-card">
                <div class="card-body p-3 p-md-4">
                    <% if ((conversations || []).length) { %>
                        <div class="d-flex flex-column gap-3">
                            <% conversations.forEach(function(item) { const link = item.link || `/admin/chats/${item.role}/${item.userId}`; %>
                                <div class="chat-conversation">
                                    <div class="chat-avatar">
                                        <% if (item.participant.profile_photo) { %>
                                            <img src="/img/<%= photoDirForRole(item.role) %>/<%= item.participant.profile_photo %>" alt="<%= item.participant.name %>">
                                        <% } else { %>
                                            <span><%= String(item.participant.name || item.role).charAt(0).toUpperCase() %></span>
                                        <% } %>
                                    </div>
                                    <div class="flex-grow-1 min-w-0">
                                        <div class="d-flex justify-content-between align-items-start gap-2">
                                            <div>
                                                <div class="fw-bold"><%= item.participant.name %></div>
                                                <div class="small text-muted"><%= item.role %> - <%= item.participant.subtitle || '-' %></div>
                                            </div>
                                            <% if (item.unreadCount > 0) { %>
                                                <span class="badge rounded-pill bg-danger"><%= item.unreadCount %></span>
                                            <% } %>
                                        </div>
                                        <div class="small text-muted mt-2"><%= senderLabelFor(item) %>: <%= item.lastMessage %></div>
                                        <div class="small text-muted mt-1"><%= formatWib(item.createdAt) %></div>
                                    </div>
                                    <div class="d-flex flex-column gap-2">
                                        <a href="<%= link %>" class="btn btn-outline-primary btn-sm rounded-pill px-3">Buka</a>
                                        <button type="button" class="btn btn-outline-danger btn-sm rounded-pill px-3"
                                            data-chat-delete-role="<%= item.role %>"
                                            data-chat-delete-id="<%= item.userId %>"
                                            data-chat-delete-name="<%= item.participant.name %>">
                                            Hapus
                                        </button>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    <% } else { %>
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-chat-dots fs-1 d-block mb-3"></i>
                            Belum ada percakapan.
                        </div>
                    <% } %>
                </div>
            </div>
        </main>
    </div>
</div>

<div class="modal fade" id="newChatModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0" style="border-radius:24px;">
            <div class="modal-header border-0 pb-0">
                <div>
                    <h5 class="modal-title fw-bold">Tambah Chat</h5>
                    <div class="small text-muted">Pilih role lalu tujuan percakapan.</div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Tutup"></button>
            </div>
            <div class="modal-body pt-3">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Role</label>
                    <select class="form-select form-select-lg" id="chatTargetRole">
                        <option value="customer">Customer</option>
                        <option value="technician">Teknisi</option>
                        <option value="agent">Agent</option>
                        <option value="collector">Collector</option>
                    </select>
                </div>
                <div class="mb-0">
                    <label class="form-label fw-semibold">Tujuan</label>
                    <div id="chatTargetList" class="chat-target-list">
                        <div class="text-muted small py-3">Memuat daftar tujuan...</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    (function () {
        const roleSelect = document.getElementById('chatTargetRole');
        const listWrap = document.getElementById('chatTargetList');

        function escapeHtml(value) {
            return String(value || '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function photoDirFromLink(link) {
            if (link.includes('/technicians/')) return '/img/technician-profiles/';
            if (link.includes('/collector/')) return '/img/collector-profiles/';
            if (link.includes('/agent/')) return '/img/agent-profiles/';
            return '/img/customer-profiles/';
        }

        function renderTargets(targets) {
            if (!Array.isArray(targets) || !targets.length) {
                listWrap.innerHTML = '<div class="text-muted small py-3">Belum ada data tujuan.</div>';
                return;
            }

            listWrap.innerHTML = targets.map((item) => `
                <button type="button" class="chat-target-item" data-chat-target-link="${item.link}">
                    <div class="chat-target-avatar">
                        ${item.profile_photo ? `<img src="${photoDirFromLink(item.link)}${item.profile_photo}" alt="${escapeHtml(item.name)}">` : `<span>${escapeHtml(String(item.name || '?').charAt(0).toUpperCase())}</span>`}
                    </div>
                    <div class="text-start">
                        <div class="fw-semibold">${escapeHtml(item.name)}</div>
                        <div class="small text-muted">${escapeHtml(item.subtitle || '-')}</div>
                    </div>
                </button>
            `).join('');
        }

        async function loadTargets() {
            const role = roleSelect.value;
            listWrap.innerHTML = '<div class="text-muted small py-3">Memuat daftar tujuan...</div>';
            const response = await fetch(`/admin/chats/targets/${role}`, { cache: 'no-store' });
            const result = await response.json();
            if (!result.success) throw new Error(result.message || 'Gagal memuat daftar');
            renderTargets(result.targets || []);
        }

        roleSelect?.addEventListener('change', () => loadTargets().catch((error) => {
            listWrap.innerHTML = `<div class="text-danger small py-3">${escapeHtml(error.message)}</div>`;
        }));

        listWrap?.addEventListener('click', (event) => {
            const item = event.target.closest('[data-chat-target-link]');
            if (!item) return;
            window.location.href = item.getAttribute('data-chat-target-link');
        });

        document.addEventListener('click', async (event) => {
            const deleteButton = event.target.closest('[data-chat-delete-role]');
            if (!deleteButton) return;
            const role = deleteButton.getAttribute('data-chat-delete-role');
            const userId = deleteButton.getAttribute('data-chat-delete-id');
            const name = deleteButton.getAttribute('data-chat-delete-name') || 'percakapan';
            if (!confirm(`Hapus chat dengan ${name}? Riwayat di kedua sisi akan ikut kosong.`)) return;
            const response = await fetch(`/admin/chats/${role}/${userId}`, { method: 'DELETE' });
            const result = await response.json().catch(() => ({ success: false }));
            if (!result.success) {
                alert(result.message || 'Gagal menghapus chat');
                return;
            }
            window.location.reload();
        });

        document.getElementById('newChatModal')?.addEventListener('shown.bs.modal', () => {
            loadTargets().catch((error) => {
                listWrap.innerHTML = `<div class="text-danger small py-3">${escapeHtml(error.message)}</div>`;
            });
        });
    })();
</script>
</body>
</html>
