<!-- EJS Context Setup via Meta Tags -->
<script type="text/javascript">
    // Read values from meta tags to avoid EJS in JavaScript
    window.isTechnicianView = document.querySelector('meta[name="technician-view"]').content === 'true';
    window.reportId = document.querySelector('meta[name="report-id"]').content;
</script>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const updateStatusForm = document.getElementById('updateStatusForm');
        const notificationModal = new bootstrap.Modal(document.getElementById('notificationModal'));
        const notificationMessage = document.getElementById('notificationMessage');
        const modalOkButton = document.getElementById('modalOkButton');
        
        // Animasi untuk status radio buttons
        const statusRadios = document.querySelectorAll('.status-radio input');
        console.log('Found', statusRadios.length, 'radio buttons');
        
        statusRadios.forEach(radio => {
            console.log('Setting up radio:', radio.id, 'value:', radio.value, 'checked:', radio.checked);
            
            radio.addEventListener('change', function() {
                console.log('Radio changed to:', this.value, 'checked:', this.checked);
                
                // Highlight label yang dipilih dengan animasi
                const label = this.nextElementSibling;
                label.classList.add('animate__animated', 'animate__pulse');
                setTimeout(() => {
                    label.classList.remove('animate__animated', 'animate__pulse');
                }, 500);
            });
            
            // Also add click handler to label for better UX
            const label = radio.nextElementSibling;
            label.addEventListener('click', function(e) {
                e.preventDefault();
                console.log('Label clicked for:', radio.value);
                radio.checked = true;
                radio.dispatchEvent(new Event('change'));
            });
        });
        
        // Handle form submission
        updateStatusForm.addEventListener('submit', function(e) {
            e.preventDefault();
            
            // Get form data
            const statusRadio = document.querySelector('input[name="status"]:checked');
            const status = statusRadio ? statusRadio.value : '';
            const notes = document.getElementById('notes').value;
            const sendNotification = document.getElementById('sendNotification').checked;
            
            // Debug logging
            console.log('Form submission debug:');
            console.log('  - Status radio found:', statusRadio);
            console.log('  - Status value:', status);
            console.log('  - Notes:', notes);
            console.log('  - Send notification:', sendNotification);
            
            // Validate required fields
            if (!status) {
                alert('Silakan pilih status laporan');
                return;
            }
            
            if (!notes.trim()) {
                alert('Silakan tambahkan catatan update');
                return;
            }
            
            // Determine parameter name based on context
            const notesParam = window.isTechnicianView ? 'technician_notes' : 'notes';
            
            // Prepare body data
            const bodyData = { 
                status, 
                [notesParam]: notes,
                sendNotification
            };
            
            console.log('Body data to send:', bodyData);
            
            // Tampilkan loading state pada button
            const submitBtn = this.querySelector('button[type="submit"]');
            const originalBtnText = submitBtn.innerHTML;
            submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span> Memproses...';
            submitBtn.disabled = true;
            
            
            // Determine update URL based on context
            const updateUrl = window.isTechnicianView ? 
                '/technician/troubletickets/' + window.reportId + '/update' : 
                '/admin/trouble/update-status/' + window.reportId;
            
            fetch(updateUrl, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(bodyData)
            })
            .then(response => response.json())
            .then(data => {
                // Kembalikan button ke state normal
                submitBtn.innerHTML = originalBtnText;
                submitBtn.disabled = false;
                
                if (data.success) {
                    notificationMessage.innerHTML = 
                        '<div class="alert alert-success">' +
                        '<i class="bi bi-check-circle-fill me-2"></i> ' + data.message +
                        '</div>';
                    
                    // Reset form dan refresh halaman setelah berhasil
                    document.getElementById('notes').value = '';
                    modalOkButton.addEventListener('click', function() {
                        window.location.reload();
                    }, { once: true });
                } else {
                    notificationMessage.innerHTML = 
                        '<div class="alert alert-danger">' +
                        '<i class="bi bi-exclamation-triangle-fill me-2"></i> ' + data.message +
                        '</div>';
                }
                
                notificationModal.show();
            })
            .catch(error => {
                console.error('Error:', error);
                submitBtn.innerHTML = originalBtnText;
                submitBtn.disabled = false;
                notificationMessage.innerHTML = 
                    '<div class="alert alert-danger">' +
                    'Terjadi kesalahan saat mengupdate status. Silakan coba lagi.' +
                    '</div>';
                notificationModal.show();
            });
        });
    });
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</body>
