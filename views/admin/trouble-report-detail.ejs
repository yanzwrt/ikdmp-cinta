<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title><%= title %> - <%= typeof isTechnicianView !== 'undefined' && isTechnicianView ? 'Portal Teknisi' : 'Admin Panel' %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="technician-view" content="<% if (typeof isTechnicianView !== 'undefined' && isTechnicianView) { %>true<% } else { %>false<% } %>">
    <meta name="report-id" content="<%= report.id %>">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet">
    <link href="https://cdn.datatables.net/responsive/2.5.0/css/dataTables.responsive.min.css" rel="stylesheet">
    <link href="https://cdn.datatables.net/responsive/2.5.0/css/responsive.bootstrap5.min.css" rel="stylesheet">
    <link href="/css/responsive-admin.css" rel="stylesheet">
    <!-- Admin Mobile Optimizations -->
    <link href="/css/admin-mobile.css" rel="stylesheet">
    
    <!-- Mobile Sidebar Enhancement -->
    <%- include('../partials/mobile-sidebar-head') %>
    
    <style>
        body {
            background: #f5f6fa;
            margin: 0;
        }
        .form-label { font-weight: 600; }

        .trouble-detail-page {
            margin-left: 252px;
            width: calc(100% - 252px);
            min-height: 100vh;
            padding: 28px 28px 40px;
            box-sizing: border-box;
        }

        .trouble-detail-shell {
            width: 100%;
            max-width: 1320px;
            margin: 0 auto;
        }
        
        .card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        }
        
        .page-title {
            font-weight: 700;
            color: #343a40;
            margin-bottom: 0;
        }

        .detail-page-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            flex-wrap: wrap;
            gap: 16px;
            margin: 0 0 24px 0 !important;
            padding: 0 !important;
            min-height: auto !important;
            height: auto !important;
        }

        .detail-page-header p {
            margin: 8px 0 0 0;
        }

        .detail-page-actions {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }
        
        .badge-status {
            padding: 8px 16px;
            border-radius: 50px;
            font-weight: 500;
        }
        
        .detail-label {
            color: #6c757d;
            font-size: 0.9rem;
            margin-bottom: 5px;
        }
        
        .detail-value {
            font-weight: 500;
            margin-bottom: 20px;
        }
        
        .avatar-circle {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 1.5rem;
            margin-right: 15px;
        }
        
        .timeline {
            position: relative;
            padding-left: 30px;
        }
        
        .timeline::before {
            content: '';
            position: absolute;
            left: 10px;
            top: 0;
            height: 100%;
            width: 2px;
            background: #e9ecef;
        }
        
        .timeline-item {
            position: relative;
            padding-bottom: 25px;
        }
        
        .timeline-item:last-child {
            padding-bottom: 0;
        }
        
        .timeline-dot {
            position: absolute;
            left: -30px;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: #3b7ddd;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 0.7rem;
        }
        
        .timeline-content {
            background: #f8f9fa;
            border-radius: 8px;
            padding: 15px;
        }
        
        .btn-action {
            width: 36px;
            height: 36px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            margin-right: 5px;
            transition: all 0.3s ease;
        }
        
        .btn-action:hover {
            transform: translateY(-3px);
        }
        
        /* Mobile responsive improvements */
        @media (max-width: 767.98px) {
            .trouble-detail-page {
                padding: 15px;
                margin: 60px 0 0;
                width: 100%;
            }

            .detail-page-header {
                align-items: stretch;
                margin-bottom: 18px !important;
            }
            
            .page-title {
                font-size: 1.5rem;
            }
            
            .avatar-circle {
                width: 48px;
                height: 48px;
                font-size: 1.2rem;
            }
            
            .timeline {
                padding-left: 20px;
            }
            
            .timeline-dot {
                left: -20px;
                width: 16px;
                height: 16px;
                font-size: 0.6rem;
            }
        }

        @media (min-width: 992px) {
            #adminSidebar.sidebar,
            #technicianSidebar.sidebar,
            .sidebar {
                position: fixed !important;
                top: 0 !important;
                left: 0 !important;
            }
        }

        @media (max-width: 991.98px) {
            .trouble-detail-page {
                margin-left: 0;
                width: 100%;
            }
        }
    </style>
</head>
<body>
    <!-- Include Responsive Sidebar -->
    <% if (typeof isTechnicianView !== 'undefined' && isTechnicianView) { %>
        <%- include('../partials/technician-responsive-sidebar', { page: 'troubletickets', technician: technician }) %>
    <% } else { %>
        <%- include('../partials/admin-responsive-sidebar', { page: 'trouble', settings: settings }) %>
    <% } %>
    
    <main class="trouble-detail-page">
        <div class="trouble-detail-shell">
            <div class="detail-page-header">
                <div>
                    <h1 class="page-title">Detail Laporan Gangguan</h1>
                    <p class="text-muted">Informasi lengkap dan penanganan laporan #<%= report.id %></p>
                </div>
                <div class="detail-page-actions">
                    <% if (typeof isTechnicianView !== 'undefined' && isTechnicianView) { %>
                        <a href="/technician/troubletickets" class="btn btn-outline-secondary rounded-pill me-2">
                            <i class="bi bi-arrow-left me-1"></i> Kembali
                        </a>
                    <% } else { %>
                        <a href="/admin/trouble" class="btn btn-outline-secondary rounded-pill me-2">
                            <i class="bi bi-arrow-left me-1"></i> Kembali
                        </a>
                    <% } %>
                    <a href="https://wa.me/<%= report.phone.replace(/^0/, '62') %>" target="_blank" class="btn btn-success rounded-pill">
                        <i class="bi bi-whatsapp me-1"></i> Hubungi Pelanggan
                    </a>
                </div>
            </div>
            
            <!-- Status dan Info Laporan -->
            <div class="row mb-4">
                <div class="col-md-8">
                    <div class="card mb-4">
                        <div class="card-body">
                            <div class="d-flex align-items-center mb-4">
                                <div class="avatar-circle bg-primary text-white">
                                    <%= report.name.charAt(0).toUpperCase() %>
                                </div>
                                <div>
                                    <h5 class="mb-1"><%= report.name %></h5>
                                    <p class="text-muted mb-0"><i class="bi bi-telephone me-2"></i><%= report.phone %></p>
                                </div>
                                <div class="ms-auto">
                                    <span class="badge badge-status <%= 
                                        report.status === 'open' ? 'bg-danger' : 
                                        report.status === 'in_progress' ? 'bg-warning text-dark' : 
                                        report.status === 'resolved' ? 'bg-success' : 
                                        'bg-secondary' 
                                    %>">
                                        <% if (report.status === 'open') { %>
                                            <i class="bi bi-exclamation-circle me-1"></i>
                                        <% } else if (report.status === 'in_progress') { %>
                                            <i class="bi bi-gear me-1"></i>
                                        <% } else if (report.status === 'resolved') { %>
                                            <i class="bi bi-check-circle me-1"></i>
                                        <% } else { %>
                                            <i class="bi bi-archive me-1"></i>
                                        <% } %>
                                        <%= 
                                            report.status === 'open' ? 'Belum Ditangani' : 
                                            report.status === 'in_progress' ? 'Sedang Ditangani' : 
                                            report.status === 'resolved' ? 'Terselesaikan' : 
                                            'Ditutup' 
                                        %>
                                    </span>
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="detail-label">ID Tiket</div>
                                    <div class="detail-value">#<%= report.id %></div>
                                </div>
                                <div class="col-md-6">
                                    <div class="detail-label">Kategori</div>
                                    <div class="detail-value">
                                        <span class="badge bg-light text-dark rounded-pill px-3 py-2">
                                            <% if (report.category === 'internet') { %>
                                                <i class="bi bi-globe me-1"></i>
                                            <% } else if (report.category === 'wifi') { %>
                                                <i class="bi bi-wifi me-1"></i>
                                            <% } else if (report.category === 'perangkat') { %>
                                                <i class="bi bi-router me-1"></i>
                                            <% } else { %>
                                                <i class="bi bi-question-circle me-1"></i>
                                            <% } %>
                                            <%= report.category %>
                                        </span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="detail-label">Tanggal Laporan</div>
                                    <div class="detail-value">
                                        <i class="bi bi-calendar-event me-2"></i>
                                        <%= new Date(report.createdAt).toLocaleDateString('id-ID') %>
                                        <small class="text-muted ms-2"><%= new Date(report.createdAt).toLocaleTimeString('id-ID') %></small>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="detail-label">Terakhir Diupdate</div>
                                    <div class="detail-value">
                                        <i class="bi bi-clock-history me-2"></i>
                                        <%= new Date(report.updatedAt).toLocaleDateString('id-ID') %>
                                        <small class="text-muted ms-2"><%= new Date(report.updatedAt).toLocaleTimeString('id-ID') %></small>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="detail-label">Prioritas</div>
                                    <div class="detail-value">
                                        <% if (report.priority === 'high') { %>
                                            <span class="badge bg-danger rounded-pill px-3 py-2">
                                                <i class="bi bi-exclamation-triangle me-1"></i> Tinggi
                                            </span>
                                        <% } else if (report.priority === 'medium') { %>
                                            <span class="badge bg-warning text-dark rounded-pill px-3 py-2">
                                                <i class="bi bi-exclamation me-1"></i> Sedang
                                            </span>
                                        <% } else { %>
                                            <span class="badge bg-info text-dark rounded-pill px-3 py-2">
                                                <i class="bi bi-info-circle me-1"></i> Normal
                                            </span>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="mt-4">
                                <div class="detail-label">Deskripsi Masalah</div>
                                <div class="p-3 bg-light rounded">
                                    <%= report.description %>
                                </div>
                            </div>
                            <% if (report.device_photo) { %>
                                <div class="mt-4">
                                    <div class="detail-label">Foto Modem / ONT</div>
                                    <a href="/img/trouble-attachments/<%= report.device_photo %>" target="_blank" class="d-inline-block">
                                        <img src="/img/trouble-attachments/<%= report.device_photo %>" alt="Foto perangkat" class="img-fluid rounded-4 border" style="max-height: 280px; object-fit: cover;">
                                    </a>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
                
                <div class="col-md-4">
                    <div class="card mb-4">
                        <div class="card-body">
                            <h5 class="card-title mb-3"><i class="bi bi-arrow-clockwise me-2"></i>Update Status</h5>
                            <form id="updateStatusForm">
                                <div class="mb-3">
                                    <label for="status" class="form-label">Status Laporan</label>
                                    <div class="status-options">
                                        <div class="form-check form-check-inline status-radio">
                                            <input class="form-check-input" type="radio" name="status" id="statusOpen" value="open" <%= report.status === 'open' ? 'checked' : '' %>>
                                            <label class="form-check-label status-label open" for="statusOpen">
                                                <i class="bi bi-exclamation-circle"></i> Belum Ditangani
                                            </label>
                                        </div>
                                        <div class="form-check form-check-inline status-radio">
                                            <input class="form-check-input" type="radio" name="status" id="statusInProgress" value="in_progress" <%= report.status === 'in_progress' ? 'checked' : '' %>>
                                            <label class="form-check-label status-label in-progress" for="statusInProgress">
                                                <i class="bi bi-gear"></i> Sedang Ditangani
                                            </label>
                                        </div>
                                        <div class="form-check form-check-inline status-radio">
                                            <input class="form-check-input" type="radio" name="status" id="statusResolved" value="resolved" <%= report.status === 'resolved' ? 'checked' : '' %>>
                                            <label class="form-check-label status-label resolved" for="statusResolved">
                                                <i class="bi bi-check-circle"></i> Terselesaikan
                                            </label>
                                        </div>
                                        <div class="form-check form-check-inline status-radio">
                                            <input class="form-check-input" type="radio" name="status" id="statusClosed" value="closed" <%= report.status === 'closed' ? 'checked' : '' %>>
                                            <label class="form-check-label status-label closed" for="statusClosed">
                                                <i class="bi bi-archive"></i> Ditutup
                                            </label>
                                        </div>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label for="notes" class="form-label">Catatan Update</label>
                                    <textarea class="form-control" id="notes" name="notes" rows="4" placeholder="Tambahkan catatan atau update terkait penanganan laporan..." required></textarea>
                                </div>
                                <div class="form-check form-switch mb-3">
                                    <input class="form-check-input" type="checkbox" id="sendNotification" name="sendNotification" checked>
                                    <label class="form-check-label" for="sendNotification">
                                        <i class="bi bi-bell me-1"></i> Kirim notifikasi ke pelanggan
                                    </label>
                                </div>
                                <button type="submit" class="btn btn-primary w-100 rounded-pill">
                                    <i class="bi bi-save me-2"></i> Update Status
                                </button>
                            </form>
                        </div>
                    </div>
                    
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title mb-3"><i class="bi bi-info-circle me-2"></i>Informasi Tambahan</h5>
                            <div class="info-item mb-3">
                                <div class="detail-label">Perangkat</div>
                                <div class="detail-value">
                                    <% if (report.device_id) { %>
                                        <a href="/admin/genieacs/device/<%= report.device_id %>" class="text-decoration-none">
                                            <i class="bi bi-router me-1"></i> <%= report.device_id %>
                                        </a>
                                    <% } else { %>
                                        <span class="text-muted">Tidak ada data perangkat</span>
                                    <% } %>
                                </div>
                            </div>
                            <div class="info-item">
                                <div class="detail-label">Lokasi</div>
                                <div class="detail-value">
                                    <% if (report.location) { %>
                                        <i class="bi bi-geo-alt me-1"></i> <%= report.location %>
                                    <% } else { %>
                                        <span class="text-muted">Tidak ada data lokasi</span>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Timeline Aktivitas -->
            <div class="card mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="card-title mb-0"><i class="bi bi-clock-history me-2"></i>Riwayat Aktivitas</h5>
                        <span class="badge bg-primary rounded-pill"><%= report.notes ? report.notes.length + 1 : 1 %> aktivitas</span>
                    </div>
                    
                    <%
                        const timelineItems = [{
                            timestamp: report.createdAt,
                            authorType: 'customer',
                            authorLabel: report.name || 'Pelanggan',
                            status: 'open',
                            content: `Laporan gangguan dibuat oleh pelanggan melalui ${report.source || 'WhatsApp'}.`,
                            notificationSent: false
                        }];

                        (report.notes || []).forEach((note) => {
                            const rawContent = String(note.content || '').trim();
                            let authorType = 'support';
                            let authorLabel = 'Admin';
                            let content = rawContent;

                            const adminMatch = rawContent.match(/^\[Admin:([^\]]+)\]\s*/i);
                            if (adminMatch) {
                                authorLabel = adminMatch[1].trim() || 'Admin';
                                content = rawContent.replace(/^\[Admin:[^\]]+\]\s*/i, '');
                            } else if (/^\[Teknisi\]:/i.test(rawContent)) {
                                authorLabel = 'Teknisi';
                                content = rawContent.replace(/^\[Teknisi\]:\s*/i, '');
                            } else if (/^\[Pelanggan\]:/i.test(rawContent)) {
                                authorType = 'customer';
                                authorLabel = report.name || 'Pelanggan';
                                content = rawContent.replace(/^\[Pelanggan\]:\s*/i, '');
                            }

                            timelineItems.push({
                                timestamp: note.timestamp,
                                authorType,
                                authorLabel,
                                status: note.status || report.status,
                                content,
                                notificationSent: note.notificationSent
                            });
                        });

                        timelineItems.sort((a, b) => new Date(a.timestamp) - new Date(b.timestamp));
                    %>
                    <div class="timeline">
                        <% if (timelineItems.length > 0) { %>
                            <% timelineItems.forEach(item => { %>
                                <div class="timeline-item">
                                    <div class="timeline-dot <%= 
                                        item.status === 'open' ? 'bg-danger' : 
                                        item.status === 'in_progress' ? 'bg-warning' : 
                                        item.status === 'resolved' ? 'bg-success' : 
                                        'bg-secondary' 
                                    %>">
                                        <i class="bi <%= 
                                            item.authorType === 'customer' ? 'bi-person' :
                                            item.status === 'open' ? 'bi-exclamation' : 
                                            item.status === 'in_progress' ? 'bi-gear' : 
                                            item.status === 'resolved' ? 'bi-check' : 
                                            'bi-archive' 
                                        %>"></i>
                                    </div>
                                    <div class="timeline-content">
                                        <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
                                            <h6 class="mb-0 fw-bold">
                                                <%= item.authorLabel %>
                                                <span class="<%= 
                                                    item.authorType === 'customer' ? 'text-primary' :
                                                    item.status === 'open' ? 'text-danger' : 
                                                    item.status === 'in_progress' ? 'text-warning' : 
                                                    item.status === 'resolved' ? 'text-success' : 
                                                    'text-secondary' 
                                                %> ms-1">
                                                    <%= 
                                                        item.status === 'open' ? 'Belum Ditangani' : 
                                                        item.status === 'in_progress' ? 'Sedang Ditangani' : 
                                                        item.status === 'resolved' ? 'Terselesaikan' : 
                                                        'Ditutup' 
                                                    %>
                                                </span>
                                            </h6>
                                            <span class="badge <%= item.authorType === 'customer' ? 'bg-primary-subtle text-primary' : 'bg-dark-subtle text-dark' %> rounded-pill">
                                                <%= item.authorType === 'customer' ? 'Pelanggan' : 'Support' %>
                                            </span>
                                        </div>
                                        <p class="text-muted small mb-2">
                                            <i class="bi bi-calendar-event me-1"></i> <%= new Date(item.timestamp).toLocaleDateString('id-ID') %>
                                            <i class="bi bi-clock ms-2 me-1"></i> <%= new Date(item.timestamp).toLocaleTimeString('id-ID') %>
                                        </p>
                                        <div class="timeline-message">
                                            <p class="mb-0"><%= item.content %></p>
                                            <% if (item.notificationSent) { %>
                                                <div class="notification-sent mt-2">
                                                    <i class="bi bi-check-circle-fill text-success me-1"></i>
                                                    <small class="text-muted">Notifikasi terkirim ke pelanggan</small>
                                                </div>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <div class="empty-timeline text-center py-4">
                                <i class="bi bi-clock" style="font-size: 2rem; color: #dee2e6;"></i>
                                <p class="text-muted mt-2 mb-0">Belum ada update aktivitas</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
            
        </div>
    </main>

<% if (typeof isTechnicianView !== 'undefined' && isTechnicianView) { %>
    <%- include('../technician/partials/mobile-navbar', { currentPage: 'troubletickets', technician: technician }) %>
<% } %>

<!-- Modal Notifikasi -->
<div class="modal fade" id="notificationModal" tabindex="-1" aria-labelledby="notificationModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="notificationModalLabel">Notifikasi</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="notificationMessage">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal" id="modalOkButton">OK</button>
            </div>
        </div>
    </div>
</div>

<style>
    /* Status Radio Buttons */
    .status-options {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 15px;
    }
    .status-radio {
        margin: 0;
    }
    .status-radio input {
        position: absolute;
        opacity: 0;
        cursor: pointer;
        height: 0;
        width: 0;
    }
    .status-label {
        display: inline-block;
        padding: 8px 15px;
        border-radius: 50px;
        cursor: pointer;
        font-size: 0.9rem;
        transition: all 0.3s ease;
        border: 1px solid #dee2e6;
        background: #f8f9fa;
    }
    .status-label.open {
        color: #dc3545;
    }
    .status-label.in-progress {
        color: #ffc107;
    }
    .status-label.resolved {
        color: #198754;
    }
    .status-label.closed {
        color: #6c757d;
    }
    .status-radio input:checked + .status-label.open {
        background: #dc3545;
        color: white;
        border-color: #dc3545;
    }
    .status-radio input:checked + .status-label.in-progress {
        background: #ffc107;
        color: #212529;
        border-color: #ffc107;
    }
    .status-radio input:checked + .status-label.resolved {
        background: #198754;
        color: white;
        border-color: #198754;
    }
    .status-radio input:checked + .status-label.closed {
        background: #6c757d;
        color: white;
        border-color: #6c757d;
    }
    
    /* Timeline Styling */
    .timeline {
        position: relative;
        padding: 20px 0;
    }
    .timeline::before {
        content: '';
        position: absolute;
        top: 0;
        bottom: 0;
        left: 12px;
        width: 2px;
        background: linear-gradient(to bottom, #dee2e6 0%, #3b7ddd 100%);
        z-index: 1;
    }
    .timeline-item {
        position: relative;
        margin-bottom: 30px;
        padding-left: 40px;
        animation: fadeInRight 0.5s ease-in-out;
    }
    .timeline-item:last-child {
        margin-bottom: 0;
    }
    .timeline-dot {
        position: absolute;
        left: 0;
        width: 24px;
