<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title><%= title %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/responsive-admin.css" rel="stylesheet">
    <style>
        body { background: #eef4ff; }
        .chat-shell {
            background: linear-gradient(180deg, rgba(255,255,255,.95), rgba(246,249,255,.96));
            border: 1px solid rgba(148,163,184,.2);
            border-radius: 28px;
            overflow: hidden;
            box-shadow: 0 24px 48px rgba(37,99,235,.08);
        }
        .chat-header {
            padding: 18px 20px;
            background: linear-gradient(135deg, #6d4bff 0%, #7c3aed 42%, #8b5cf6 100%);
            color: #fff;
        }
        .chat-messages {
            min-height: 60vh;
            max-height: 64vh;
            overflow-y: auto;
            padding: 20px;
            background:
                radial-gradient(circle at top right, rgba(109,75,255,.08), transparent 30%),
                linear-gradient(180deg, rgba(255,255,255,.98), rgba(245,247,255,.98));
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        .chat-bubble {
            max-width: min(78%, 560px);
            border-radius: 20px;
            padding: 12px 14px;
            box-shadow: 0 10px 24px rgba(15,23,42,.07);
        }
        .chat-bubble--admin {
            align-self: flex-end;
            background: linear-gradient(135deg, #3b82f6 0%, #6d4bff 100%);
            color: #fff;
        }
        .chat-bubble--technician {
            align-self: flex-start;
            background: #fff;
            color: #0f172a;
            border: 1px solid rgba(148,163,184,.24);
        }
        .chat-compose {
            padding: 16px 20px;
            background: rgba(255,255,255,.92);
            border-top: 1px solid rgba(148,163,184,.16);
        }
        .chat-empty {
            text-align: center;
            color: #64748b;
            padding: 3rem 1rem;
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <%- include('../partials/admin-responsive-sidebar', { page: 'technicians', settings: settings, versionInfo: versionInfo, versionBadge: versionBadge }) %>
            <main class="col-md-10 ms-sm-auto main-content py-4">
                <div class="mb-3 d-flex justify-content-between align-items-center gap-3">
                    <div>
                        <h2 class="mb-1">Chat Teknisi</h2>
                        <div class="text-muted">Percakapan langsung dengan <strong><%= technician.name %></strong>.</div>
                    </div>
                    <a href="/admin/technicians" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-2"></i>Kembali</a>
                </div>

                <div class="chat-shell">
                    <div class="chat-header d-flex justify-content-between align-items-center gap-3">
                        <div>
                            <div class="fw-bold fs-5"><%= technician.name %></div>
                            <div class="small opacity-75"><%= technician.phone %> | <%= technician.role %></div>
                        </div>
                        <span class="badge text-bg-light"><%= technician.is_active ? 'Aktif' : 'Nonaktif' %></span>
                    </div>

                    <div id="chatMessages" class="chat-messages">
                        <div class="chat-empty">Memuat percakapan...</div>
                    </div>

                    <div class="chat-compose">
                        <form id="chatForm" class="d-flex gap-2">
                            <input type="text" id="chatInput" class="form-control form-control-lg" placeholder="Ketik pesan ke teknisi..." required>
                            <button type="submit" class="btn btn-primary px-4">Kirim</button>
                        </form>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <script>
        const technicianId = <%- JSON.stringify(String(technician.id)) %>;
        let refreshTimer = null;

        function escapeHtml(value) {
            return String(value || '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function formatWib(value) {
            const date = new Date(value);
            if (Number.isNaN(date.getTime())) return '-';
            return new Intl.DateTimeFormat('id-ID', {
                timeZone: 'Asia/Jakarta',
                day: '2-digit',
                month: '2-digit',
                year: 'numeric',
                hour: '2-digit',
                minute: '2-digit',
                second: '2-digit'
            }).format(date) + ' WIB';
        }

        function renderMessages(messages) {
            const wrap = document.getElementById('chatMessages');
            if (!wrap) return;
            if (!Array.isArray(messages) || !messages.length) {
                wrap.innerHTML = '<div class="chat-empty">Belum ada percakapan.</div>';
                return;
            }
            wrap.innerHTML = messages.map((item) => {
                const isAdmin = item.sender_role === 'admin';
                return `
                    <div class="chat-bubble ${isAdmin ? 'chat-bubble--admin' : 'chat-bubble--technician'}">
                        <div class="fw-semibold small mb-1">${isAdmin ? 'Admin' : 'Teknisi'}</div>
                        <div>${escapeHtml(item.message)}</div>
                        <div class="small mt-2 ${isAdmin ? 'text-white-50' : 'text-muted'}">${formatWib(item.created_at)}</div>
                    </div>
                `;
            }).join('');
            wrap.scrollTop = wrap.scrollHeight;
        }

        async function loadMessages() {
            const response = await fetch(`/admin/technicians/${technicianId}/chat/messages`, { cache: 'no-store' });
            const result = await response.json();
            if (!result.success) throw new Error(result.message || 'Gagal memuat percakapan');
            renderMessages(result.messages || []);
        }

        document.getElementById('chatForm').addEventListener('submit', async function (e) {
            e.preventDefault();
            const input = document.getElementById('chatInput');
            const message = input.value.trim();
            if (!message) return;
            const response = await fetch(`/admin/technicians/${technicianId}/chat/messages`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message })
            });
            const result = await response.json();
            if (!result.success) {
                alert(result.message || 'Gagal mengirim pesan');
                return;
            }
            input.value = '';
            await loadMessages();
        });

        loadMessages().catch((error) => {
            document.getElementById('chatMessages').innerHTML = `<div class="chat-empty text-danger">${escapeHtml(error.message)}</div>`;
        });
        refreshTimer = setInterval(() => loadMessages().catch(() => {}), 12000);
    </script>
</body>
</html>
