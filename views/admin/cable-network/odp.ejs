<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Optical Distribution Point (ODP) Management - Admin Portal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/boxicons@2.0.7/css/boxicons.min.css" rel="stylesheet">
    <link href="/css/responsive-admin.css" rel="stylesheet">
    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script>
        document.documentElement.setAttribute('data-theme', localStorage.getItem('theme') || 'light');
    </script>
    <style>
        .dashboard-hero {
            position: relative;
            overflow: hidden;
            border: 1px solid rgba(148, 163, 184, 0.22);
            border-radius: 24px;
            padding: 16px 20px;
            background:
                linear-gradient(145deg, rgba(255,255,255,0.88), rgba(244,247,255,0.82)),
                radial-gradient(circle at top left, rgba(96, 165, 250, 0.22), transparent 38%);
            backdrop-filter: blur(18px);
            box-shadow: 0 18px 44px rgba(37, 99, 235, 0.08);
            margin-bottom: 1.5rem;
        }

        .dashboard-hero::before {
            content: "";
            position: absolute;
            inset: auto -60px -110px auto;
            width: 220px;
            height: 220px;
            border-radius: 999px;
            background: radial-gradient(circle, rgba(96, 165, 250, 0.16), transparent 70%);
            pointer-events: none;
        }

        .dashboard-hero h4 {
            font-size: 2rem;
            font-weight: 800;
            letter-spacing: -0.03em;
            color: #1e293b;
            margin-bottom: 0.4rem;
        }

        .dashboard-hero p {
            color: #64748b;
            margin-bottom: 0;
        }

        [data-theme="dark"] .dashboard-hero {
            background:
                linear-gradient(145deg, rgba(15,23,42,0.88), rgba(17,24,39,0.9)),
                radial-gradient(circle at top left, rgba(56, 189, 248, 0.14), transparent 42%);
            border-color: rgba(148, 163, 184, 0.22);
            box-shadow: 0 20px 42px rgba(2, 8, 23, 0.32);
        }

        [data-theme="dark"] .dashboard-hero h4 {
            color: #f8fafc !important;
        }

        [data-theme="dark"] .dashboard-hero p {
            color: #cbd5e1 !important;
        }

        body .main-content .nav.nav-tabs {
            border-bottom: 1px solid rgba(148, 163, 184, 0.24) !important;
            gap: 1.2rem !important;
        }

        body .main-content .nav.nav-tabs .nav-item {
            margin-bottom: 0 !important;
        }

        body .main-content .nav.nav-tabs .nav-link {
            border: 0 !important;
            border-radius: 0 !important;
            background: transparent !important;
            box-shadow: none !important;
            color: #64748b !important;
            font-weight: 700 !important;
            padding: 0.7rem 0.1rem 0.85rem !important;
            display: inline-flex !important;
            align-items: center !important;
            gap: 0.45rem !important;
            border-bottom: 3px solid transparent !important;
            transform: none !important;
        }

        body .main-content .nav.nav-tabs .nav-link:hover {
            color: #2563eb !important;
        }

        body .main-content .nav.nav-tabs .nav-link.active,
        body .main-content .nav.nav-tabs .show > .nav-link {
            background: transparent !important;
            color: #2563eb !important;
            border-bottom-color: #2563eb !important;
            box-shadow: none !important;
            transform: none !important;
        }

        .tabs-toolbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .theme-toggle-btn {
            width: 42px;
            height: 42px;
            border-radius: 999px;
            border: 1px solid rgba(148, 163, 184, 0.22);
            background: rgba(255, 255, 255, 0.92);
            color: #1e293b;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            flex: 0 0 auto;
        }

        [data-theme="dark"] .theme-toggle-btn {
            background: rgba(15, 23, 42, 0.88);
            color: #e6eefc;
            border-color: rgba(148, 163, 184, 0.24);
        }

        .stats-card {
            border: 0;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
        }

        .stats-card-odps {
            background: linear-gradient(135deg, #06d6a0 0%, #118ab2 100%) !important;
        }

        .stats-card-active {
            background: linear-gradient(135deg, #118ab2 0%, #667eea 100%) !important;
        }

        .stats-card-maintenance {
            background: linear-gradient(135deg, #ffd166 0%, #fd7e14 100%) !important;
        }

        .stats-card-used {
            background: linear-gradient(135deg, #ef476f 0%, #8e44ad 100%) !important;
        }

        .stats-card.stats-card-odps,
        .stats-card.stats-card-active,
        .stats-card.stats-card-maintenance,
        .stats-card.stats-card-used {
            color: #ffffff !important;
            border: 0 !important;
            background-color: transparent !important;
            background-image: inherit !important;
        }

        .stats-card .card-body {
            background: transparent !important;
        }

        [data-theme="dark"] .stats-card.stats-card-odps {
            background: linear-gradient(135deg, #06d6a0 0%, #118ab2 100%) !important;
        }

        [data-theme="dark"] .stats-card.stats-card-active {
            background: linear-gradient(135deg, #118ab2 0%, #667eea 100%) !important;
        }

        [data-theme="dark"] .stats-card.stats-card-maintenance {
            background: linear-gradient(135deg, #ffd166 0%, #fd7e14 100%) !important;
        }

        [data-theme="dark"] .stats-card.stats-card-used {
            background: linear-gradient(135deg, #ef476f 0%, #8e44ad 100%) !important;
        }

        [data-theme="dark"] .stats-card h4,
        [data-theme="dark"] .stats-card p,
        [data-theme="dark"] .stats-card i {
            color: #ffffff !important;
        }

        .odp-card {
            transition: transform 0.2s;
        }

        .odp-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        }

        .progress {
            height: 12px;
            border-radius: 999px;
            background-color: rgba(226, 232, 240, 0.92);
            overflow: hidden;
        }

        .capacity-bar {
            height: 100% !important;
            min-height: 100%;
            border-radius: inherit;
            display: block;
        }

        .odp-icon {
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            font-size: 20px;
        }

        .odp-active {
            background-color: #d1e7dd;
            color: #198754;
        }

        .odp-maintenance {
            background-color: #fff3cd;
            color: #ffc107;
        }

        .odp-inactive {
            background-color: #e2e3e5;
            color: #6c757d;
        }

        @media (max-width: 768px) {
            .dashboard-hero {
                border-radius: 20px;
            }

            .dashboard-hero h4 {
                font-size: 1.75rem;
            }
        }
    </style>
</head>

<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <%- include('../../partials/admin-responsive-sidebar', { page: 'cable-network-odp' , settings: typeof
                settings !=='undefined' ? settings : {} }) %>

                <!-- Main Content -->
                <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4 main-content">
                    <div class="dashboard-hero d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <h4 class="mb-2">ODP</h4>
                            <p>Kelola dan pantau data Optical Distribution Point.</p>
                        </div>
                        <button class="theme-toggle-btn" id="themeToggle" type="button" title="Ganti tema">
                            <i class="bi bi-sun-fill text-warning" id="themeIcon"></i>
                        </button>
                    </div>

                    <!-- Tab Navigation -->
                    <div class="tabs-toolbar">
                        <ul class="nav nav-tabs mb-0">
                            <li class="nav-item">
                                <a class="nav-link <%= page === 'mapping-new' ? 'active' : '' %>"
                                    href="/admin/mapping-new">
                                    <i class="bi bi-map"></i> Network Mapping
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link <%= page === 'cable-network-odp' ? 'active' : '' %>"
                                    href="/admin/cable-network/odp">
                                    <i class="bi bi-broadcast"></i> ODP
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link <%= page === 'cable-network-cables' ? 'active' : '' %>"
                                    href="/admin/cable-network/cables">
                                    <i class="bi bi-cable-car"></i> Cable Routes
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link <%= page === 'cable-network-analytics' ? 'active' : '' %>"
                                    href="/admin/cable-network/analytics">
                                    <i class="bi bi-bar-chart-alt-2"></i> Analytics
                                </a>
                            </li>
                        </ul>
                    </div>

                    <div
                        class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                        <h1 class="h2">Optical Distribution Points (ODP)</h1>
                        <div class="btn-toolbar mb-2 mb-md-0">
                            <button type="button" class="btn btn-sm btn-outline-secondary me-2">
                                <i class="bx bx-download"></i> Export
                            </button>
                            <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal"
                                data-bs-target="#addODPModal">
                                <i class="bx bx-plus"></i> Tambah ODP
                            </button>
                        </div>
                    </div>

                    <!-- Statistics Cards -->
                    <div class="row mb-4">
                        <div class="col-md-3">
                            <div class="card stats-card stats-card-odps text-white" style="background: linear-gradient(135deg, #06d6a0 0%, #118ab2 100%) !important; color: #fff !important;">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between">
                                        <div>
                                            <h4>
                                                <%= odps.length %>
                                            </h4>
                                            <p class="mb-0">Total ODP</p>
                                        </div>
                                        <div class="align-self-center">
                                            <i class="bx bx-server fs-1"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card stats-card stats-card-active text-white" style="background: linear-gradient(135deg, #118ab2 0%, #667eea 100%) !important; color: #fff !important;">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between">
                                        <div>
                                            <h4>
                                                <%= odps.filter(o=> o.status && o.status === 'active').length %>
                                            </h4>
                                            <p class="mb-0">Active ODP</p>
                                        </div>
                                        <div class="align-self-center">
                                            <i class="bx bx-check-circle fs-1"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card stats-card stats-card-maintenance text-white" style="background: linear-gradient(135deg, #ffd166 0%, #fd7e14 100%) !important; color: #fff !important;">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between">
                                        <div>
                                            <h4>
                                                <%= odps.filter(o=> o.status && o.status === 'maintenance').length %>
                                            </h4>
                                            <p class="mb-0">Maintenance</p>
                                        </div>
                                        <div class="align-self-center">
                                            <i class="bx bx-wrench fs-1"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="card stats-card stats-card-used text-white" style="background: linear-gradient(135deg, #ef476f 0%, #8e44ad 100%) !important; color: #fff !important;">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between">
                                        <div>
                                            <h4>
                                                <%= odps.reduce((sum, o)=> sum + (o.used_ports || 0), 0) %>
                                            </h4>
                                            <p class="mb-0">Used Ports</p>
                                        </div>
                                        <div class="align-self-center">
                                            <i class="bx bx-plug fs-1"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ODP List -->
                    <div class="row">
                        <% odps.forEach(odp=> { %>
                            <div class="col-md-6 col-lg-4 mb-4">
                                <div class="card odp-card h-100" data-odp-id="<%= odp.id %>">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-start mb-3">
                                            <div class="d-flex align-items-center">
                                                <div class="odp-icon <%= 'odp-' + odp.status %>">
                                                    <i class="bx bx-broadcast"></i>
                                                </div>
                                                <div class="ms-3">
                                                    <h5 class="mb-0" data-field="name">
                                                        <%= odp.name %>
                                                    </h5>
                                                    <small class="text-muted" data-field="code">
                                                        <%= odp.code %>
                                                    </small>
                                                </div>
                                            </div>
                                            <span
                                                class="badge <%= odp.status === 'active' ? 'bg-success' : odp.status === 'maintenance' ? 'bg-warning' : 'bg-secondary' %> status-badge"
                                                data-field="status">
                                                <%= odp.status ? odp.status.charAt(0).toUpperCase() +
                                                    odp.status.slice(1) : 'Unknown' %>
                                            </span>
                                        </div>

                                        <div class="mb-3">
                                            <small class="text-muted d-block">Address</small>
                                            <p class="mb-1" data-field="address">
                                                <%= odp.address || 'No address' %>
                                            </p>
                                            <% if (odp.parent_name) { %>
                                                <small class="text-info d-block">
                                                    <i class="bx bx-sitemap me-1"></i>
                                                    Sub ODP dari: <strong>
                                                        <%= odp.parent_name %> (<%= odp.parent_code %>)
                                                    </strong>
                                                </small>
                                                <% } else { %>
                                                    <small class="text-success d-block">
                                                        <i class="bx bx-home me-1"></i>
                                                        ODP Utama
                                                    </small>
                                                    <% } %>
                                                        <!-- Hidden data fields for edit functionality -->
                                                        <span data-field="latitude" style="display: none;">
                                                            <%= odp.latitude %>
                                                        </span>
                                                        <span data-field="longitude" style="display: none;">
                                                            <%= odp.longitude %>
                                                        </span>
                                                        <span data-field="parent_odp_id" style="display: none;">
                                                            <%= odp.parent_odp_id || '' %>
                                                        </span>
                                                        <span data-field="notes" style="display: none;">
                                                            <%= odp.notes || '' %>
                                                        </span>
                                                        <span data-field="photo" style="display: none;">
                                                            <%= odp.photo || '' %>
                                                        </span>
                                        </div>

                                        <div class="mb-3">
                                            <div class="d-flex justify-content-between align-items-center mb-1">
                                                <small class="text-muted">Port Usage</small>
                                                <small class="text-muted">
                                                    <%= odp.used_ports || 0 %>/<span data-field="capacity">
                                                            <%= odp.capacity || 0 %>
                                                        </span>
                                                </small>
                                            </div>
                                            <div class="progress">
                                                <% const utilization=((odp.used_ports || 0) / (odp.capacity || 1) *
                                                    100); const barClass=utilization>= 90 ? 'bg-danger' : utilization >=
                                                    70 ? 'bg-warning' : 'bg-success';
                                                    %>
                                                    <div class="progress-bar capacity-bar <%= barClass %>"
                                                        style="--width: <%= utilization %>%; width: var(--width);">
                                                    </div>
                                            </div>
                                        </div>

                                        <div class="mb-3">
                                            <div class="row text-center">
                                                <div class="col-6">
                                                    <div class="border-end">
                                                        <h6 class="mb-0 text-primary">
                                                            <%= odp.connected_customers || 0 %>
                                                        </h6>
                                                        <small class="text-muted">Customers</small>
                                                    </div>
                                                </div>
                                                <div class="col-6">
                                                    <h6 class="mb-0 text-success">
                                                        <%= odp.active_connections || 0 %>
                                                    </h6>
                                                    <small class="text-muted">Active</small>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="d-flex justify-content-between">
                                            <button class="btn btn-sm btn-outline-primary" data-action="edit-odp"
                                                data-odp-id="<%= odp.id %>">
                                                <i class="bx bx-edit"></i> Edit
                                            </button>
                                            <button class="btn btn-sm btn-outline-info" data-action="view-odp-details"
                                                data-odp-id="<%= odp.id %>">
                                                <i class="bx bx-info-circle"></i> Details
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" data-action="delete-odp"
                                                data-odp-id="<%= odp.id %>" <%=(odp.used_ports || 0)> 0 ? 'disabled' :
                                                '' %>>
                                                <i class="bx bx-trash"></i> Delete
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <% }); %>
                    </div>

                    <!-- Add ODP Modal -->
                    <div class="modal fade" id="addODPModal" tabindex="-1">
                        <div class="modal-dialog modal-lg">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">Tambah ODP Baru</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <form id="addODPForm">
                                    <div class="modal-body">
                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="mb-3">
                                                    <label class="form-label">Nama ODP *</label>
                                                    <input type="text" class="form-control" name="name" required>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="mb-3">
                                                    <label class="form-label">Kode ODP *</label>
                                                    <input type="text" class="form-control" name="code" required>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Parent ODP (Sub ODP)</label>
                                            <select class="form-select" name="parent_odp_id">
                                                <option value="">Pilih Parent ODP (Opsional - untuk Sub ODP)</option>
                                                <% if (parentOdps && parentOdps.length> 0) { %>
                                                    <% parentOdps.forEach(function(parentOdp) { %>
                                                        <option value="<%= parentOdp.id %>">
                                                            <%= parentOdp.name %> (<%= parentOdp.code %>) - <%=
                                                                        parentOdp.used_ports %>/<%= parentOdp.capacity
                                                                            %> ports
                                                        </option>
                                                        <% }); %>
                                                            <% } %>
                                            </select>
                                            <small class="form-text text-muted">Pilih Parent ODP jika ini adalah Sub
                                                ODP. Kosongkan jika ini adalah ODP utama.</small>
                                        </div>

                                        <!-- ODP Connection Section -->
                                        <div class="card border-info mb-3">
                                            <div class="card-header bg-info text-white">
                                                <h6 class="mb-0"><i class="bx bx-link me-2"></i>Koneksi Kabel ODP</h6>
                                            </div>
                                            <div class="card-body">
                                                <div class="form-check mb-3">
                                                    <input class="form-check-input" type="checkbox"
                                                        id="enableODPConnection" name="enable_connection">
                                                    <label class="form-check-label" for="enableODPConnection">
                                                        <strong>Buat koneksi kabel langsung ke ODP yang sudah
                                                            ada</strong>
                                                    </label>
                                                </div>

                                                <div id="odpConnectionFields" style="display: none;">
                                                    <div class="row">
                                                        <div class="col-md-6">
                                                            <div class="mb-3">
                                                                <label class="form-label">ODP Awal (Sumber) *</label>
                                                                <select class="form-select" name="from_odp_id"
                                                                    id="fromOdpSelect">
                                                                    <option value="">Pilih ODP Awal</option>
                                                                    <% if (parentOdps && parentOdps.length> 0) { %>
                                                                        <% parentOdps.forEach(function(odp) { %>
                                                                            <option value="<%= odp.id %>"
                                                                                data-lat="<%= odp.latitude %>"
                                                                                data-lng="<%= odp.longitude %>">
                                                                                <%= odp.name %> (<%= odp.code %>) - <%=
                                                                                            odp.used_ports %>/<%=
                                                                                                odp.capacity %> ports
                                                                            </option>
                                                                            <% }); %>
                                                                                <% } %>
                                                                </select>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-6">
                                                            <div class="mb-3">
                                                                <label class="form-label">Jenis Koneksi</label>
                                                                <select class="form-select" name="connection_type">
                                                                    <option value="fiber">Fiber Optic</option>
                                                                    <option value="copper">Copper</option>
                                                                    <option value="wireless">Wireless</option>
                                                                    <option value="microwave">Microwave</option>
                                                                </select>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="row">
                                                        <div class="col-md-6">
                                                            <div class="mb-3">
                                                                <label class="form-label">Kapasitas Kabel</label>
                                                                <select class="form-select" name="cable_capacity">
                                                                    <option value="100M">100 Mbps</option>
                                                                    <option value="1G" selected>1 Gbps</option>
                                                                    <option value="10G">10 Gbps</option>
                                                                    <option value="100G">100 Gbps</option>
                                                                </select>
                                                            </div>
                                                        </div>
                                                        <div class="col-md-6">
                                                            <div class="mb-3">
                                                                <label class="form-label">Status Koneksi</label>
                                                                <select class="form-select" name="connection_status">
                                                                    <option value="active" selected>Aktif</option>
                                                                    <option value="maintenance">Maintenance</option>
                                                                    <option value="inactive">Tidak Aktif</option>
                                                                </select>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="mb-3">
                                                        <label class="form-label">Catatan Koneksi</label>
                                                        <textarea class="form-control" name="connection_notes" rows="2"
                                                            placeholder="Catatan untuk koneksi kabel ODP..."></textarea>
                                                    </div>
                                                    <div class="mb-3">
                                                        <label class="form-label">Panjang Kabel (meter)</label>
                                                        <input type="number" class="form-control" name="cable_length"
                                                            id="cableLengthField" step="0.01"
                                                            placeholder="Akan dihitung otomatis" readonly>
                                                        <small class="form-text text-muted">Panjang kabel akan dihitung
                                                            otomatis berdasarkan jarak antara ODP awal dan ODP
                                                            baru</small>
                                                    </div>
                                                    <div class="alert alert-info">
                                                        <i class="bx bx-info-circle me-2"></i>
