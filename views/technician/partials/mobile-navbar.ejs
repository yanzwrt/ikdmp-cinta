}

.technician-notification-item.is-unread {
    background: linear-gradient(135deg, rgba(109, 75, 255, 0.08), rgba(168, 85, 247, 0.04));
    border-color: rgba(109, 75, 255, 0.2);
}

.technician-notification-item__icon {
    width: 40px;
