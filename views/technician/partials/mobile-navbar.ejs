<%
    const techHeaderName = technician?.name || 'Teknisi';
    const techHeaderMeta = technician?.phone || technician?.username || 'technician';
    const techHeaderPhoto = technician?.profile_photo ? `/img/technician-profiles/${technician.profile_photo}` : '';
    const techHeaderInitial = String(techHeaderName || 'T').trim().charAt(0).toUpperCase();
%>
<div class="technician-mobile-topbar d-md-none">
    <div class="technician-mobile-topbar__identity">
        <div class="technician-mobile-topbar__avatar">
            <% if (techHeaderPhoto) { %>
                <img src="<%= techHeaderPhoto %>" alt="Foto Profil <%= techHeaderName %>">
            <% } else { %>
                <span><%= techHeaderInitial %></span>
            <% } %>
        </div>
        <div class="technician-mobile-topbar__text">
            <strong><%= techHeaderName %></strong>
            <small><%= techHeaderMeta %></small>
        </div>
    </div>
    <div class="d-flex align-items-center gap-2">
        <a href="/technician/chat" class="technician-mobile-topbar__action text-decoration-none" aria-label="Chat admin">
            <i class="bx bx-message-rounded-dots"></i>
        </a>
        <button type="button" class="technician-mobile-topbar__action" id="technicianNotificationToggle" aria-label="Notifikasi teknisi">
            <i class="bx bx-bell"></i>
            <span class="technician-mobile-topbar__badge d-none" id="technicianTopbarBadge">0</span>
        </button>
    </div>
</div>

<div class="technician-notification-overlay d-md-none" id="technicianNotificationOverlay"></div>
<div class="technician-notification-panel d-md-none" id="technicianNotificationPanel" aria-hidden="true">
    <div class="technician-notification-panel__header">
        <div>
            <h5>Notifikasi Teknisi</h5>
            <p>Gangguan, perangkat offline, dan tugas baru.</p>
        </div>
        <button type="button" class="technician-notification-panel__close" id="technicianNotificationClose" aria-label="Tutup notifikasi">
            <i class="bx bx-x"></i>
        </button>
    </div>
    <div class="technician-notification-list" id="technicianNotificationList"></div>
</div>

<nav class="mobile-bottom-nav">
    <div class="nav-item" onclick="navigateTo('/technician/dashboard')">
        <div class="nav-icon <%= currentPage === 'dashboard' ? 'active' : '' %>">
            <i class="bx bx-home"></i>
        </div>
        <span class="nav-label">Dashboard</span>
    </div>
    <div class="nav-item" onclick="navigateTo('/technician/mobile/mapping')">
        <div class="nav-icon <%= currentPage === 'mapping' ? 'active' : '' %>">
            <i class="bx bx-map"></i>
        </div>
        <span class="nav-label">Mapping</span>
    </div>
    <div class="nav-item" onclick="navigateTo('/technician/odp')">
        <div class="nav-icon <%= currentPage === 'odp' ? 'active' : '' %>">
            <i class="bx bx-layer"></i>
        </div>
        <span class="nav-label">ODP</span>
    </div>
    <div class="nav-item" onclick="navigateTo('/technician/mobile/customers')">
        <div class="nav-icon <%= currentPage === 'customers' ? 'active' : '' %>">
            <i class="bx bx-user"></i>
        </div>
        <span class="nav-label">Customer</span>
    </div>
    <div class="nav-item" onclick="navigateTo('/technician/troubletickets')">
        <div class="nav-icon <%= currentPage === 'troubletickets' ? 'active' : '' %>">
            <i class="bx bx-error-circle"></i>
            <span class="tech-nav-badge d-none" id="technicianTroubleBadge">0</span>
        </div>
        <span class="nav-label">Gangguan</span>
    </div>
    <div class="nav-item" onclick="navigateTo('/technician/installations')">
        <div class="nav-icon <%= currentPage === 'installations' ? 'active' : '' %>">
            <i class="bx bx-wrench"></i>
        </div>
        <span class="nav-label">Tiket</span>
    </div>
    <div class="nav-item" onclick="navigateTo('/technician/settings')">
        <div class="nav-icon <%= currentPage === 'settings' ? 'active' : '' %>">
            <i class="bx bx-cog"></i>
        </div>
        <span class="nav-label">Setting</span>
    </div>
</nav>

<style>
