}

.technician-notification-item__content p {
    margin: 0 0 6px;
    color: #475569;
    font-size: 0.86rem;
    line-height: 1.45;
}

.technician-notification-item__content small {
    color: #64748b;
    font-size: 0.76rem;
}

.technician-notification-item__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 3px 8px;
    border-radius: 999px;
    background: #ef4444;
    color: #fff;
