}

@media (min-width: 769px) {
    .technician-mobile-topbar,
    .technician-notification-overlay,
    .technician-notification-panel {
        display: none !important;
    }
    .mobile-bottom-nav {
        display: none !important;
    }
    body {
        padding-bottom: 0 !important;
    }
}

@media (max-width: 768px) {
    body {
        padding-top: 84px !important;
        padding-bottom: 104px !important;
    }
    .navbar-tech {
        display: none !important;
    }
}
</style>

<script>
function navigateTo(url) {
    setTimeout(() => {
        window.location.href = url;
    }, 120);
}

(function () {
    const readStorageKey = 'technicianNotificationReadMap';
    const lastUnreadKey = 'technicianNotificationLastUnread';
    const bellBtn = document.getElementById('technicianNotificationToggle');
    const panel = document.getElementById('technicianNotificationPanel');
    const overlay = document.getElementById('technicianNotificationOverlay');
    const listWrap = document.getElementById('technicianNotificationList');

    function getReadMap() {
        try { return JSON.parse(localStorage.getItem(readStorageKey) || '{}') || {}; }
        catch (error) { return {}; }
    }

    function setReadMap(map) {
        localStorage.setItem(readStorageKey, JSON.stringify(map || {}));
    }

    function getLastUnreadCount() {
        return Number(localStorage.getItem(lastUnreadKey) || '0');
    }

    function setLastUnreadCount(count) {
        localStorage.setItem(lastUnreadKey, String(Number(count || 0)));
    }

    function normalize(items) {
        return Array.isArray(items) ? items.filter(Boolean).map((item) => ({
            id: String(item.id || ''),
            title: String(item.title || 'Notifikasi Teknisi'),
            message: String(item.message || ''),
            type: String(item.type || 'info'),
            link: String(item.link || '/technician/dashboard'),
            updatedAt: String(item.updatedAt || item.createdAt || ''),
            createdAt: String(item.createdAt || item.updatedAt || ''),
            marker: String(item.marker || item.updatedAt || item.createdAt || '')
        })).filter((item) => item.id) : [];
    }

    function getUnread(items) {
        const readMap = getReadMap();
        return normalize(items).filter((item) => readMap[item.id] !== item.marker);
    }

    function markSingleRead(id, marker) {
        const readMap = getReadMap();
        readMap[String(id)] = String(marker || new Date().toISOString());
        setReadMap(readMap);
    }

    function renderBadges(count) {
        ['technicianTopbarBadge', 'technicianTroubleBadge'].forEach((id) => {
            const badge = document.getElementById(id);
            if (!badge) return;
            if (count > 0) {
                badge.textContent = count > 9 ? '9+' : String(count);
                badge.classList.remove('d-none');
            } else {
                badge.classList.add('d-none');
            }
        });
    }

    function iconFor(type) {
        if (type === 'chat') return 'bx bx-message-rounded-dots';
        if (type === 'offline') return 'bx bx-wifi-off';
        if (type === 'installation') return 'bx bx-wrench';
        return 'bx bx-bell';
    }

    function renderList(items) {
        const unreadIds = new Set(getUnread(items).map((item) => item.id));
        if (!listWrap) return;
        if (!items.length) {
            listWrap.innerHTML = '<div class="technician-notification-empty"><i class="bx bx-bell-off mb-2"></i><div>Belum ada notifikasi</div></div>';
            return;
        }
        listWrap.innerHTML = items.map((item) => `
            <a href="${item.link}" class="technician-notification-item ${unreadIds.has(item.id) ? 'is-unread' : ''}" data-technician-notification-id="${item.id}" data-technician-notification-marker="${item.marker}">
                <div class="technician-notification-item__icon"><i class="${iconFor(item.type)}"></i></div>
                <div class="technician-notification-item__content">
                    <div class="technician-notification-item__top">
                        <h6>${item.title}</h6>
                        ${unreadIds.has(item.id) ? '<span class="technician-notification-item__badge">Baru</span>' : ''}
                    </div>
                    <p>${item.message}</p>
                    <small>${item.updatedAt ? new Date(item.updatedAt).toLocaleString('id-ID') : ''}</small>
                </div>
            </a>
        `).join('');
    }

    function playNotificationSound() {
        try {
            const AudioCtx = window.AudioContext || window.webkitAudioContext;
            if (!AudioCtx) return;
            const audioContext = new AudioCtx();
            const oscillator = audioContext.createOscillator();
            const gainNode = audioContext.createGain();
            oscillator.type = 'sine';
            oscillator.frequency.setValueAtTime(740, audioContext.currentTime);
            oscillator.frequency.exponentialRampToValueAtTime(1047, audioContext.currentTime + 0.14);
            gainNode.gain.setValueAtTime(0.0001, audioContext.currentTime);
            gainNode.gain.exponentialRampToValueAtTime(0.08, audioContext.currentTime + 0.03);
            gainNode.gain.exponentialRampToValueAtTime(0.0001, audioContext.currentTime + 0.34);
            oscillator.connect(gainNode);
            gainNode.connect(audioContext.destination);
            oscillator.start();
            oscillator.stop(audioContext.currentTime + 0.36);
        } catch (error) {
            console.warn('Suara notifikasi teknisi gagal diputar:', error);
        }
    }

    function openPanel() {
        if (panel) panel.classList.add('is-open');
        if (overlay) overlay.classList.add('is-open');
    }

    function closePanel() {
        if (panel) panel.classList.remove('is-open');
        if (overlay) overlay.classList.remove('is-open');
    }

    async function refreshSummary() {
        try {
            const response = await fetch('/technician/notifications/summary', { headers: { Accept: 'application/json' }, cache: 'no-store' });
            if (!response.ok) return;
            const payload = await response.json();
            if (!payload.success) return;
            const notifications = normalize(payload.notifications);
            const unread = getUnread(notifications);
            const previousUnread = getLastUnreadCount();
            renderBadges(unread.length);
            renderList(notifications);
            if (unread.length > previousUnread && previousUnread > 0) {
                playNotificationSound();
            }
            setLastUnreadCount(unread.length);
        } catch (error) {
            console.warn('Gagal memuat notifikasi teknisi:', error);
        }
    }

    document.addEventListener('DOMContentLoaded', function() {
        const currentPath = window.location.pathname;
        document.querySelectorAll('.nav-item').forEach((item) => {
            const label = item.querySelector('.nav-label')?.textContent;
            const icon = item.querySelector('.nav-icon');
            if (!icon) return;
            icon.classList.remove('active');
            if (currentPath.includes('/dashboard') && label === 'Dashboard') icon.classList.add('active');
            else if (currentPath.includes('/mapping') && label === 'Mapping') icon.classList.add('active');
            else if (currentPath.includes('/odp') && label === 'ODP') icon.classList.add('active');
            else if (currentPath.includes('/customers') && label === 'Customer') icon.classList.add('active');
            else if (currentPath.includes('/troubletickets') && label === 'Gangguan') icon.classList.add('active');
            else if (currentPath.includes('/installations') && label === 'Tiket') icon.classList.add('active');
            else if (currentPath.includes('/settings') && label === 'Setting') icon.classList.add('active');
        });

        refreshSummary();
        setInterval(refreshSummary, 30000);
    });

    if (bellBtn) {
        bellBtn.addEventListener('click', function(event) {
            event.preventDefault();
            event.stopPropagation();
            if (panel && panel.classList.contains('is-open')) closePanel();
            else openPanel();
        });
    }

    document.addEventListener('click', function(event) {
        const item = event.target.closest('[data-technician-notification-id]');
        if (item) {
            markSingleRead(item.getAttribute('data-technician-notification-id'), item.getAttribute('data-technician-notification-marker'));
            setTimeout(refreshSummary, 50);
            closePanel();
            return;
        }
        if (event.target.closest('#technicianNotificationClose') || event.target.closest('#technicianNotificationOverlay')) {
            closePanel();
        }
    });
})();
</script>
