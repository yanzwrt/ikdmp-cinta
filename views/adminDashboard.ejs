            <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
                        <script>
                        // Grafik bandwidth real-time modern
            const maxPoints = 30;
            let currentInterface = localStorage.getItem('selectedInterface') || 'ether1-ISP';
            
            function formatBandwidth(bytesPerSec) {
              if (!bytesPerSec || isNaN(bytesPerSec)) return '0 bps';
              if (bytesPerSec >= 1000000000) return (bytesPerSec / 1000000000).toFixed(2) + ' Gbps';
              if (bytesPerSec >= 1000000) return (bytesPerSec / 1000000).toFixed(2) + ' Mbps';
              if (bytesPerSec >= 1000) return (bytesPerSec / 1000).toFixed(2) + ' Kbps';
              return Math.floor(bytesPerSec) + ' bps';
            }

            function createAreaGradient(ctx, rgbColor) {
              const gradient = ctx.createLinearGradient(0, 0, 0, 260);
              gradient.addColorStop(0, `rgba(${rgbColor}, 0.35)`);
              gradient.addColorStop(0.65, `rgba(${rgbColor}, 0.12)`);
              gradient.addColorStop(1, `rgba(${rgbColor}, 0.02)`);
              return gradient;
            }

            function getChartBaseOptions() {
              return {
                responsive: true,
                maintainAspectRatio: false,
                animation: { duration: 520, easing: 'easeOutCubic' },
                interaction: { mode: 'index', intersect: false },
                plugins: {
                  legend: {
                    display: true,
                    position: 'top',
                    labels: {
                      padding: 12,
                      usePointStyle: true,
                      pointStyle: 'circle',
                      color: '#64748b',
                      font: { size: 12, weight: '600' }
                    }
                  },
                  tooltip: {
                    mode: 'index',
                    intersect: false,
                    backgroundColor: 'rgba(15,23,42,0.92)',
                    titleColor: '#ffffff',
                    bodyColor: '#e2e8f0',
                    borderColor: 'rgba(148,163,184,0.35)',
                    borderWidth: 1,
                    cornerRadius: 12,
                    padding: 12,
                    callbacks: {
                      label: function(context) {
                        return `${context.dataset.label}: ${formatBandwidth(context.parsed.y)}`;
                      }
                    }
                  }
                },
                scales: {
                  y: {
                    beginAtZero: true,
                    title: { display: true, text: 'Bandwidth', color: '#64748b', font: { size: 12, weight: '700' } },
                    ticks: {
                      callback: (v) => formatBandwidth(v),
                      color: '#64748b',
                      font: { size: 10, weight: '600' },
                      maxTicksLimit: 8
                    },
                    grid: { color: 'rgba(148,163,184,0.16)', drawBorder: false }
                  },
                  x: {
                    title: { display: true, text: 'Time', color: '#64748b', font: { size: 12, weight: '700' } },
                    ticks: { color: '#94a3b8', font: { size: 10, weight: '600' }, maxTicksLimit: 6 },
                    grid: { display: false, drawBorder: false },
                    min: 0,
                    max: maxPoints - 1
                  }
                },
                elements: {
                  point: { radius: 0, hoverRadius: 5, hitRadius: 16 },
                  line: { borderWidth: 3, tension: 0.42, cubicInterpolationMode: 'monotone' }
                }
              };
            }

            let rxChart, txChart, combinedChart, trafficShareChart, trafficTrendChart;
            let trendTotals = [];

            const rxCtx = document.getElementById('rxChart').getContext('2d');
            const txCtx = document.getElementById('txChart').getContext('2d');
            const combinedCtx = document.getElementById('combinedChart').getContext('2d');
            const shareCtx = document.getElementById('trafficShareChart').getContext('2d');
            const trendCtx = document.getElementById('trafficTrendChart').getContext('2d');

            function createRealtimeCharts() {
              const base = { type: 'line', options: getChartBaseOptions() };

              rxChart = new Chart(rxCtx, {
                ...base,
                data: {
                  labels: [],
                  datasets: [{
                    label: 'Download (RX)',
                    data: [],
                    fill: true,
                    backgroundColor: createAreaGradient(rxCtx, '13,202,240'),
                    borderColor: '#0dcaf0',
                    pointBackgroundColor: '#0dcaf0',
                    pointBorderColor: '#ffffff'
                  }]
                }
              });

              txChart = new Chart(txCtx, {
                ...base,
                data: {
                  labels: [],
                  datasets: [{
                    label: 'Upload (TX)',
                    data: [],
                    fill: true,
                    backgroundColor: createAreaGradient(txCtx, '34,197,94'),
                    borderColor: '#22c55e',
                    pointBackgroundColor: '#22c55e',
                    pointBorderColor: '#ffffff'
                  }]
                }
              });

              combinedChart = new Chart(combinedCtx, {
                ...base,
                data: {
                  labels: [],
                  datasets: [
                    {
                      type: 'bar',
                      label: 'Total',
                      data: [],
                      backgroundColor: 'rgba(99,102,241,0.18)',
                      borderColor: 'rgba(99,102,241,0.38)',
                      borderWidth: 1,
                      borderRadius: 8,
                      barPercentage: 0.72,
                      categoryPercentage: 0.74,
                      order: 3
                    },
                    {
                      label: 'Download (RX)',
                      data: [],
                      fill: false,
                      borderColor: '#0dcaf0',
                      borderWidth: 2.5,
                      order: 1
                    },
                    {
                      label: 'Upload (TX)',
                      data: [],
                      fill: false,
                      borderColor: '#22c55e',
                      borderWidth: 2.5,
                      order: 2
                    }
                  ]
                }
              });

              trafficShareChart = new Chart(shareCtx, {
                type: 'doughnut',
                data: {
                  labels: ['Download', 'Upload'],
                  datasets: [{
                    data: [1, 1],
                    backgroundColor: ['rgba(13,202,240,0.85)', 'rgba(34,197,94,0.85)'],
                    borderColor: ['#0dcaf0', '#22c55e'],
                    borderWidth: 1
                  }]
                },
                options: {
                  responsive: true,
                  maintainAspectRatio: false,
                  cutout: '66%',
                  plugins: {
                    legend: { position: 'bottom', labels: { usePointStyle: true, color: '#64748b' } },
                    tooltip: {
                      callbacks: {
                        label: (ctx) => `${ctx.label}: ${formatBandwidth(ctx.parsed)}`
                      }
                    }
                  }
                }
              });

              trafficTrendChart = new Chart(trendCtx, {
                type: 'bar',
                data: {
                  labels: [],
                  datasets: [{
                    label: 'Total Trend',
                    data: [],
                    backgroundColor: 'rgba(99,102,241,0.32)',
                    borderColor: '#6366f1',
                    borderWidth: 1,
                    borderRadius: 6
                  }]
                },
                options: {
                  responsive: true,
                  maintainAspectRatio: false,
                  plugins: { legend: { display: false } },
                  scales: {
                    y: { beginAtZero: true, ticks: { callback: (v) => formatBandwidth(v), color: '#64748b', maxTicksLimit: 6 }, grid: { color: 'rgba(148,163,184,0.14)' } },
                    x: { ticks: { display: false }, grid: { display: false } }
                  }
                }
              });
            }

            function applyChartStyle() {
              const rxDs = rxChart.data.datasets[0];
              const txDs = txChart.data.datasets[0];
              const cTotal = combinedChart.data.datasets[0];
              const cRx = combinedChart.data.datasets[1];
              const cTx = combinedChart.data.datasets[2];

              rxChart.config.type = 'line';
              txChart.config.type = 'line';

              rxDs.borderColor = '#0dcaf0';
              txDs.borderColor = '#22c55e';
              rxDs.backgroundColor = createAreaGradient(rxCtx, '13,202,240');
              txDs.backgroundColor = createAreaGradient(txCtx, '34,197,94');
              rxDs.fill = true;
              txDs.fill = true;

              cTotal.hidden = false;
              cRx.borderColor = '#0dcaf0';
              cTx.borderColor = '#22c55e';
              cRx.fill = false;
              cTx.fill = false;

              [rxChart, txChart, combinedChart].forEach(ch => {
                ch.options.scales.x.grid.display = false;
                ch.options.scales.y.grid.color = 'rgba(148,163,184,0.16)';
              });

              rxChart.update('none');
              txChart.update('none');
              combinedChart.update('none');
            }
            function updateExtraCharts(rxValue, txValue) {
              trafficShareChart.data.datasets[0].data = [Math.max(0, rxValue), Math.max(0, txValue)];
              trafficShareChart.update('none');

              const total = rxValue + txValue;
              trendTotals.push(total);
              if (trendTotals.length > maxPoints) trendTotals.shift();

              trafficTrendChart.data.labels = trendTotals.map((_, idx) => idx + 1);
              trafficTrendChart.data.datasets[0].data = [...trendTotals];
              adjustChartYAxis(trafficTrendChart);
              trafficTrendChart.update('none');
            }

            function adjustChartYAxis(chart) {
              if (!chart || !chart.data || !chart.data.datasets || chart.data.datasets.length === 0) return;
              let allData = [];
              chart.data.datasets.forEach(ds => {
                if (Array.isArray(ds.data)) allData = allData.concat(ds.data.filter(v => typeof v === 'number' && !isNaN(v)));
              });
              if (!allData.length) return;

              const maxValue = Math.max(...allData);
              if (!isFinite(maxValue) || maxValue <= 0) {
                chart.options.scales.y.min = 0;
                chart.options.scales.y.max = 1;
                chart.options.scales.y.ticks.stepSize = 0.2;
                return;
              }

              const targetTicks = 7;
              const roughStep = maxValue / targetTicks;
              const magnitude = Math.pow(10, Math.floor(Math.log10(roughStep)));
              const normalized = roughStep / magnitude;

              let niceNormalized;
              if (normalized <= 1) niceNormalized = 1;
              else if (normalized <= 2) niceNormalized = 2;
              else if (normalized <= 2.5) niceNormalized = 2.5;
              else if (normalized <= 5) niceNormalized = 5;
              else niceNormalized = 10;

              const stepSize = niceNormalized * magnitude;
              const yMax = Math.ceil(maxValue / stepSize) * stepSize;

              chart.options.scales.y.min = 0;
              chart.options.scales.y.max = yMax;
              chart.options.scales.y.ticks.stepSize = stepSize;
              chart.options.scales.y.ticks.maxTicksLimit = 8;
            }

            function updateChart(chart, label, value) {
              if (chart.data.labels.length >= maxPoints) {
                chart.data.labels.shift();
                chart.data.datasets[0].data.shift();
              }
              chart.data.labels.push(label);
              chart.data.datasets[0].data.push(parseFloat(value));

              if (chart.data.labels.length >= maxPoints) {
                chart.options.scales.x.min = chart.data.labels.length - maxPoints;
                chart.options.scales.x.max = chart.data.labels.length - 1;
              }

              adjustChartYAxis(chart);
              chart.update('none');
            }

            function updateCombinedChart(label, rxValue, txValue) {
              if (combinedChart.data.labels.length >= maxPoints) {
                combinedChart.data.labels.shift();
                combinedChart.data.datasets[0].data.shift();
                combinedChart.data.datasets[1].data.shift();
                combinedChart.data.datasets[2].data.shift();
              }

              combinedChart.data.labels.push(label);
              combinedChart.data.datasets[0].data.push(parseFloat(rxValue + txValue));
              combinedChart.data.datasets[1].data.push(parseFloat(rxValue));
              combinedChart.data.datasets[2].data.push(parseFloat(txValue));

              if (combinedChart.data.labels.length >= maxPoints) {
                combinedChart.options.scales.x.min = combinedChart.data.labels.length - maxPoints;
                combinedChart.options.scales.x.max = combinedChart.data.labels.length - 1;
              }

              adjustChartYAxis(combinedChart);
              combinedChart.update('none');
            }

            function updateAllCharts(label, rxBytes, txBytes) {
              updateChart(rxChart, label, rxBytes);
              updateChart(txChart, label, txBytes);
              updateCombinedChart(label, rxBytes, txBytes);
              updateExtraCharts(rxBytes, txBytes);
            }

            function addTrafficData(rx, tx, interface) {
              const now = new Date();
              const label = now.toLocaleTimeString('id-ID', { hour12: false });
              const rxBytes = parseInt(rx) || 0;
              const txBytes = parseInt(tx) || 0;

              document.getElementById('currentRx').textContent = formatBandwidth(rxBytes);
              document.getElementById('currentTx').textContent = formatBandwidth(txBytes);
              document.getElementById('currentTotal').textContent = formatBandwidth(rxBytes + txBytes);

              const statusElement = document.getElementById('currentStatus');
              const containerDiv = document.getElementById('trafficStatusCard') || statusElement.closest('.p-3');
              const totalMbps = (rxBytes + txBytes) / 1000000;
              statusElement.className = 'mb-0 fw-bold text-white';

              if (totalMbps > 1000) {
                statusElement.textContent = 'Ultra High';
                containerDiv.className = 'p-3 rounded-3 live-metric-card metric-status ultra-high h-100';
              } else if (totalMbps > 500) {
                statusElement.textContent = 'Very High';
                containerDiv.className = 'p-3 rounded-3 live-metric-card metric-status very-high h-100';
              } else if (totalMbps > 100) {
                statusElement.textContent = 'High';
                containerDiv.className = 'p-3 rounded-3 live-metric-card metric-status high h-100';
              } else if (totalMbps > 10) {
                statusElement.textContent = 'Medium';
                containerDiv.className = 'p-3 rounded-3 live-metric-card metric-status medium h-100';
              } else if (totalMbps > 1) {
                statusElement.textContent = 'Low';
                containerDiv.className = 'p-3 rounded-3 live-metric-card metric-status low h-100';
              } else {
                statusElement.textContent = 'Idle';
                containerDiv.className = 'p-3 rounded-3 live-metric-card metric-status idle h-100';
              }

              updateAllCharts(label, rxBytes, txBytes);
            }

            function resetAllCharts() {
              rxChart.data.labels = [];
              rxChart.data.datasets[0].data = [];
              rxChart.update('none');

              txChart.data.labels = [];
              txChart.data.datasets[0].data = [];
              txChart.update('none');

              combinedChart.data.labels = [];
              combinedChart.data.datasets[0].data = [];
              combinedChart.data.datasets[1].data = [];
              combinedChart.data.datasets[2].data = [];
              combinedChart.update('none');

              trendTotals = [];
              trafficTrendChart.data.labels = [];
              trafficTrendChart.data.datasets[0].data = [];
              trafficTrendChart.update('none');

              trafficShareChart.data.datasets[0].data = [1, 1];
              trafficShareChart.update('none');
            }

            createRealtimeCharts();
            applyChartStyle();

async function fetchTraffic() {
  try {
    const res = await fetch(`/api/dashboard/traffic?interface=${currentInterface}`);
    const data = await res.json();
    if (data.success) {
      // Gunakan requestAnimationFrame untuk update yang lebih smooth
      requestAnimationFrame(() => {
        addTrafficData(data.rx, data.tx, data.interface);
      });
    }
  } catch (e) { 
    console.error('Error fetching traffic data:', e);
  }
}

// Load interface secara dinamis dari Mikrotik
async function loadInterfaces() {
  try {
    console.log('Info dashboard.');
    const response = await fetch('/api/dashboard/interfaces');
    const data = await response.json();
    
    console.log('Info dashboard.');
    
    if (data.success && data.interfaces && data.interfaces.length > 0) {
      const select = document.getElementById('interfaceSelect');
      
      // Hapus semua option kecuali yang pertama (default)
      while (select.children.length > 1) {
        select.removeChild(select.lastChild);
      }
      
      // Tambahkan interface yang terdeteksi
      data.interfaces.forEach(iface => {
        const option = document.createElement('option');
        option.value = iface.name;
        
        // Buat label yang informatif
        let label = iface.name;
        
        // Tambahkan label khusus untuk interface tertentu
        if (iface.name === 'ether1-ISP') {
          label = 'ether1-ISP (ISP)';
        } else if (iface.name === 'ether2-CADANGAN ISP') {
          label = 'ether2-CADANGAN ISP (Backup)';
        } else if (iface.name === 'ether3-LOKAL') {
          label = 'ether3-LOKAL (Local)';
        } else if (iface.name === 'ether4-LOKAL-LEPTOP') {
          label = 'ether4-LOKAL-LEPTOP (Laptop)';
        } else if (iface.name === 'ether5-LOKAL-REMOT OLT') {
          label = 'ether5-LOKAL-REMOT OLT (Remote)';
        } else if (iface.name === 'ether6-OLT-SFP1-TANJUNGPURA') {
          label = 'ether6-OLT-SFP1-TANJUNGPURA (OLT1)';
        } else if (iface.name === 'ether7-OLT-SFP2-TANJUNGPURA2') {
          label = 'ether7-OLT-SFP2-TANJUNGPURA2 (OLT2)';
        } else if (iface.name === 'ether8-HOTSPOT-RADIO') {
          label = 'ether8-HOTSPOT-RADIO (Hotspot)';
        } else if (iface.name === 'ether9-HOTSPOT-SWICTHHUB') {
          label = 'ether9-HOTSPOT-SWICTHHUB (Switch)';
        } else if (iface.name === 'ether10-POP PEGAGAN/JANGGAR') {
          label = 'ether10-POP PEGAGAN/JANGGAR (POP)';
        } else if (iface.name === 'bridge1-HOTSPOT') {
          label = 'bridge1-HOTSPOT (Bridge)';
        } else if (iface.name === 'bridge2_OLT') {
          label = 'bridge2_OLT (Bridge OLT)';
        } else if (iface.name === 'vlan6-1100') {
          label = 'vlan6-1100 (VLAN)';
        }
        
        // Tambahkan status
        if (iface.disabled) {
          label += ' [Disabled]';
        } else if (!iface.running) {
          label += ' [Down]';
        } else {
          label += ' [Active]';
        }
        
        option.textContent = label;
        select.appendChild(option);
      });
      
      console.log('Info dashboard.');
      
      // Update current interface jika tidak ada di list
      // Perbaikan: Jangan paksa override currentInterface jika sudah ada di localStorage, kecuali benar-benar tidak valid
      // Biarkan user choice (dari localStorage) tetap menjadi prioritas
      
      const currentOption = select.querySelector(`option[value="${currentInterface}"]`);
      if (currentOption) {
          // Jika interface yang disimpan valid dan ada di list, set dropdown ke nilai tersebut
          select.value = currentInterface;
          document.getElementById('currentInterface').textContent = currentInterface;
      } else if (data.interfaces.length > 0) {
          // Jika interface yang disimpan TIDAK valid (misal ganti router), baru fallback ke interface pertama
          console.warn(`Interface ${currentInterface} not found in list, fallback to first available.`);
          currentInterface = data.interfaces[0].name;
          localStorage.setItem('selectedInterface', currentInterface);
          document.getElementById('currentInterface').textContent = currentInterface;
          select.value = currentInterface;
      }
      
    } else {
      console.warn('Peringatan proses dashboard.');
      console.warn('Response:', data);
    }
  } catch (error) {
    console.error('Terjadi error pada proses dashboard.');
    console.error('Error details:', error.message);
  }
}

