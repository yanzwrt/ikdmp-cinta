    }

    .dashboard-notification-item:hover,
    .dashboard-notification-item:focus {
        background: rgba(59, 130, 246, 0.06);
    }

    .dashboard-notification-icon {
        width: 38px;
        height: 38px;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 1rem;
        color: #fff;
    }

    .notification-danger { background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%); }
    .notification-primary { background: linear-gradient(135deg, #6d4bff 0%, #7c3aed 100%); }
    .notification-warning { background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); }
    .notification-info { background: linear-gradient(135deg, #0ea5e9 0%, #2563eb 100%); }
    .notification-success { background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%); }

    .dashboard-notification-copy {
        display: flex;
        flex-direction: column;
        gap: 2px;
        min-width: 0;
    }

    .dashboard-notification-title {
        color: #0f172a;
        font-weight: 800;
        font-size: 0.92rem;
    }

    .dashboard-notification-text {
        color: #475569;
        font-size: 0.82rem;
        line-height: 1.45;
    }

    .dashboard-notification-meta {
        color: #64748b;
        font-size: 0.75rem;
        font-weight: 700;
    }

    [data-theme="dark"] .dashboard-utility-btn {
        background: rgba(15, 23, 42, 0.72);
        border-color: rgba(148, 163, 184, 0.28) !important;
        color: #e2e8f0 !important;
        box-shadow: 0 18px 34px rgba(2, 8, 23, 0.28);
    }

    [data-theme="dark"] .dashboard-notification-menu {
        background: linear-gradient(180deg, rgba(8,17,32,0.98), rgba(13,23,40,0.98));
        border-color: rgba(148, 163, 184, 0.18) !important;
        box-shadow: 0 24px 48px rgba(2, 8, 23, 0.38);
    }

    [data-theme="dark"] .dashboard-notification-header {
        border-bottom-color: rgba(148, 163, 184, 0.14);
        background: linear-gradient(135deg, rgba(37, 99, 235, 0.16), rgba(99, 102, 241, 0.14));
    }

    [data-theme="dark"] .dashboard-notification-header strong,
    [data-theme="dark"] .dashboard-notification-title {
        color: #f8fafc !important;
    }

    [data-theme="dark"] .dashboard-notification-text,
    [data-theme="dark"] .dashboard-notification-empty .text-muted {
        color: #cbd5e1 !important;
    }

    [data-theme="dark"] .dashboard-notification-meta,
    [data-theme="dark"] .dashboard-notification-header .text-muted {
        color: #93a4bf !important;
    }

    @media (max-width: 767.98px) {
        .dashboard-action-toolbar {
            width: 100%;
            justify-content: flex-end;
        }

        .dashboard-notification-menu {
            width: min(340px, calc(100vw - 24px));
        }
    }

    .section-header {
        position: relative;
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 1rem !important;
    }

    .section-header::after {
        content: "";
        flex: 1;
        height: 1px;
        background: linear-gradient(90deg, rgba(99, 102, 241, 0.22), rgba(148, 163, 184, 0.08));
    }

    .section-header h6 {
        margin: 0;
        font-size: 0.78rem;
        letter-spacing: 0.18em;
        color: #5b6ea6 !important;
        font-weight: 800 !important;
    }

    [data-theme="dark"] .section-header h6 {
        color: #9db4df !important;
    }
</style>

<!-- GENIEACS SECTION -->
<div class="section-header mb-3 mt-4">
  <h6 class="text-uppercase text-muted fw-bold small ls-1">Node Status (GenieACS)</h6>
</div>
<div class="row g-4 mb-4">
  <div class="col-xl-4 col-md-6">
    <div class="card stat-card-modern stat-gradient-card stat-gradient-acs border-0 h-100" style="background: linear-gradient(135deg, #1f6feb 0%, #1d4ed8 100%) !important;">
      <div class="card-body p-4 d-flex align-items-center">
        <div class="stat-icon-box bg-light-primary text-primary me-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
          <i class="bi bi-router fs-3"></i>
        </div>
        <div>
          <div class="text-muted small fw-bold text-uppercase mb-1">Total ACS</div>
          <div class="stat-value fw-bold text-dark fs-2" id="genieacs-total">
            <% if (typeof genieacsTotal !== 'undefined' && genieacsTotal !== null) { %>
              <%= genieacsTotal %>
            <% } else { %>
              <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-xl-4 col-md-6">
    <div class="card stat-card-modern stat-gradient-card stat-gradient-online border-0 h-100" style="background: linear-gradient(135deg, #1fbf8f 0%, #0f9f8a 100%) !important;">
      <div class="card-body p-4 d-flex align-items-center">
        <div class="stat-icon-box bg-light-success text-success me-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
          <i class="bi bi-wifi fs-3"></i>
        </div>
        <div>
          <div class="text-muted small fw-bold text-uppercase mb-1">Online ONT</div>
          <div class="stat-value fw-bold text-success fs-2" id="genieacs-online">
            <% if (typeof genieacsOnline !== 'undefined' && genieacsOnline !== null) { %>
              <%= genieacsOnline %>
            <% } else { %>
              <div class="spinner-border spinner-border-sm text-success" role="status"></div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-xl-4 col-md-6">
    <div class="card stat-card-modern stat-gradient-card stat-gradient-lost border-0 h-100" style="background: linear-gradient(135deg, #ef476f 0%, #c1121f 100%) !important;">
      <div class="card-body p-4 d-flex align-items-center">
        <div class="stat-icon-box bg-light-danger text-danger me-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
          <i class="bi bi-wifi-off fs-3"></i>
        </div>
        <div>
          <div class="text-muted small fw-bold text-uppercase mb-1">Lost Signal</div>
          <div class="stat-value fw-bold text-danger fs-2" id="genieacs-offline">
            <% if (typeof genieacsOffline !== 'undefined' && genieacsOffline !== null) { %>
              <%= genieacsOffline %>
            <% } else { %>
              <div class="spinner-border spinner-border-sm text-danger" role="status"></div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- MIKROTIK SECTION -->
<div class="section-header mb-3 mt-4">
  <h6 class="text-uppercase text-muted fw-bold small ls-1">Connection Hub (Mikrotik)</h6>
</div>
<div class="row g-4 mb-4">
  <div class="col-xl-4 col-md-6">
    <div class="card stat-card-modern stat-gradient-card stat-gradient-pppoe border-0 h-100" style="background: linear-gradient(135deg, #0ea5e9 0%, #1d4ed8 100%) !important;">
      <div class="card-body p-4 d-flex align-items-center">
        <div class="stat-icon-box bg-light-info text-info me-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
          <i class="bi bi-people-fill fs-3"></i>
        </div>
        <div>
          <div class="text-muted small fw-bold text-uppercase mb-1">PPPoE Registries</div>
          <div class="stat-value fw-bold text-dark fs-2" id="mikrotik-total"><%= typeof mikrotikTotal !== 'undefined' ? mikrotikTotal : '-' %></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-xl-4 col-md-6">
    <div class="card stat-card-modern stat-gradient-card stat-gradient-uplink border-0 h-100" style="background: linear-gradient(135deg, #6366f1 0%, #4338ca 100%) !important;">
      <div class="card-body p-4 d-flex align-items-center">
        <div class="stat-icon-box bg-light-primary text-primary me-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
          <i class="bi bi-person-check-fill fs-3"></i>
        </div>
        <div>
          <div class="text-muted small fw-bold text-uppercase mb-1">Active Uplink</div>
          <div class="stat-value fw-bold text-primary fs-2" id="mikrotik-aktif"><%= typeof mikrotikAktif !== 'undefined' ? mikrotikAktif : '-' %></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-xl-4 col-md-6">
    <div class="card stat-card-modern stat-gradient-card stat-gradient-disconnected border-0 h-100" style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%) !important;">
      <div class="card-body p-4 d-flex align-items-center">
        <div class="stat-icon-box bg-light-warning text-warning me-3 rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
          <i class="bi bi-person-x-fill fs-3"></i>
        </div>
        <div>
          <div class="text-muted small fw-bold text-uppercase mb-1">Disconnected</div>
          <div class="stat-value fw-bold text-warning fs-2" id="mikrotik-offline"><%= typeof mikrotikOffline !== 'undefined' ? mikrotikOffline : '-' %></div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
.bg-light-primary { background-color: #eef2ff !important; }
.bg-light-success { background-color: #ecfdf5 !important; }
.bg-light-danger { background-color: #fef2f2 !important; }
.bg-light-info { background-color: #f0f9ff !important; }
.bg-light-warning { background-color: #fffbeb !important; }

.stat-card-modern {
  box-shadow: 0 18px 38px rgba(15, 23, 42, 0.09);
  transition: transform 0.28s ease, box-shadow 0.28s ease;
  border-radius: 24px !important;
}

.stat-card-modern:hover {
  transform: translateY(-7px);
  box-shadow: 0 28px 52px rgba(15, 23, 42, 0.14);
}

.stat-gradient-card {
  position: relative;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.28) !important;
  isolation: isolate;
}

.stat-gradient-card::before {
  content: "";
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at top right, rgba(255,255,255,0.28), transparent 42%),
    linear-gradient(180deg, rgba(255,255,255,0.08), transparent 55%);
  pointer-events: none;
}

.stat-gradient-card::after {
  content: "";
  position: absolute;
  inset: auto -52px -52px auto;
  width: 170px;
  height: 170px;
  border-radius: 999px;
  background: rgba(255,255,255,0.08);
  pointer-events: none;
}

.stat-gradient-acs { background: linear-gradient(135deg, #4f7cff 0%, #2756d8 100%) !important; }
.stat-gradient-online { background: linear-gradient(135deg, #20c997 0%, #0f9f8a 100%) !important; }
.stat-gradient-lost { background: linear-gradient(135deg, #ff5e7b 0%, #d7264c 100%) !important; }
.stat-gradient-pppoe { background: linear-gradient(135deg, #20b7f5 0%, #0b84d8 100%) !important; }
.stat-gradient-uplink { background: linear-gradient(135deg, #5f6bff 0%, #3a41d6 100%) !important; }
.stat-gradient-disconnected { background: linear-gradient(135deg, #f7b801 0%, #e28a00 100%) !important; }
/* Keep per-card gradient colors in dark mode (do not let global card background override) */
[data-theme="dark"] .stat-gradient-card.stat-gradient-acs { background-image: linear-gradient(135deg, #3366ff 0%, #1e3a8a 100%) !important; background-color: transparent !important; }
[data-theme="dark"] .stat-gradient-card.stat-gradient-online { background-image: linear-gradient(135deg, #16c784 0%, #0f766e 100%) !important; background-color: transparent !important; }
[data-theme="dark"] .stat-gradient-card.stat-gradient-lost { background-image: linear-gradient(135deg, #ff4d6d 0%, #be123c 100%) !important; background-color: transparent !important; }
[data-theme="dark"] .stat-gradient-card.stat-gradient-pppoe { background-image: linear-gradient(135deg, #0ea5e9 0%, #1d4ed8 100%) !important; background-color: transparent !important; }
[data-theme="dark"] .stat-gradient-card.stat-gradient-uplink { background-image: linear-gradient(135deg, #6366f1 0%, #3730a3 100%) !important; background-color: transparent !important; }
[data-theme="dark"] .stat-gradient-card.stat-gradient-disconnected { background-image: linear-gradient(135deg, #f59e0b 0%, #b45309 100%) !important; background-color: transparent !important; }

.stat-gradient-card .text-muted,
.stat-gradient-card .stat-value,
.stat-gradient-card .fw-bold {
  color: #ffffff !important;
}

.stat-gradient-card .card-body {
  min-height: 110px;
  padding: 1.05rem 1.2rem !important;
}

.stat-gradient-card .small {
  opacity: 0.88;
}

[data-theme="dark"] .stat-gradient-card .text-uppercase,
[data-theme="dark"] .stat-gradient-card .text-muted,
[data-theme="dark"] .stat-gradient-card .small {
  color: #ffffff !important;
  opacity: 1 !important;
}

.stat-gradient-card .stat-value {
  font-size: 1.95rem !important;
  letter-spacing: -0.03em;
  text-shadow: 0 10px 24px rgba(0,0,0,0.18);
}

.stat-icon-box {
