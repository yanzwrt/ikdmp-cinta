.metric-download { background: linear-gradient(135deg, #1d7df2 0%, #0058c9 100%) !important; }
.metric-upload { background: linear-gradient(135deg, #17c1a3 0%, #10997f 100%) !important; }
.metric-total { background: linear-gradient(135deg, #00b5e2 0%, #0077b6 100%) !important; }
.metric-status { background: linear-gradient(135deg, #5f6bff 0%, #3e49df 100%) !important; }
.metric-status.idle { background: linear-gradient(135deg, #6b7280 0%, #4b5563 100%) !important; }
