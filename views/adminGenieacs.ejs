<script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>
<script src="https://cdn.datatables.net/responsive/2.5.0/js/responsive.bootstrap5.min.js"></script>

<script>
$(document).ready(function(){
    console.log('Document ready, initializing DataTable...');
    
    // Inisialisasi DataTables
    var table = $('#genieacsTable').DataTable({
        "responsive": true,
        "scrollX": true,
        "autoWidth": false,
        "lengthMenu": [[20, 50, 100, -1], [20, 50, 100, "All"]],
        "pageLength": 20,
        "language": {
            "search": "Cari:",
            "lengthMenu": "Tampilkan _MENU_ data per halaman",
            "info": "Menampilkan _START_ sampai _END_ dari _TOTAL_ data",
            "infoEmpty": "Menampilkan 0 sampai 0 dari 0 data",
            "infoFiltered": "(difilter dari _MAX_ total data)",
            "paginate": {
                "first": "Pertama",
                "last": "Terakhir",
                "next": "Selanjutnya",
                "previous": "Sebelumnya"
            }
        },
        "columnDefs": [
            { "targets": [0], "responsivePriority": 1, "width": "5%" },
            { "targets": [1], "responsivePriority": 2, "width": "25%" },
            { "targets": [2], "responsivePriority": 4, "width": "20%" },
            { "targets": [3], "responsivePriority": 5, "width": "10%", "className": "text-center" },
            { "targets": [4], "responsivePriority": 6, "width": "15%" },
            { "targets": [5], "responsivePriority": 7, "width": "10%", "className": "text-center" },
            { "targets": [6], "responsivePriority": 3, "width": "10%", "className": "text-center" },
            { "targets": [-1], "responsivePriority": 2, "orderable": false, "width": "25%" }
        ]
    });
    
    console.log('DataTable initialized successfully');

    function isGenieacsDarkMode() {
        const body = document.body;
        const html = document.documentElement;
        const bTheme = (body?.getAttribute('data-theme') || '').toLowerCase();
        const hTheme = (html?.getAttribute('data-theme') || '').toLowerCase();
        const bClass = (body?.className || '').toLowerCase();
        const hClass = (html?.className || '').toLowerCase();
        return bTheme === 'dark' || hTheme === 'dark' || bClass.includes('dark') || hClass.includes('dark') || body?.classList.contains('genieacs-dark');
    }

    function applyGenieacsHeaderTheme() {
        const dark = isGenieacsDarkMode();
        const bg = dark ? '#1e293b' : '#f8fafc';
        const fg = dark ? '#ffffff' : '#111827';
        const bd = dark ? '#334155' : '#d1d5db';

        const headers = document.querySelectorAll('#genieacsTable thead th, .dataTables_scrollHead table thead th, .dataTables_scrollHeadInner table thead th');
        headers.forEach((th) => {
            th.style.setProperty('background-color', bg, 'important');
            th.style.setProperty('color', fg, 'important');
            th.style.setProperty('border-color', bd, 'important');
        });
    }

    function applyGenieacsModalTheme() {
        const dark = isGenieacsDarkMode();
        const modals = document.querySelectorAll('#editModal .modal-content, #editTagModal .modal-content, #restartOnuModal .modal-content');
        modals.forEach((m) => {
            if (dark) {
                m.style.setProperty('background-color', '#0f172a', 'important');
                m.style.setProperty('color', '#f8fafc', 'important');
                m.style.setProperty('border', '1px solid #334155', 'important');
            } else {
                m.style.removeProperty('background-color');
                m.style.removeProperty('color');
                m.style.removeProperty('border');
            }
        });
    }

    applyGenieacsHeaderTheme();
    applyGenieacsModalTheme();

    table.on('draw', function () {
        applyGenieacsHeaderTheme();
        applyGenieacsModalTheme();
    });
    setTimeout(applyGenieacsHeaderTheme, 150);
    setTimeout(applyGenieacsHeaderTheme, 700);

    // Event delegation tombol edit
    $(document).on('click', '.edit-btn', function(){
        const id = $(this).data('id');
        const ssid = $(this).data('ssid');
        const password = $(this).data('password');
        $('#deviceId').val(id);
        $('#ssid').val(ssid);
        $('#password').val(password);
        var modal = new bootstrap.Modal(document.getElementById('editModal'));
        modal.show();
        setTimeout(applyGenieacsModalTheme, 10);
    });

    // Fungsi alert dalam modal
    function showEditAlert(type, message) {
        $('#editAlert').removeClass().addClass('alert alert-' + type).html(message).show();
    }

    // Tombol simpan SSID - Versi Final
    $(document).on('click', '#saveSsidBtn', function(e){
        const id = $('#deviceId').val();
        const ssid = $('#ssid').val();
        
        // Validasi
        if (!ssid || ssid.length < 3 || ssid.length > 32) {
            e.preventDefault();
            showEditAlert('danger', 'SSID harus berisi 3-32 karakter!');
            return;
        }

        // Tampilkan notifikasi proses setelah modal tertutup
        setTimeout(function() {
            showToast('info', 'Memproses SSID...', `WiFi 2.4GHz: ${ssid} sedang diupdate. Mohon tunggu...`);
        }, 300);
        
        // Kirim request
        $.ajax({
            url: '/admin/genieacs/edit',
            method: 'POST',
            data: { id, ssid },
            success: function(res) {
                if (res.success) {
                    showToast('success', 'SSID Berhasil Diubah!', `WiFi 2.4GHz: ${res.newSSID} berhasil diupdate.`);
                    updateTableRow(id, 'ssid', ssid);
                } else {
                    showToast('error', 'Gagal Update SSID', res.message || 'Gagal update SSID!');
                }
            },
            error: function(err) {
                const errorMsg = err.responseJSON?.message || 'Gagal update SSID!';
                showToast('error', 'Error', errorMsg);
            }
        });
    });

    // Tombol simpan Password - Versi Final
    $(document).on('click', '#savePasswordBtn', function(e){
        const id = $('#deviceId').val();
        const password = $('#password').val();
        
        // Validasi
        if (!password || password.length < 8 || password.length > 63) {
            e.preventDefault();
            showEditAlert('danger', 'Password harus berisi 8-63 karakter!');
            return;
        }

        // Tampilkan notifikasi proses setelah modal tertutup
        setTimeout(function() {
            showToast('info', 'Memproses Password...', 'Password WiFi sedang diupdate. Mohon tunggu...');
        }, 300);
        
        // Kirim request
        $.ajax({
            url: '/admin/genieacs/edit',
            method: 'POST',
            data: { id, password },
            success: function(res) {
                if (res.success) {
                    showToast('success', 'Password Berhasil Diubah!', 'Password WiFi berhasil diupdate.');
                } else {
                    showToast('error', 'Gagal Update Password', res.message || 'Gagal update password!');
                }
            },
            error: function(err) {
                const errorMsg = err.responseJSON?.message || 'Gagal update password!';
                showToast('error', 'Error', errorMsg);
            }
        });
    });

    // Tombol restart perangkat setelah edit
    $('#rebootAfterEditBtn').on('click', function(e){
        e.preventDefault();
        const id = $('#deviceId').val();
        
        if (!id) {
            showEditAlert('danger', 'Device ID tidak ditemukan!');
            return;
        }

        const $btn = $(this);
        const originalText = $btn.html();
        $btn.prop('disabled', true).html('<i class="bi bi-hourglass-split"></i> Merestart...');
        
        $.ajax({
            url: '/admin/genieacs/restart-onu',
            method: 'POST',
            data: { id },
            success: function(res) {
                if (res.success) {
                    showEditAlert('success', 'Perintah restart berhasil dikirim!');
                    showToast('success', 'Restart Berhasil', 'Perangkat akan restart dalam beberapa menit untuk menerapkan perubahan.');
                    setTimeout(function(){ $('#editModal').modal('hide'); }, 2000);
                } else {
                    showEditAlert('danger', res.message || 'Gagal restart perangkat!');
                }
            },
            error: function(err) {
                const errorMsg = err.responseJSON?.message || 'Gagal restart perangkat!';
                showEditAlert('danger', errorMsg);
                showToast('error', 'Error Restart', errorMsg);
            },
            complete: function() {
                $btn.prop('disabled', false).html(originalText);
            }
        });
    });

    // Modal kembali ke halaman pertama DataTables saat ditutup
    $('#editModal').on('hidden.bs.modal', function () {
        if (table && table.page) {
            table.page('first').draw('page');
        }
    });
    
    // Event handler untuk modal hidden - kembali ke halaman pertama DataTables
    $('#editModal').on('hidden.bs.modal', function () {
        if (table && table.page) {
            table.page('first').draw('page');
        }
    });
    

    
    // Fungsi notifikasi
    function showAlert(message, type) {
        var alert = $(`<div class="alert alert-${type} alert-dismissible fade show" role="alert">
            ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>`);
        $('#alert-container').append(alert);
        setTimeout(function(){ alert.alert('close'); }, 3000);
    }

    // Fungsi toast notification yang modern dan reliable
    function showToast(type, title, message, duration = 5000) {
        try {
            const toastId = 'toast-' + Date.now();
            const iconClass = type === 'success' ? 'bi-check-circle' : type === 'error' ? 'bi-x-circle' : type === 'info' ? 'bi-info-circle' : 'bi-hourglass-split';
            const bgClass = type === 'success' ? 'bg-success' : type === 'error' ? 'bg-danger' : type === 'info' ? 'bg-primary' : 'bg-warning';
            
            const toastHtml = `
                <div id="${toastId}" class="toast align-items-center text-white ${bgClass} border-0" role="alert" aria-live="assertive" aria-atomic="true" style="position: fixed; top: 20px; right: 20px; z-index: 9999; min-width: 300px;">
                    <div class="d-flex">
                        <div class="toast-body">
                            <i class="bi ${iconClass} me-2"></i>
                            <strong>${title}</strong><br>
                            <small>${message}</small>
                        </div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                    </div>
                </div>
            `;
            
            // Append ke body langsung jika alert-container tidak ada
            const container = $('#alert-container');
            if (container.length > 0) {
                container.append(toastHtml);
            } else {
                $('body').append(toastHtml);
            }
            
            const toastElement = document.getElementById(toastId);
            if (toastElement) {
                const toast = new bootstrap.Toast(toastElement, { delay: duration });
                toast.show();
                
                // Auto remove after hide
                toastElement.addEventListener('hidden.bs.toast', () => {
                    toastElement.remove();
                });
            }
            
            return toastId;
        } catch (error) {
            console.error('Error in showToast:', error);
            // Fallback ke alert jika toast gagal
            alert(`${title}: ${message}`);
        }
    }



    // Fungsi update row di tabel tanpa reload
    function updateTableRow(deviceId, field, newValue) {
        try {
            // Find the row with the device ID
            table.rows().every(function(rowIdx, tableLoop, rowLoop) {
                const data = this.data();
                if (data && data.length > 0) {
                    // Check if this row contains the device ID (biasanya di kolom aksi)
                    const actionCell = data[data.length - 1]; // Last column is action
                    if (actionCell && actionCell.includes(deviceId)) {
                        if (field === 'ssid') {
                            // Update SSID column (index 2)
                            data[2] = newValue;
                            // Also update the SSID data attribute in action buttons
                            const updatedActionCell = actionCell.replace(/data-ssid="[^"]*"/, `data-ssid="${newValue}"`);
                            data[data.length - 1] = updatedActionCell;
                        }
                        this.data(data).draw(false);
                        return false; // Break the loop
                    }
                }
            });
        } catch (error) {
            console.error('Error updating table row:', error);
        }
    }
});
</script>

