<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title><%= title || 'Device GenieACS' %> - <%= typeof isTechnicianView !== 'undefined' && isTechnicianView ? 'Portal Teknisi' : 'Admin Panel' %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
    <link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet">
    <link href="https://cdn.datatables.net/responsive/2.5.0/css/dataTables.responsive.min.css" rel="stylesheet">
    <link href="https://cdn.datatables.net/responsive/2.5.0/css/responsive.bootstrap5.min.css" rel="stylesheet">
    <style>
        /* DataTables styling yang diperbaiki */
        .dataTables_wrapper .dataTables_length,
        .dataTables_wrapper .dataTables_filter,
        .dataTables_wrapper .dataTables_info,
        .dataTables_wrapper .dataTables_processing,
        .dataTables_wrapper .dataTables_paginate {
            margin: 10px 0;
            display: block !important;
            visibility: visible !important;
        }
        .dataTables_wrapper .dataTables_filter {
            float: right;
            text-align: right;
            margin-bottom: 10px;
        }
        .dataTables_wrapper .dataTables_filter input {
            border: 1px solid #ddd;
            border-radius: 4px;
            padding: 5px 10px;
            margin-left: 5px;
            width: 200px;
        }
        .dataTables_wrapper .dataTables_length {
            float: left;
            margin-bottom: 10px;
        }
        .dataTables_wrapper .dataTables_length select {
            border: 1px solid #ddd;
            border-radius: 4px;
            padding: 5px;
            margin: 0 5px;
        }
        .dataTables_wrapper .dataTables_paginate {
            float: right;
            margin-top: 10px;
        }
        .dataTables_wrapper .dataTables_paginate .paginate_button {
            border: 1px solid #ddd;
            border-radius: 4px;
            padding: 5px 10px;
            margin: 0 2px;
            cursor: pointer;
        }
        .dataTables_wrapper .dataTables_paginate .paginate_button.current {
            background: #007bff;
            color: white;
            border-color: #007bff;
        }
        .dataTables_wrapper .dataTables_info {
            clear: both;
            float: left;
            padding-top: 10px;
        }
        /* Pastikan wrapper terlihat */
        .dataTables_wrapper {
            display: block !important;
            visibility: visible !important;
        }
    </style>
    <link href="/css/responsive-admin.css" rel="stylesheet">
    <style>
        body { background: #f5f6fa; transition: background 0.3s ease; }
        .form-label { font-weight: 600; }
        .main-content {
            padding: 32px 24px;
        }
        .dashboard-hero {
            position: relative;
            overflow: hidden;
            border: 1px solid rgba(148, 163, 184, 0.22);
            border-radius: 24px;
            padding: 16px 20px;
            background:
                linear-gradient(145deg, rgba(255,255,255,0.88), rgba(244,247,255,0.82)),
                radial-gradient(circle at top left, rgba(96, 165, 250, 0.22), transparent 38%);
            backdrop-filter: blur(18px);
            box-shadow: 0 18px 44px rgba(37, 99, 235, 0.08);
            margin-bottom: 1.5rem;
        }
        .dashboard-hero::before {
            content: "";
            position: absolute;
            inset: auto -60px -110px auto;
            width: 220px;
            height: 220px;
            border-radius: 999px;
            background: radial-gradient(circle, rgba(96, 165, 250, 0.16), transparent 70%);
            pointer-events: none;
        }
        .dashboard-hero h4 {
            font-size: 2rem;
            font-weight: 800;
            letter-spacing: -0.03em;
            color: #1e293b;
            margin-bottom: 0.4rem;
        }
        .dashboard-hero p {
            color: #64748b;
            margin-bottom: 0;
        }
        .card {
            border: none;
            border-radius: 15px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            transition: all 0.3s ease;
            background-color: #fff;
        }
        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.1);
        }

        /* Modern Gradient Cards */
        .card.text-bg-primary {
            background: linear-gradient(135deg, #4e73df 0%, #224abe 100%) !important;
            border: none;
            box-shadow: 0 4px 15px rgba(78, 115, 223, 0.4) !important;
        }
        .card.text-bg-success {
            background: linear-gradient(135deg, #1cc88a 0%, #13855c 100%) !important;
            border: none;
            box-shadow: 0 4px 15px rgba(28, 200, 138, 0.4) !important;
        }
        .card.text-bg-danger {
            background: linear-gradient(135deg, #e74a3b 0%, #be2617 100%) !important;
            border: none;
            box-shadow: 0 4px 15px rgba(231, 74, 59, 0.4) !important;
        }
        
        /* DARK MODE SUPPORT */
        [data-theme="dark"] body {
            background-color: #0f172a !important;
            color: #f8fafc !important;
        }
        [data-theme="dark"] .main-content {
            background-color: #0f172a;
        }
        [data-theme="dark"] .dashboard-hero {
            background:
                linear-gradient(145deg, rgba(15,23,42,0.88), rgba(17,24,39,0.9)),
                radial-gradient(circle at top left, rgba(56, 189, 248, 0.14), transparent 42%);
            border-color: rgba(148, 163, 184, 0.22);
            box-shadow: 0 20px 42px rgba(2, 8, 23, 0.32);
        }
        [data-theme="dark"] .dashboard-hero h4 {
            color: #f8fafc !important;
        }
        [data-theme="dark"] .dashboard-hero p {
            color: #cbd5e1 !important;
        }
        [data-theme="dark"] .card {
            background-color: #1e293b;
            color: #f8fafc;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.5);
        }
        /* Keep stat cards colorful in dark mode */
        [data-theme="dark"] .card.text-bg-primary {
            background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%) !important;
            color: #fff !important;
        }
        [data-theme="dark"] .card.text-bg-success {
            background: linear-gradient(135deg, #0d9488 0%, #14b8a6 100%) !important;
            color: #fff !important;
        }
        [data-theme="dark"] .card.text-bg-danger {
            background: linear-gradient(135deg, #dc2626 0%, #f43f5e 100%) !important;
            color: #fff !important;
        }
        [data-theme="dark"] .card.text-bg-primary .text-white-50,
        [data-theme="dark"] .card.text-bg-success .text-white-50,
        [data-theme="dark"] .card.text-bg-danger .text-white-50 {
            color: rgba(255, 255, 255, 0.92) !important;
        }
        body.dark-mode .card.text-bg-primary,
        body.dark .card.text-bg-primary {
            background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%) !important;
            color: #fff !important;
        }

        @media (max-width: 768px) {
            .dashboard-hero {
                border-radius: 20px;
            }

            .dashboard-hero h4 {
                font-size: 1.75rem;
            }
        }
    </style>
<style>    /* Final mode-aware overrides for GenieACS */
    .card.text-bg-primary {
        background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%) !important;
        border: 1px solid rgba(59, 130, 246, 0.5) !important;
        color: #ffffff !important;
    }
    .card.text-bg-success {
        background: linear-gradient(135deg, #0d9488 0%, #14b8a6 100%) !important;
        border: 1px solid rgba(20, 184, 166, 0.5) !important;
        color: #ffffff !important;
    }
    .card.text-bg-danger {
        background: linear-gradient(135deg, #dc2626 0%, #f43f5e 100%) !important;
        border: 1px solid rgba(244, 63, 94, 0.5) !important;
        color: #ffffff !important;
    }
    .card.text-bg-primary .text-white-50,
    .card.text-bg-success .text-white-50,
    .card.text-bg-danger .text-white-50 {
        color: rgba(255,255,255,0.92) !important;
    }

    /* Light mode: teks tabel hitam dan jelas */
    body:not([data-theme="dark"]):not(.dark-mode):not(.dark) #genieacsTable thead th {
        background-color: #f8fafc !important;
        color: #111827 !important;
        border-color: #d1d5db !important;
    }
    body:not([data-theme="dark"]):not(.dark-mode):not(.dark) #genieacsTable tbody td,
    body:not([data-theme="dark"]):not(.dark-mode):not(.dark) #genieacsTable tbody th {
        color: #111827 !important;
        border-color: #e5e7eb !important;
    }

    /* Dark mode: header gelap + teks putih */
    /* DataTables generated header cells */
    body:not([data-theme="dark"]):not(.dark-mode):not(.dark) #genieacsTable.dataTable thead th,
    body:not([data-theme="dark"]):not(.dark-mode):not(.dark) #genieacsTable.dataTable thead td {
        background-color: #f8fafc !important;
        color: #111827 !important;
        border-color: #d1d5db !important;
    }
    body[data-theme="dark"] #genieacsTable.dataTable thead th,
    body[data-theme="dark"] #genieacsTable.dataTable thead td,
    body.dark-mode #genieacsTable.dataTable thead th,
    body.dark-mode #genieacsTable.dataTable thead td,
    body.dark #genieacsTable.dataTable thead th,
    body.dark #genieacsTable.dataTable thead td {
        background-color: #1e293b !important;
        color: #ffffff !important;
        border-color: #334155 !important;
    }
    body[data-theme="dark"] #genieacsTable thead th,
    body.dark-mode #genieacsTable thead th,
    body.dark #genieacsTable thead th {
        background-color: #1e293b !important;
        color: #ffffff !important;
        border-color: #334155 !important;
    }
    body[data-theme="dark"] #genieacsTable tbody td,
    body[data-theme="dark"] #genieacsTable tbody th,
    body.dark-mode #genieacsTable tbody td,
    body.dark-mode #genieacsTable tbody th,
    body.dark #genieacsTable tbody td,
    body.dark #genieacsTable tbody th {
        color: #f8fafc !important;
        border-color: rgba(148, 163, 184, 0.25) !important;
    }

    #genieacsTable .btn-group {
        display: flex;
        flex-wrap: nowrap;
        gap: 2px;
    }
    #genieacsTable .btn-group .btn {
        white-space: nowrap;
        font-size: 0.72rem;
        padding: 0.25rem 0.45rem;
        line-height: 1.2;
    }
</style>
</head>
<body>
<!-- Alert Container untuk Notifikasi -->
<div id="alert-container" style="position:fixed;top:70px;right:20px;z-index:1055;"></div>

<style>
/* Mobile alert positioning */
@media (max-width: 767.98px) {
    #alert-container {
        top: 80px !important; /* Below mobile navbar */
        right: 10px !important;
        left: 10px !important;
        width: auto !important;
    }
}
</style>

<style>
/* GenieACS theme lock (stable light/dark) */
body.genieacs-dark #genieacsTable thead th,
body.genieacs-dark #genieacsTable.dataTable thead th,
body.genieacs-dark #genieacsTable.dataTable thead td {
    background-color: #1e293b !important;
    color: #ffffff !important;
    border-color: #334155 !important;
}
body.genieacs-dark #genieacsTable tbody td,
body.genieacs-dark #genieacsTable tbody th {
    color: #f8fafc !important;
    border-color: rgba(148, 163, 184, 0.25) !important;
    background-color: #162033 !important;
}
body.genieacs-dark #genieacsTable.table-striped > tbody > tr:nth-of-type(odd) > * {
    color: #f8fafc !important;
    background-color: #162033 !important;
}
body.genieacs-dark #genieacsTable.table-striped > tbody > tr:nth-of-type(even) > * {
    color: #f8fafc !important;
    background-color: #1b263b !important;
}
body.genieacs-dark #genieacsTable.table-hover > tbody > tr:hover > * {
    color: #ffffff !important;
    background-color: #22314d !important;
}
body.genieacs-dark #genieacsTable tbody tr {
    color: #f8fafc !important;
}
body.genieacs-dark #genieacsTable tbody a,
body.genieacs-dark #genieacsTable tbody span,
body.genieacs-dark #genieacsTable tbody small,
body.genieacs-dark #genieacsTable tbody div {
    color: inherit !important;
}
body:not(.genieacs-dark) #genieacsTable thead th,
body:not(.genieacs-dark) #genieacsTable.dataTable thead th,
body:not(.genieacs-dark) #genieacsTable.dataTable thead td {
    background-color: #f8fafc !important;
    color: #111827 !important;
    border-color: #d1d5db !important;
}
body:not(.genieacs-dark) #genieacsTable tbody td,
body:not(.genieacs-dark) #genieacsTable tbody th {
    color: #111827 !important;
    border-color: #e5e7eb !important;
}

/* Edit modal follows theme */
body.genieacs-dark #editModal .modal-content,
body.genieacs-dark #editTagModal .modal-content,
body.genieacs-dark #restartOnuModal .modal-content {
    background-color: #0f172a !important;
    color: #f8fafc !important;
    border: 1px solid #334155 !important;
}
body.genieacs-dark #editModal .modal-header,
body.genieacs-dark #editModal .modal-footer,
body.genieacs-dark #editTagModal .modal-header,
body.genieacs-dark #editTagModal .modal-footer,
body.genieacs-dark #restartOnuModal .modal-header,
body.genieacs-dark #restartOnuModal .modal-footer {
    border-color: #334155 !important;
}
body.genieacs-dark #editModal .form-control,
body.genieacs-dark #editTagModal .form-control {
    background-color: #1e293b !important;
    color: #f8fafc !important;
    border-color: #334155 !important;
}
body.genieacs-dark #editModal .form-label,
body.genieacs-dark #editTagModal .form-label,
body.genieacs-dark #editModal .modal-title,
body.genieacs-dark #editTagModal .modal-title,
body.genieacs-dark #restartOnuModal .modal-title,
body.genieacs-dark #restartOnuModal .modal-body,
body.genieacs-dark #editModal .text-muted {
    color: #e2e8f0 !important;
}
</style>
<div class="container-fluid">
    <div class="row">
        <!-- Include Responsive Sidebar -->
        <% if (typeof isTechnicianView !== 'undefined' && isTechnicianView) { %>
            <%- include('partials/technician-responsive-sidebar', { page: 'monitoring', technician: technician }) %>
        <% } else { %>
            <%- include('partials/admin-responsive-sidebar', { page: 'genieacs', settings: settings }) %>
        <% } %>

        <main class="col-md-10 main-content ms-sm-auto">
            <div class="dashboard-hero d-flex justify-content-between align-items-start gap-3">
                <div>
                    <h4 class="mb-2"><%= title || 'Device GenieACS' %></h4>
                    <p>Kelola dan pantau perangkat GenieACS.</p>
                </div>
                <button class="btn btn-white shadow-sm border-0 rounded-pill" id="themeToggle" type="button" title="Ganti tema">
                    <i class="bi bi-sun-fill text-warning" id="themeIcon"></i>
                </button>
            </div>
            <!-- GENIEACS CARDS: Statistik -->
            <div class="row mb-4 g-3">
              <div class="col-md-4">
                <div class="card text-bg-primary h-100 overflow-hidden" style="background: linear-gradient(135deg,#2563eb 0%,#3b82f6 100%) !important; border:1px solid rgba(59,130,246,.5) !important;">
                  <div class="card-body p-3 d-flex align-items-center justify-content-between position-relative" style="background: transparent !important;">
                    <div class="z-1">
                        <div class="text-white-50 small fw-bold text-uppercase mb-1">Total Device</div>
                        <div class="fs-2 fw-bold text-white lh-sm" id="genieacs-total"><%= typeof genieacsTotal !== 'undefined' ? genieacsTotal : '-' %></div>
                    </div>
                    <div class="rounded-circle bg-white bg-opacity-25 p-3 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                        <i class="bi bi-hdd-network fs-3 text-white"></i>
                    </div>
                  </div>
                </div>
              </div>
              <div class="col-md-4">
                <div class="card text-bg-success h-100 overflow-hidden" style="background: linear-gradient(135deg,#0d9488 0%,#14b8a6 100%) !important; border:1px solid rgba(20,184,166,.5) !important;">
                  <div class="card-body p-3 d-flex align-items-center justify-content-between position-relative" style="background: transparent !important;">
                    <div class="z-1">
                        <div class="text-white-50 small fw-bold text-uppercase mb-1">Device Online</div>
                        <div class="fs-2 fw-bold text-white lh-sm" id="genieacs-online"><%= typeof genieacsOnline !== 'undefined' ? genieacsOnline : '-' %></div>
                    </div>
                    <div class="rounded-circle bg-white bg-opacity-25 p-3 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                        <i class="bi bi-wifi fs-3 text-white"></i>
                    </div>
                  </div>
                </div>
              </div>
              <div class="col-md-4">
                <div class="card text-bg-danger h-100 overflow-hidden" style="background: linear-gradient(135deg,#dc2626 0%,#f43f5e 100%) !important; border:1px solid rgba(244,63,94,.5) !important;">
                  <div class="card-body p-3 d-flex align-items-center justify-content-between position-relative" style="background: transparent !important;">
                    <div class="z-1">
                        <div class="text-white-50 small fw-bold text-uppercase mb-1">Device Offline</div>
                        <div class="fs-2 fw-bold text-white lh-sm" id="genieacs-offline"><%= typeof genieacsOffline !== 'undefined' ? genieacsOffline : '-' %></div>
                    </div>
                    <div class="rounded-circle bg-white bg-opacity-25 p-3 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                        <i class="bi bi-wifi-off fs-3 text-white"></i>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div class="card mb-4">
                <div class="card-body">
                    <h4 class="mb-3"><i class="bi bi-hdd-network"></i> <%= title || 'List Device GenieACS' %></h4>
                    <div class="table-responsive">
                        <table id="genieacsTable" class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>No</th>
                                    <th>PPPoE Username</th>
                                    <th>SSID</th>
                                    <th>User Konek</th>
                                    <th>Nomor Pelanggan</th>
                                    <th>RX Power</th>
                                    <th>Status</th>
                                    <th>Aksi</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% devices.forEach(function(device, i) { %>
                                <tr>
                                    <td><%= i+1 %></td>
                                    <td><%= device.pppoeUsername %></td>
                                    <td><%= device.ssid %></td>
                                    <td><%= device.userKonek %></td>
                                    <td><%= device.tag %></td>
                                    <% const rxValue = (typeof device.rxPower !== 'undefined' && device.rxPower !== null && String(device.rxPower).trim() !== '') ? String(device.rxPower).trim() : '-'; %>
                                    <% const hasExplicitStatus = typeof device.isOnline !== 'undefined' || typeof device.status !== 'undefined'; %>
                                    <% const isOnlineByRx = rxValue !== '-' && rxValue.toLowerCase() !== 'unknown' && rxValue.toLowerCase() !== 'n/a'; %>
                                    <% const isOnline = typeof device.isOnline !== 'undefined'
                                        ? Boolean(device.isOnline)
                                        : (typeof device.status === 'string'
                                            ? device.status.toLowerCase() === 'online'
                                            : isOnlineByRx); %>
                                    <td><%= rxValue %></td>
                                    <td>
                                        <% if (isOnline) { %>
                                            <span class="badge bg-success">Online</span>
                                        <% } else { %>
                                            <span class="badge bg-danger">Offline</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <button class="btn btn-warning edit-btn" data-id="<%= device.id %>" data-ssid="<%= device.ssid %>" data-password="<%= device.password %>" title="Edit SSID & Password"><i class="bi bi-pencil"></i> Edit SSID</button>
                                            <button class="btn btn-info edit-tag-btn" data-id="<%= device.id %>" data-tag="<%= device.tag || '' %>" title="Edit Tag"><i class="bi bi-tag"></i> Edit Tag</button>
                                            <button class="btn btn-secondary refresh-onu-btn" data-id="<%= device.id %>" data-serial="<%= device.serialNumber || device.id %>" title="Refresh ONU"><i class="bi bi-arrow-repeat"></i> Refresh</button>
                                            <button class="btn btn-danger restart-onu-btn" data-id="<%= device.id %>" data-serial="<%= device.serialNumber || device.id %>" title="Restart ONU"><i class="bi bi-arrow-clockwise"></i> Restart</button>
                                        </div>
                                    </td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>
<!-- Modal Edit SSID/Password -->
<div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="editModalLabel">Edit SSID & Password</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div id="editAlert" style="display:none;"></div>
        <input type="hidden" id="deviceId">
        <div class="mb-3">
          <label for="ssid" class="form-label">SSID</label>
          <input type="text" class="form-control" id="ssid">
          <button type="button" class="btn btn-success mt-2 w-100" id="saveSsidBtn" data-bs-dismiss="modal">Simpan SSID</button>
        </div>
        <div class="mb-3">
          <label for="password" class="form-label">Password</label>
          <input type="text" class="form-control" id="password">
          <button type="button" class="btn btn-primary mt-2 w-100" id="savePasswordBtn" data-bs-dismiss="modal">Simpan Password</button>
        </div>
      </div>
      <div class="modal-footer d-flex flex-column align-items-stretch gap-2">
        <div class="alert alert-info" role="alert">
          <i class="bi bi-info-circle"></i> <strong>Tips:</strong> Setelah mengubah SSID/Password, restart perangkat untuk menerapkan perubahan dengan cepat.
        </div>
        <button type="button" class="btn btn-warning w-100" id="rebootAfterEditBtn">
          <i class="bi bi-arrow-clockwise"></i> Restart Perangkat Setelah Edit
        </button>
        <button type="button" class="btn btn-secondary w-100" data-bs-dismiss="modal">Tutup</button>
      </div>
    </div>
  </div>
</div>

<script>
(function () {
  function updateThemeButton() {
    const icon = document.getElementById('themeIcon');
    if (!icon) return;
    const theme = ((document.documentElement.getAttribute('data-theme') || localStorage.getItem('theme') || 'light') + '').toLowerCase();
    icon.className = theme === 'dark' ? 'bi bi-moon-stars-fill text-white' : 'bi bi-sun-fill text-warning';
  }

  function toggleTheme() {
    const html = document.documentElement;
    const currentTheme = (html.getAttribute('data-theme') || localStorage.getItem('theme') || 'light').toLowerCase();
    const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', newTheme);
    localStorage.setItem('theme', newTheme);
    syncGenieacsTheme();
    updateThemeButton();
  }

  function hasDarkMarker(el) {
    if (!el) return false;
    const theme = (el.getAttribute('data-theme') || '').toLowerCase();
    const bsTheme = (el.getAttribute('data-bs-theme') || '').toLowerCase();
    const cls = (el.className || '').toLowerCase();
    return theme === 'dark' || bsTheme === 'dark' || cls.includes('dark');
  }

  function syncGenieacsTheme() {
    const body = document.body;
    const html = document.documentElement;
    if (!body || !html) return;

    const lsTheme = ((localStorage.getItem('theme') || localStorage.getItem('admin-theme') || '') + '').toLowerCase();
    const dark = hasDarkMarker(body) || hasDarkMarker(html) || lsTheme === 'dark';

    body.classList.toggle('genieacs-dark', dark);
    body.classList.toggle('genieacs-light', !dark);
  }

  document.addEventListener('DOMContentLoaded', function () {
    syncGenieacsTheme();
    updateThemeButton();

    const themeToggle = document.getElementById('themeToggle');
    if (themeToggle) {
      themeToggle.addEventListener('click', toggleTheme);
    }

    const obs = new MutationObserver(syncGenieacsTheme);
    obs.observe(document.documentElement, { attributes: true, attributeFilter: ['class', 'data-theme', 'data-bs-theme'] });
    if (document.body) {
      obs.observe(document.body, { attributes: true, attributeFilter: ['class', 'data-theme', 'data-bs-theme'] });
    }

    window.addEventListener('storage', syncGenieacsTheme);
    setInterval(syncGenieacsTheme, 1200);
  });
})();
</script>
<!-- Scripts - hanya satu set jQuery dan Bootstrap -->
<script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
