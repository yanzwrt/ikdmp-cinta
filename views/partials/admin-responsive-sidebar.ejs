}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const SIDEBAR_STATE_KEY = 'globalAdminSidebarCollapsed';
    const sidebarToggle = document.getElementById('sidebarToggle');
    const sidebarClose = document.getElementById('sidebarClose');
    const sidebar = document.getElementById('adminSidebar');
    const overlay = document.getElementById('sidebarOverlay');
    const hamburger = document.getElementById('hamburgerBtn');
    const desktopToggle = document.getElementById('desktopSidebarToggle');

    function isDesktop() {
        return window.innerWidth >= 768;
    }

    function setDisplay(selector, displayValue) {
        document.querySelectorAll(selector).forEach(el => {
            el.style.display = displayValue;
        });
    }

    function applySidebarCollapsedState(collapsed) {
        if (!sidebar) return;

        const mainContent = document.querySelector('.main-content');
        sidebar.classList.toggle('collapsed', collapsed);
        if (mainContent) {
            mainContent.classList.toggle('expanded', collapsed);
        }

        if (collapsed) {
            setDisplay('.company-name', 'none');
            setDisplay('.version-badge-container', 'none');
            setDisplay('.nav-link span', 'none');
            setDisplay('.nav-section-header', 'none');
            setDisplay('.bi-chevron-right', 'none');
            setDisplay('.sidebar-footer #updateResult', 'none');

            const logoContainer = document.querySelector('.logo-container');
            const sidebarLogo = document.querySelector('.sidebar-logo');
            if (logoContainer) logoContainer.style.padding = '6px';
            if (sidebarLogo) {
                sidebarLogo.style.maxWidth = '34px';
                sidebarLogo.style.maxHeight = '24px';
            }
        } else {
            setDisplay('.company-name', 'block');
            setDisplay('.version-badge-container', 'block');
            setDisplay('.nav-link span', 'block');
            setDisplay('.nav-section-header', 'block');
            setDisplay('.bi-chevron-right', 'block');

            const logoContainer = document.querySelector('.logo-container');
            const sidebarLogo = document.querySelector('.sidebar-logo');
            if (logoContainer) logoContainer.style.padding = '10px';
            if (sidebarLogo) {
                sidebarLogo.style.maxWidth = '80px';
                sidebarLogo.style.maxHeight = '40px';
            }
        }
    }

    function saveSidebarState(collapsed) {
        try {
            localStorage.setItem(SIDEBAR_STATE_KEY, collapsed ? '1' : '0');
        } catch (e) {
            console.warn('Tidak bisa simpan state sidebar:', e);
        }
    }

    function loadSidebarState() {
        try {
            const v = localStorage.getItem(SIDEBAR_STATE_KEY);
            if (v !== null) return v === '1';
            // Backward compatibility with old key
            return localStorage.getItem('adminSidebarCollapsed') === '1' || localStorage.getItem('billingSidebarCollapsed') === '1';
        } catch (e) {
            return false;
        }
    }

    applySidebarCollapsedState(isDesktop() ? loadSidebarState() : false);
    function applySavedTheme() {
        const savedTheme = localStorage.getItem('theme') || 'light';
        document.body.setAttribute('data-theme', savedTheme);
        document.documentElement.setAttribute('data-theme', savedTheme);
    }

    // Apply theme on every page that uses this sidebar
    applySavedTheme();

    // Sync across tabs/windows
    window.addEventListener('storage', function(event) {
        if (event.key === 'theme') {
            applySavedTheme();
        }
    });

    if (sidebarToggle) {
        sidebarToggle.addEventListener('click', function() {
            sidebar.classList.add('show');
            overlay.classList.add('show');
            document.body.style.overflow = 'hidden';
        });
    }

    if (desktopToggle) {
        desktopToggle.addEventListener('click', function() {
            const willCollapse = !sidebar.classList.contains('collapsed');
            applySidebarCollapsedState(willCollapse);
            saveSidebarState(willCollapse);
        });
    }

    if (hamburger) {
        hamburger.addEventListener('click', function() {
            sidebar.classList.toggle('show');
            overlay.classList.toggle('show');
        });
    }

    function closeSidebar() {
        sidebar.classList.remove('show');
        overlay.classList.remove('show');
        document.body.style.overflow = '';
    }

    if (sidebarClose) {
        sidebarClose.addEventListener('click', closeSidebar);
    }

    if (overlay) {
        overlay.addEventListener('click', closeSidebar);
    }

    const navLinks = sidebar.querySelectorAll('a:not(#restartMikrotikBtn)');
    navLinks.forEach(link => {
        link.addEventListener('click', function() {
            if (window.innerWidth < 768) {
                setTimeout(closeSidebar, 100);
            }
        });
    });

    window.addEventListener('resize', function() {
        if (window.innerWidth >= 768) {
            closeSidebar();
            applySidebarCollapsedState(loadSidebarState());
        } else {
            applySidebarCollapsedState(false);
        }
    });

    const restartBtn = document.getElementById('restartMikrotikBtn');
    if (restartBtn) {
        restartBtn.addEventListener('click', function(e) {
            e.preventDefault();
            if (confirm('Apakah Anda yakin ingin restart Mikrotik?')) {
                fetch('/admin/mikrotik/restart', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('Mikrotik berhasil direstart');
                    } else {
                        alert('Gagal restart Mikrotik: ' + data.message);
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Terjadi kesalahan saat restart Mikrotik');
                });
            }
        });
    }

    const btnCheck = document.getElementById('btnCheckUpdate');
    const btnUpdate = document.getElementById('btnRunUpdate');
    const resultBox = document.getElementById('updateResult');

    function showUpdateResult(text, success = true) {
        if (!resultBox) return;
        resultBox.style.display = 'block';
        resultBox.style.color = success ? '#c8e6c9' : '#ffcdd2';
        resultBox.textContent = text;
    }

    if (btnCheck) {
        btnCheck.addEventListener('click', async function() {
            try {
                showUpdateResult('Checking updates...', true);
                const b = (document.getElementById('gitBranchInput') && document.getElementById('gitBranchInput').value.trim()) || '';
                const url = b ? `/admin/billing/system/check-update?branch=${encodeURIComponent(b)}` : '/admin/billing/system/check-update';
                const res = await fetch(url);
                const data = await res.json();
                if (!data.success) {
                    showUpdateResult('Check update failed: ' + (data.message || 'Unknown error'), false);
                    return;
                }
                const summary = data.hasUpdate
                    ? `Update tersedia di branch ${data.branch}.\nLocal: ${data.local}\nRemote: ${data.remote}\nCommits:\n${data.commits || '(no list)'}`
                    : `Tidak ada update.\nBranch: ${data.branch}\nLocal == Remote: ${data.local}`;
                showUpdateResult(summary, true);
            } catch (e) {
                showUpdateResult('Check update error: ' + e.message, false);
            }
        });
    }

    if (btnUpdate) {
        btnUpdate.addEventListener('click', async function() {
            if (!confirm('Peringatan: mohon backup file settings.json terlebih dahulu. Lanjutkan update & restart?')) return;
            try {
                showUpdateResult('Running update... this may take a while.', true);
                const b = (document.getElementById('gitBranchInput') && document.getElementById('gitBranchInput').value.trim()) || '';
                const res = await fetch('/admin/billing/system/update', { method: 'POST', headers: { 'Content-Type':'application/json' }, body: JSON.stringify({ branch: b || undefined }) });
                const data = await res.json();
                if (!data.success) {
                    showUpdateResult('Update failed: ' + (data.message || 'Unknown error') + '\n' + (data.error || '') + '\n' + (data.log || ''), false);
                    return;
                }
                showUpdateResult('Update selesai. Aplikasi akan direload oleh PM2.\n' + (data.log || ''), true);
            } catch (e) {
                showUpdateResult('Update error: ' + e.message, false);
            }
        });
    }

    function refreshLogo() {
        const logo = document.getElementById('logoImage');
        if (logo) {
            const timestamp = new Date().getTime();
            const src = logo.src.split('?')[0];
            logo.src = `${src}?v=${timestamp}`;
        }
    }

    if (document.getElementById('logoImage')) {
        setInterval(refreshLogo, 5000);
    }

    const submenuToggles = document.querySelectorAll('.submenu-toggle[data-submenu-target]');
    submenuToggles.forEach(toggle => {
        toggle.addEventListener('click', function(e) {
            if (sidebar.classList.contains('collapsed') && window.innerWidth >= 768) {
                return;
            }
            e.preventDefault();

            const targetId = this.getAttribute('data-submenu-target');
            const submenu = document.getElementById(targetId);
            const parentItem = this.closest('.has-submenu');
            if (!submenu || !parentItem) return;

            const willShow = !submenu.classList.contains('show');
            submenu.classList.toggle('show', willShow);
            parentItem.classList.toggle('open', willShow);
            this.setAttribute('aria-expanded', willShow ? 'true' : 'false');
        });
    });
});
</script>























