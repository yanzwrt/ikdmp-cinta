<%
    const headerAgent = (typeof agent !== 'undefined' && agent) ? agent : ((typeof agentData !== 'undefined' && agentData) ? agentData : null);
    const agentHeaderName = headerAgent?.name || 'Agent';
    const agentHeaderUsername = headerAgent?.username || headerAgent?.phone || 'agent';
    const agentHeaderPhoto = headerAgent?.profile_photo ? `/img/agent-profiles/${headerAgent.profile_photo}` : '';
    const agentHeaderInitial = String(agentHeaderName || 'A').trim().charAt(0).toUpperCase();
%>
<div class="agent-mobile-topbar d-md-none">
    <div class="agent-mobile-topbar__identity">
        <div class="agent-mobile-topbar__avatar">
            <% if (agentHeaderPhoto) { %>
                <img src="<%= agentHeaderPhoto %>" alt="Foto Profil <%= agentHeaderName %>">
            <% } else { %>
                <span><%= agentHeaderInitial %></span>
            <% } %>
        </div>
        <div class="agent-mobile-topbar__text">
            <strong><%= agentHeaderName %></strong>
            <small>@<%= agentHeaderUsername %></small>
        </div>
    </div>
    <div class="agent-mobile-topbar__actions">
        <a href="/agent/chat" class="agent-mobile-topbar__action text-decoration-none" aria-label="Chat admin">
            <i class="fas fa-comments"></i>
        </a>
        <button type="button" class="agent-mobile-topbar__action" id="agentNotificationToggle" aria-label="Notifikasi agent">
            <i class="fas fa-bell"></i>
            <span class="agent-mobile-topbar__badge d-none" id="agentTopbarBadge">0</span>
        </button>
        <button type="button" class="agent-mobile-topbar__action" id="agentTopMenuBtn" aria-label="Buka menu">
            <i class="fas fa-bars"></i>
        </button>
    </div>
</div>

<div class="agent-mobile-quick-menu d-md-none" id="agentQuickMenu">
    <a href="/agent/dashboard" class="agent-mobile-quick-menu__item">
        <i class="fas fa-home"></i>
        <span>Dashboard</span>
    </a>
    <a href="/agent/vouchers" class="agent-mobile-quick-menu__item">
        <i class="fas fa-ticket-alt"></i>
        <span>Voucher</span>
    </a>
    <a href="/agent/payments" class="agent-mobile-quick-menu__item">
        <i class="fas fa-credit-card"></i>
        <span>Pembayaran</span>
    </a>
    <a href="/agent/transactions" class="agent-mobile-quick-menu__item">
        <i class="fas fa-history"></i>
        <span>Riwayat</span>
    </a>
    <a href="/agent/chat" class="agent-mobile-quick-menu__item">
        <i class="fas fa-comments"></i>
        <span>Chat Admin</span>
    </a>
    <a href="/agent/balance" class="agent-mobile-quick-menu__item">
        <i class="fas fa-wallet"></i>
        <span>Saldo</span>
    </a>
    <a href="/agent/profile" class="agent-mobile-quick-menu__item">
        <i class="fas fa-user"></i>
        <span>Profil</span>
    </a>
    <a href="/agent/change-password" class="agent-mobile-quick-menu__item">
        <i class="fas fa-key"></i>
        <span>Ubah Password</span>
    </a>
    <a href="/agent/logout" class="agent-mobile-quick-menu__item agent-mobile-quick-menu__item--danger">
        <i class="fas fa-sign-out-alt"></i>
        <span>Logout</span>
    </a>
</div>

<div class="agent-notification-overlay d-md-none" id="agentNotificationOverlay"></div>
<div class="agent-notification-panel d-md-none" id="agentNotificationPanel" aria-hidden="true">
    <div class="agent-notification-panel__header">
        <div>
            <h5>Notifikasi Agent</h5>
            <p>Voucher, saldo, pembayaran, dan info terbaru.</p>
        </div>
        <button type="button" class="agent-notification-panel__close" id="agentNotificationClose" aria-label="Tutup notifikasi">
            <i class="fas fa-times"></i>
        </button>
    </div>
    <div class="agent-notification-list" id="agentNotificationList"></div>
</div>

<nav class="agent-bottom-nav d-md-none" id="agentBottomNav">
    <a class="agent-bot-nav-item" data-path="/agent/dashboard" href="/agent/dashboard">
        <i class="fas fa-home"></i>
        <span>Home</span>
    </a>
    <a class="agent-bot-nav-item" data-path="/agent/vouchers,/agent/voucher-history" href="/agent/vouchers">
        <i class="fas fa-ticket-alt"></i>
        <span>Voucher</span>
    </a>
    <a class="agent-bot-nav-item" data-path="/agent/payments,/agent/payment-history" href="/agent/payments">
        <i class="fas fa-credit-card"></i>
        <span>Bayar</span>
    </a>
    <a class="agent-bot-nav-item" data-path="/agent/transactions,/agent/balance" href="/agent/transactions">
        <i class="fas fa-history"></i>
        <span>Riwayat</span>
    </a>
    <a class="agent-bot-nav-item" data-path="/agent/profile,/agent/notifications,/agent/change-password" href="/agent/profile">
        <i class="fas fa-user"></i>
        <span>Profil</span>
    </a>
</nav>

