        .container,
        .container-fluid,
        .main-content {
            width: 100% !important;
            max-width: 100% !important;
            overflow: visible !important;
        }

        .mobile-container {
            padding-bottom: 120px !important;
        }

        .navbar {
            display: none !important;
        }

        .bottom-nav {
            display: none !important;
        }
    }

    @media (min-width: 768px) {
        .agent-mobile-topbar,
        .agent-mobile-quick-menu,
        .agent-notification-panel,
        .agent-notification-overlay,
        .agent-bottom-nav {
            display: none !important;
        }
    }
</style>

<script>
    (function () {
        const readStorageKey = 'agentNotificationReadMap';
        const nav = document.getElementById('agentBottomNav');
        const topMenuBtn = document.getElementById('agentTopMenuBtn');
        const quickMenu = document.getElementById('agentQuickMenu');
        const bellBtn = document.getElementById('agentNotificationToggle');
        const panel = document.getElementById('agentNotificationPanel');
        const overlay = document.getElementById('agentNotificationOverlay');
        const listWrap = document.getElementById('agentNotificationList');

        function getReadMap() {
            try { return JSON.parse(localStorage.getItem(readStorageKey) || '{}') || {}; }
            catch (error) { return {}; }
        }

        function setReadMap(map) {
            localStorage.setItem(readStorageKey, JSON.stringify(map || {}));
        }

        function normalize(items) {
            return Array.isArray(items) ? items.filter(Boolean).map((item) => ({
                id: String(item.id || ''),
                title: String(item.title || 'Notifikasi Agent'),
                message: String(item.message || ''),
                type: String(item.type || 'info'),
                link: String(item.link || '/agent/notifications'),
                updatedAt: String(item.updatedAt || item.createdAt || ''),
                createdAt: String(item.createdAt || item.updatedAt || ''),
                marker: String(item.marker || item.updatedAt || item.createdAt || '')
            })).filter((item) => item.id) : [];
        }

        function getUnread(items) {
            const readMap = getReadMap();
            return normalize(items).filter((item) => readMap[item.id] !== item.marker);
        }

        function markSingleRead(id, marker) {
            const readMap = getReadMap();
            readMap[String(id)] = String(marker || new Date().toISOString());
            setReadMap(readMap);
        }

        function renderBadge(count) {
            const badge = document.getElementById('agentTopbarBadge');
            if (!badge) return;
            if (count > 0) {
                badge.textContent = count > 9 ? '9+' : String(count);
                badge.classList.remove('d-none');
            } else {
                badge.classList.add('d-none');
            }
        }

        function iconFor(type) {
            if (type.includes('voucher')) return 'fas fa-ticket-alt';
            if (type.includes('balance')) return 'fas fa-wallet';
            if (type.includes('payment')) return 'fas fa-credit-card';
            return 'fas fa-bell';
        }

        function renderList(items) {
            const unreadIds = new Set(getUnread(items).map((item) => item.id));
            if (!listWrap) return;
            if (!items.length) {
                listWrap.innerHTML = '<div class="agent-notification-empty"><i class="fas fa-bell-slash mb-2"></i><div>Belum ada notifikasi</div></div>';
                return;
            }
            listWrap.innerHTML = items.map((item) => `
                <a href="${item.link}" class="agent-notification-item ${unreadIds.has(item.id) ? 'is-unread' : ''}" data-agent-notification-id="${item.id}" data-agent-notification-marker="${item.marker}">
                    <div class="agent-notification-item__icon"><i class="${iconFor(item.type)}"></i></div>
                    <div class="agent-notification-item__content">
                        <div class="agent-notification-item__top">
                            <h6>${item.title}</h6>
                            ${unreadIds.has(item.id) ? '<span class="agent-notification-item__badge">Baru</span>' : ''}
                        </div>
                        <p>${item.message}</p>
                        <small>${item.updatedAt ? new Date(item.updatedAt).toLocaleString('id-ID') : ''}</small>
                    </div>
                </a>
            `).join('');
        }

        function openPanel() {
            if (panel) panel.classList.add('is-open');
            if (overlay) overlay.classList.add('is-open');
        }

        function closePanel() {
            if (panel) panel.classList.remove('is-open');
            if (overlay) overlay.classList.remove('is-open');
        }

        async function refreshSummary() {
            try {
                const response = await fetch('/agent/api/notifications/summary', { headers: { Accept: 'application/json' }, cache: 'no-store' });
                if (!response.ok) return;
                const payload = await response.json();
                if (!payload.success) return;
                const notifications = normalize(payload.notifications);
                window.__agentNotifications = notifications;
                const unread = getUnread(notifications);
                renderBadge(unread.length);
                renderList(notifications);
            } catch (error) {
                console.warn('Gagal memuat notifikasi agent:', error);
            }
        }

        if (topMenuBtn && quickMenu) {
            topMenuBtn.addEventListener('click', (event) => {
                event.preventDefault();
                event.stopPropagation();
                closePanel();
                quickMenu.classList.toggle('show');
            });
        }

        if (bellBtn) {
            bellBtn.addEventListener('click', (event) => {
                event.preventDefault();
                event.stopPropagation();
                if (quickMenu) quickMenu.classList.remove('show');
                if (panel && panel.classList.contains('is-open')) closePanel();
                else openPanel();
            });
        }

        document.addEventListener('click', (event) => {
            const item = event.target.closest('[data-agent-notification-id]');
            if (item) {
                markSingleRead(item.getAttribute('data-agent-notification-id'), item.getAttribute('data-agent-notification-marker'));
                setTimeout(refreshSummary, 50);
                closePanel();
                return;
            }
            if (event.target.closest('#agentNotificationClose') || event.target.closest('#agentNotificationOverlay')) {
                closePanel();
                return;
            }
            if (quickMenu && quickMenu.classList.contains('show') && !quickMenu.contains(event.target) && !topMenuBtn.contains(event.target)) {
                quickMenu.classList.remove('show');
            }
        });

        if (nav) {
            const currentPath = window.location.pathname;
            nav.querySelectorAll('.agent-bot-nav-item').forEach((item) => {
                const matches = (item.dataset.path || '').split(',').map((value) => value.trim()).filter(Boolean);
                if (matches.some((path) => currentPath.startsWith(path))) item.classList.add('active');
            });
        }

        document.addEventListener('DOMContentLoaded', function () {
            refreshSummary();
            setInterval(refreshSummary, 30000);
        });
    })();
</script>
