<!-- PWA Install Prompt -->
<div id="pwa-install-prompt" class="pwa-install-prompt" style="display: none;">
    <div class="pwa-content">
        <div class="pwa-icon">
            <img src="/icons/icon-192x192.png" alt="App Icon">
        </div>
        <div class="pwa-info">
            <h5>Install Aplikasi Teknisi</h5>
            <p>Akses cepat & monitoring real-time</p>
        </div>
        <button id="pwa-install-btn" class="btn btn-primary btn-sm rounded-pill px-3">Install</button>
        <button id="pwa-dismiss-btn" class="btn-close-pwa"><i class="bx bx-x"></i></button>
    </div>
</div>
<link href="/css/pwa-install.css" rel="stylesheet">