    <style>
        .app-footer {
            background: #f8f9fa;
            color: #212529;
            border-color: #dee2e6 !important;
        }
        .app-footer .text-muted {
            color: #6c757d !important;
        }
        .app-footer hr {
            border-color: #dee2e6;
            opacity: 1;
        }

        body.footer-dark .app-footer,
        body[data-theme="dark"] .app-footer,
        html[data-theme="dark"] .app-footer,
        body[data-bs-theme="dark"] .app-footer,
        html[data-bs-theme="dark"] .app-footer,
        body.dark .app-footer,
        body.dark-mode .app-footer,
        html.dark .app-footer,
        html.dark-mode .app-footer {
            background: #0f172a !important;
            color: #e5e7eb !important;
            border-color: #334155 !important;
        }

        body.footer-dark .app-footer .text-muted,
        body[data-theme="dark"] .app-footer .text-muted,
        html[data-theme="dark"] .app-footer .text-muted,
        body[data-bs-theme="dark"] .app-footer .text-muted,
        html[data-bs-theme="dark"] .app-footer .text-muted,
        body.dark .app-footer .text-muted,
        body.dark-mode .app-footer .text-muted,
        html.dark .app-footer .text-muted,
        html.dark-mode .app-footer .text-muted {
            color: #cbd5e1 !important;
        }

        body.footer-dark .app-footer hr,
        body[data-theme="dark"] .app-footer hr,
        html[data-theme="dark"] .app-footer hr,
        body[data-bs-theme="dark"] .app-footer hr,
        html[data-bs-theme="dark"] .app-footer hr,
        body.dark .app-footer hr,
        body.dark-mode .app-footer hr,
        html.dark .app-footer hr,
        html.dark-mode .app-footer hr {
            border-color: #334155 !important;
        }

        body.footer-dark .app-footer .text-primary,
        body[data-theme="dark"] .app-footer .text-primary,
        html[data-theme="dark"] .app-footer .text-primary,
        body[data-bs-theme="dark"] .app-footer .text-primary,
        html[data-bs-theme="dark"] .app-footer .text-primary,
        body.dark .app-footer .text-primary,
        body.dark-mode .app-footer .text-primary,
        html.dark .app-footer .text-primary,
        html.dark-mode .app-footer .text-primary {
            color: #60a5fa !important;
        }
    </style>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
    (function(){
        function isDarkTheme() {
            const b = document.body;
            const h = document.documentElement;
            const bt = (b.getAttribute('data-theme') || '').toLowerCase();
            const ht = (h.getAttribute('data-theme') || '').toLowerCase();
            const bdt = (b.getAttribute('data-bs-theme') || '').toLowerCase();
            const hdt = (h.getAttribute('data-bs-theme') || '').toLowerCase();
            const bc = (b.className || '').toLowerCase();
            const hc = (h.className || '').toLowerCase();
            const ls = ((localStorage.getItem('theme') || localStorage.getItem('admin-theme') || '') + '').toLowerCase();
            return bt === 'dark' || ht === 'dark' || bdt === 'dark' || hdt === 'dark' || bc.includes('dark') || hc.includes('dark') || ls === 'dark';
        }

        function syncFooterTheme() {
            const isDark = isDarkTheme();
            document.body.classList.toggle('footer-dark', isDark);

            const footer = document.getElementById('appFooter');
            if (!footer) return;

            // Fallback inline style agar tidak tertimpa style per halaman.
            if (isDark) {
                footer.style.background = '#0f172a';
                footer.style.color = '#e5e7eb';
                footer.style.borderTopColor = '#334155';
            } else {
                footer.style.background = '#f8f9fa';
                footer.style.color = '#212529';
                footer.style.borderTopColor = '#dee2e6';
            }
        }

        document.addEventListener('DOMContentLoaded', function() {
            syncFooterTheme();
            const obs = new MutationObserver(syncFooterTheme);
            obs.observe(document.documentElement, { attributes: true, attributeFilter: ['class', 'data-theme', 'data-bs-theme'] });
            obs.observe(document.body, { attributes: true, attributeFilter: ['class', 'data-theme', 'data-bs-theme'] });
            setInterval(syncFooterTheme, 1200);
        });
    })();
    </script>

    <!-- Global Alert Function -->
    <script>
    function showAlert(message, type = 'info') {
        const alertDiv = document.createElement('div');
        alertDiv.className = `alert alert-${type} alert-dismissible fade show position-fixed`;
        alertDiv.style.cssText = 'top: 20px; right: 20px; z-index: 9999; min-width: 300px;';
        alertDiv.innerHTML = `
            ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        `;

        document.body.appendChild(alertDiv);

        // Auto dismiss after 5 seconds
        setTimeout(() => {
            if (alertDiv.parentNode) {
                alertDiv.remove();
            }
        }, 5000);
    }

    // Initialize tooltips
    document.addEventListener('DOMContentLoaded', function() {
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl);
        });
    });
    </script>
</body>
